open use "prelude.disp"
trust open use "kernel.disp"

let Type_0 = Type 0
let SimpleBool = Pi Type_0 ({A} -> Pi A ({_} -> Pi A ({_} -> A)))

let TTs = {A, ct, cf} -> ct
let FFs = {A, ct, cf} -> cf

// Predicate accepts both constructors
test SimpleBool TTs = TT
test SimpleBool FFs = TT

// =================================================================
// Hypothesis-typed Bool: does hyp_reduce work?
// =================================================================

let bool_hyp = Hyp SimpleBool 0
test is_neutral bool_hyp = TT

// Apply hypothesis to type Nat. SimpleBool is literally a Pi
// (with unguard), so hyp_reduce should fire and extend the spine.
// New stored type should be the Pi codomain at A=Nat:
//   Pi Nat ({_} -> Pi Nat ({_} -> Nat))
let bool_hyp_at_nat = bool_hyp Nat
test is_neutral bool_hyp_at_nat = TT

let expected_after_nat = Pi Nat ({_} -> Pi Nat ({_} -> Nat))
test neutral_type bool_hyp_at_nat = expected_after_nat

// Apply two more args.
let bool_hyp_full = bool_hyp Nat 5 7
test is_neutral bool_hyp_full = TT
test neutral_type bool_hyp_full = Nat

// =================================================================
// Library-level eliminator (identity-applied) on hypothesis target
// =================================================================

let bool_rec_simple = {A, ct, cf, target} -> target A ct cf

// Closed targets work
test bool_rec_simple Nat 1 0 TTs = 1
test bool_rec_simple Nat 1 0 FFs = 0

// Hypothesis target produces a stuck neutral
let bool_hyp2 = Hyp SimpleBool 7
let stuck_result = bool_rec_simple Nat 1 0 bool_hyp2

test is_neutral stuck_result = TT
test neutral_type stuck_result = Nat
