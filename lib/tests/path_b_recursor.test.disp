// B1: the dependent RECURSOR `rec_value`, derived from the cells — generalizes nat_rec/ord_rec to ANY
// inductive. Each case gets the RAW args AND the IH per recursive position; neutrals route through
// `elim` to a stuck elimination at `motive self` (a real dependent eliminator, usable under a binder).
open use "../prelude.disp"
open use "../kernel/prelude.disp"
open use "../std/nat/arith.disp"
open use "../std/list.disp"

// ── inj-tagged Peano nat ──
let PN := Coproduct [pair "zero" [], pair "succ" [Rec]]
let pz := inj "zero" t
let ps := {n} -> inj "succ" n
// convert PN -> kernel Nat via the recursor (succ case uses the IH; the raw predecessor is also passed)
let pn_to_nat := rec_value PN ({_} -> Nat) { zero := zero; succ := ({pred, ih} -> succ ih) }
test pn_to_nat pz              = 0
test pn_to_nat (ps (ps pz))   = 2

// ── shape-encoded types dispatch too: rec_value decodes through the functor view (like
//    fold_value), so cases key by variant tag even when the tag lives in the tree shape.
//    (The kernel's nat_rec/bool_rec/ord_rec are exactly these instances, annotated.) ──
test rec_value Nat ({_} -> Nat) { zero := zero; succ := ({n, ih} -> succ (succ ih)) } 3 = 6
test rec_value Bool ({_} -> Nat) { true := 1; false := 0 } TT = 1
test rec_value Ord ({_} -> Nat) { zero_ord := zero; omega_plus := ({a, b, iha, ihb} -> succ ihb) } (omega_plus zero_ord (omega_plus zero_ord zero_ord)) = 2

// ── a binary tree: the case gets raw children AND their recursive results ──
let BT := Coproduct [pair "leaf" [Nat], pair "node" [Rec, Rec]]
let lf := {n}    -> inj "leaf" n
let nd := {l, r} -> inj "node" (pair l r)
let bt := nd (lf 1) (nd (lf 2) (lf 3))
// node case `{l, r, ihl, ihr}` receives both the raw subtrees AND their folded sums (the recursor
// interface — fold_value would give only ihl/ihr). Here we use the IHs.
let bt_sum := rec_value BT ({_} -> Nat) { leaf := ({n} -> n); node := ({l, r, ihl, ihr} -> add ihl ihr) }
test bt_sum bt                = 6

// ── the dependent-eliminator payoff: a NEUTRAL target -> stuck elimination at motive(self) ──
// (exactly nat_rec's behaviour — so rec_value works under a Pi binder, in proofs).
test tree_eq (neutral_type (rec_value PN ({_} -> Bool) { zero := TT; succ := ({pred, ih} -> ih) } (make_hyp PN 0))) Bool = TT
test tree_eq (neutral_type (rec_value BT ({_} -> Nat) { leaf := ({n} -> n); node := ({l, r, ihl, ihr} -> add ihl ihr) } (make_hyp BT 0))) Nat = TT

// ── generic TRAVERSAL: `children T v` = the recursive sub-values, read off the cells. size/depth then
//    derive with NO per-constructor code — one definition works for EVERY inductive. ──
test children BT (lf 9)            = nil           // a leaf has no recursive children
test list_length (children BT bt) = 2             // a node has two
test list_length (children PN (ps (ps pz))) = 1   // succ has one
// node-count = 1 + sum of children's counts. Generic: never names a constructor.
let bt_size := fix ({self, v} -> succ (list_foldl add zero (list_map self (children BT v))))
test bt_size (lf 5)               = 1
test bt_size bt                   = 5             // 3 leaves + 2 internal nodes

// ── rec_value is TYPED: it INHABITS the standard dependent-recursor type. Here PN's recursor with the
//    hand-written Nat-style type; the annotated `:=` is VERIFIED at load (= the proof rec_value is
//    type-correct: on a neutral x it lands `P x` via elim). `derive_case_telescope` builds this type
//    FROM the cells (next). ──
PN_rec : {P : PN -> Type} -> P pz -> ({n : PN} -> P n -> P (ps n)) -> {x : PN} -> P x :=
  {P, base, step, x} -> rec_value PN P { zero := base; succ := ({pred, ih} -> step pred ih) } x
test PN_rec ({_} -> Nat) zero ({n, ih} -> succ ih) (ps (ps pz)) = 2

// ── and the TYPE itself is DERIVED from the cells by `derive_case_telescope`. For PN with motive
//    (_->Nat) it computes Record [(zero, Nat), (succ, PN -> Nat -> Nat)] — args Π-bound, IH per rec
//    position, conclusion at the reconstructed constructor. ──
test typecheck (derive_case_telescope PN ({_} -> Nat)) { zero := zero; succ := ({n, ih} -> succ ih) } = Ok TT
test param_apply (derive_case_telescope PN ({_} -> Nat)) { zero := TT; succ := ({n, ih} -> succ ih) }   = Ok FF  // zero must be a Nat
test param_apply (derive_case_telescope PN ({_} -> Nat)) { zero := zero; succ := ({n, ih} -> TT) }       = Ok FF  // succ must return a Nat
// rec_value PN is now FULLY typed with the GENERATED cases telescope — no hand-written recursor type:
PN_rec2 : {P : PN -> Type} -> derive_case_telescope PN P -> {x : PN} -> P x := rec_value PN
test PN_rec2 ({_} -> Nat) { zero := zero; succ := ({n, ih} -> succ ih) } (ps (ps pz)) = 2

// multi-rec-arg + a data arg: BT's node case-type is `Π l:BT. Π r:BT. P l -> P r -> P (node l r)`
// (two IHs), leaf's is `Π n:Nat. P (leaf n)`. So for motive (_->Nat) the derived telescope is
// Record [(leaf, Nat -> Nat), (node, BT -> BT -> Nat -> Nat -> Nat)].
test typecheck (derive_case_telescope BT ({_} -> Nat)) { leaf := ({n} -> n); node := ({l, r, ihl, ihr} -> add ihl ihr) } = Ok TT
test param_apply (derive_case_telescope BT ({_} -> Nat)) { leaf := ({n} -> n); node := ({l, r, ihl, ihr} -> TT) }       = Ok FF
BT_rec : {P : BT -> Type} -> derive_case_telescope BT P -> {x : BT} -> P x := rec_value BT
test BT_rec ({_} -> Nat) { leaf := ({n} -> n); node := ({l, r, ihl, ihr} -> add ihl ihr) } bt = 6
