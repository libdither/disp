// The tree_rec rung: Tree is the substrate floor AND an inductive (universe.disp).
// Membership stays the O(1) floor recognizer; the meta now carries variants
// [leaf | stem Rec | fork Rec Rec], the TOTAL view iso, and an app-or-elim respond:
// a {motive; cases} frame is an elimination request (gated, like every inductive),
// any other frame answers `Extend (neutral_type self)` — a tree applied to a tree
// is a tree, stuck at Tree. Pins:
//   (a) tree_rec (kernel export) carries the honest dependent recursor type;
//       concrete recursion agrees with raw triage; abstract elimination inhabits
//       the motive (the same stuck-extension H-rule as nat_rec);
//   (b) typed twins for the raw prelude dispatchers, differentially pinned, plus
//       the licensed fast-twin pattern (neutral-delegation licensed by refl; a
//       lying twin refused) — dispatch IS elimination, raw triage is its fused
//       compiled form;
//   (c) the application face: wait/omega carry real annotations now (their checks
//       apply an abstract Tree, which extends at Tree instead of dead-ending at
//       InvalidType), and extensions chain;
//   (d) the known completeness loss of frame-shape dispatch: an application whose
//       argument merely LOOKS like an elimination record is routed to elimination
//       (over-rejection, never unsoundness).
open use "../kernel/prelude.disp"
open use "../std/oeq.disp"
open use "../std/nat/arith.disp"

// ── (a) the recursor
let tsize := {v} -> tree_rec ({_} -> Nat) 1 ({c, ih} -> succ ih) ({l, r, il, ir} -> succ (add il ir)) v
test tsize t = 1
test tsize (t t) = 2
test tsize (t (t t) (t t t)) = 6
// abstract elimination inhabits the motive
test param_apply Bool (tree_rec ({_} -> Bool) TT ({c, ih} -> ih) ({l, r, il, ir} -> FF) (make_hyp Tree 0)) = Ok TT
// the honest dependent type, re-pinned from the test side (the export's own
// annotation already verified at kernel load)
TreeRecT : Type := {P : Tree -> Type} -> P t -> ({c : Tree} -> P c -> P (t c)) -> ({l : Tree} -> {r : Tree} -> P l -> P r -> P (t l r)) -> {v : Tree} -> P v
test typecheck TreeRecT tree_rec = Ok TT

// ── (b) typed twins for the raw dispatchers
is_fork_t : Tree -> Bool := {v} -> tree_rec ({_} -> Bool) FF ({c, ih} -> FF) ({l, r, il, ir} -> TT) v
is_leaf_t : Tree -> Bool := {v} -> tree_rec ({_} -> Bool) TT ({c, ih} -> FF) ({l, r, il, ir} -> FF) v
stem_child_t : Tree -> Tree := {v} -> tree_rec ({_} -> Tree) t ({c, ih} -> c) ({l, r, il, ir} -> l) v
test is_fork_t t = is_fork t
test is_fork_t (t t) = is_fork (t t)
test is_fork_t (t t t) = is_fork (t t t)
test is_leaf_t t = is_leaf t
test is_leaf_t (t (t t)) = is_leaf (t (t t))
test stem_child_t (t (t t t)) = stem_child (t (t t t))
// the licensed fast twin (the nat_rec_fast pattern, one rung lower): delegate
// neutrals to the TYPED twin, run concretes through the raw dispatcher
let is_fork_fast := {v} -> if (is_neutral v) then (is_fork_t v) else (is_fork v)
test param_apply (oeq (Arrow Tree Bool) is_fork_t is_fork_fast) ({v} -> refl) = Ok TT
// a lying twin is refused (constant TT differs on the abstract path)
test tree_eq (param_apply (oeq (Arrow Tree Bool) is_fork_t ({v} -> TT)) ({v} -> refl)) (Ok TT) = FF

// ── (c) the application face (the annotations live in the prelude and verified at
// kernel load; re-pinned here directly)
test typecheck (Arrow Tree (Arrow Tree (Arrow Tree Tree))) wait = Ok TT
test typecheck (Arrow Tree Tree) omega = Ok TT
test typecheck (Arrow Tree Tree) ({x} -> x x x) = Ok TT
test typecheck (Arrow Tree (Arrow Tree Tree)) ({x, y} -> x (y x)) = Ok TT

// ── (d) the completeness loss, pinned visible
let looks_like_elim := { motive := ({_} -> Bool); cases := t }
test tree_eq (typecheck (Arrow Tree Tree) ({x} -> x looks_like_elim)) (Ok TT) = FF
