// The metacircular universe: a TYPE is a wait-form-cell-telescope (StrictType), checked by
// one. `v : Type` iff v is a recognizer (Tree -> CheckerResult) AND type_meta v : MetaShape —
// the two faces of a wait-form. StrictType is a plain `Telescope` of two `qid` cells, walked
// by the same `at`, and it inhabits ITSELF — the metacircular fixed point closes.
open use "../prelude.disp"
open use "../kernel/prelude.disp"
open use "../std/nat/ops.disp"

// the two faces, independently
test param_apply (Arrow Tree CheckerResult) Bool = Ok TT     // recognize-face: Bool IS a recognizer
test param_apply MetaShape (type_meta Bool)      = Ok TT     // meta-face: its env is a MetaShape

// StrictType recognizes the kernel's real types via BOTH faces at once
test param_apply StrictType Bool = Ok TT
test param_apply StrictType Nat  = Ok TT
test param_apply StrictType (Pi Nat ({_} -> Bool))    = Ok TT
test param_apply StrictType (Sigma Nat ({_} -> Bool)) = Ok TT
test param_apply StrictType (Eq Nat zero zero)        = Ok TT
test param_apply StrictType Action     = Ok TT              // a coproduct type
test param_apply StrictType Type       = Ok TT              // recognizes the legacy universe
test param_apply StrictType MetaShape  = Ok TT
// non-types are rejected: zero is not a recognizer; bare `Coproduct` is a type CONSTRUCTOR
// (Tree -> Type), not a type — StrictType correctly tells them apart.
test param_apply StrictType zero = Ok FF
test param_apply StrictType Coproduct = Ok FF              // a constructor, not a type
test param_apply StrictType ({n} -> n) = Ok FF            // a bare function is not a type

// ===== the fixed point: the universe inhabits itself =====
test param_apply StrictType StrictType = Ok TT
// and the legacy `Type` agrees StrictType is a type
test param_apply Type StrictType = Ok TT
test typecheck Type CheckerResult = Ok TT
