// tree_eq is now a normal recursive tree program in lib/prelude.disp.
// The host runtime captures its compiled tree id at boot and fast-paths
// two-arg applications to an O(1) hash-cons identity check; this file
// exercises the predicate's behavior on representative inputs.

open use "../prelude.disp"

// ================================================================
// Leaves, stems, forks
// ================================================================

test tree_eq t t = TT
test tree_eq t (t t) = FF
test tree_eq (t t) t = FF
test tree_eq (t t) (t t) = TT
test tree_eq (t t t) (t t t) = TT
test tree_eq (t t t) (t t (t t)) = FF
test tree_eq (t (t t) t) (t (t t) t) = TT
test tree_eq (t (t t) t) (t t (t t)) = FF

// ================================================================
// Mixed shapes
// ================================================================

test tree_eq t (t t t) = FF
test tree_eq (t t) (t (t t)) = FF
test tree_eq (t (t t)) (t (t t)) = TT
test tree_eq (t (t t)) (t t t) = FF

// ================================================================
// Deeper trees
// ================================================================

test tree_eq (t (t t t) (t t)) (t (t t t) (t t)) = TT
test tree_eq (t (t t t) (t t)) (t (t t t) (t (t t))) = FF
test tree_eq (t (t t (t t)) (t (t t) t)) (t (t t (t t)) (t (t t) t)) = TT

// ================================================================
// Numeric literals (Nat trees: zero=leaf, succ=fork(t, n))
// ================================================================

test tree_eq 0 0 = TT
test tree_eq 0 1 = FF
test tree_eq 3 3 = TT
test tree_eq 3 4 = FF
test tree_eq 5 5 = TT
