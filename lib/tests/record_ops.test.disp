// Record operations and projection — std/record.disp tests.

open use "../prelude.disp"
open use "../kernel/prelude.disp"
open use "../std/list.disp"
open use "../std/record.disp"

// Reuse the same field-list shapes as record.test.disp. Names are
// distinct trees (any tree works as a name placeholder for testing).
let name_x = t
let name_y = t t
let name_z = t t t

let fields_x_nat = t (t name_x ({_} -> Nat)) t
let fields_xy = t (t name_x ({_} -> Nat))
                  (t (t name_y ({_} -> Bool)) t)
let fields_empty = t

// ================================================================
// in_fields: membership check.
// ================================================================
test in_fields fields_empty name_x = FF
test in_fields fields_x_nat name_x = TT
test in_fields fields_x_nat name_y = FF
test in_fields fields_xy name_x = TT
test in_fields fields_xy name_y = TT
test in_fields fields_xy name_z = FF

// ================================================================
// find_index: 0-based position.
// ================================================================
test find_index fields_x_nat name_x = zero
test find_index fields_xy name_x = zero
test find_index fields_xy name_y = succ zero

// ================================================================
// sigma_walk: extract by index from a record's value-shape.
// ================================================================
let r1 = t (succ (succ zero)) unit_witness                       // {x := 2}
let r2 = t (succ zero) (t TT unit_witness)                       // {x := 1, y := TT}

test sigma_walk r1 zero = succ (succ zero)
test sigma_walk r2 zero = succ zero
test sigma_walk r2 (succ zero) = TT

// ================================================================
// ValidField: refinement that accepts only names in fields.
// ================================================================
test hasguard (ValidField fields_xy) = TT
test is_refinement (ValidField fields_xy) = TT
test ValidField fields_xy name_x = TT
test ValidField fields_xy name_y = TT
test ValidField fields_xy name_z = FF
test ValidField fields_empty name_x = FF

// ================================================================
// proj: end-to-end projection.
// ================================================================
test proj fields_x_nat r1 name_x = succ (succ zero)
test proj fields_xy r2 name_x = succ zero
test proj fields_xy r2 name_y = TT

// ================================================================
// record_names / record_type_at: reflection.
// ================================================================
test record_names (Record fields_xy) = list_cons name_x (list_cons name_y nil)
// record_type_at T n returns the type_fn; applying it to the
// prev_tuple gives the actual type. fields_xy uses ({_} -> Nat) and
// ({_} -> Bool), which ignore prev_tuple.
test (record_type_at (Record fields_xy) name_x) unit_witness = Nat
test (record_type_at (Record fields_xy) name_y) unit_witness = Bool
