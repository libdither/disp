// Soundness baseline — attack catalog. Each attack below probes a
// specific way user code might try to forge a neutral or smuggle a
// reflective check past the type system. The tests pin current
// closure status so a regression flips the expected result.
//
//   1. Direct forged closed neutral — user constructs StuckElim with
//      arbitrary stored type. Closed by q_guard_fn's entry scan, which
//      rejects any pre-existing neutral root in the user-supplied
//      value.
//   2. K-hidden forgery — a closed thunk `{_} -> StuckElim ...`
//      bracket-abstracts to `K (StuckElim ...)`, embedding the forged
//      neutral in the function's tree. Closed by the same entry scan
//      walking through the tree shape.
//   3. Reflective is_neutral family — recognizer like
//      `select Nat (Eq Nat 0 1) (is_neutral n)`. Closed by the
//      parametric walker: `is_neutral` triages on its argument via
//      pair_fst, and the walker rejects triage on a hypothesis.
//   4. Reflective tree_eq family — same shape as 3 but uses
//      `tree_eq n 0`. Closed by the walker for the same reason
//      (tree_eq triages both arguments).
//   5. Reflective is_fork family — same shape as 3 but uses
//      `is_fork n`. Closed by the walker (is_fork triages its arg).
//
// Status summary: attacks 1, 2 closed by the entry scan; attacks
// 3, 4, 5 closed by the parametric walker. All five attacks expect
// `= FF` (forgery rejected). The remainder of this file covers the
// guard-layer baseline that was established earlier and must remain
// stable across changes.

open use "../prelude.disp"
open use "../kernel/prelude.disp"

// ================================================================
// Attack 1 — direct forged closed neutral [CLOSED]
// ================================================================
// User constructs StuckElim with arbitrary stored type and trigger.
// Entry scan in q_guard_fn sees the neutral root and returns FF.

let fake_eq = StuckElim (Eq Nat 0 1) t
test (Eq Nat 0 1) fake_eq = FF

// ================================================================
// Attack 2 — K-hidden forgery [CLOSED]
// ================================================================
// `{_} -> StuckElim (Eq Nat 0 1) t` has a fully-closed body, so bracket
// abstraction compiles it to `K (StuckElim (Eq Nat 0 1) t)` — the
// literal forged neutral lives in the function's tree. Entry scan walks
// the tree, finds the neutral, returns FF.

let bad_pi = {_} -> StuckElim (Eq Nat 0 1) t
test (Pi Nat ({_} -> Eq Nat 0 1)) bad_pi = FF

// ================================================================
// Attack 3 — reflective is_neutral family [REJECTED by walker]
// ================================================================
// BadFam is "Nat if the argument is a hypothesis, else Eq Nat 0 1".
// During Pi checking the argument IS a hypothesis. With the native
// walker active, Pi's recognizer runs `BadFam hyp`
// under parametric mode; `is_neutral hyp` triages on hyp via pair_fst,
// which the walker rejects (triage-on-neutral rule). Pi check returns
// FF — attack correctly defeated.

let BadFam = {n} -> select Nat (Eq Nat 0 1) (is_neutral n)
let bad_fn = {n} -> 0
test (Pi Nat BadFam) bad_fn = FF

// ================================================================
// Attack 4 — reflective tree_eq family [REJECTED by walker]
// ================================================================
// Same shape as attack 3 but uses tree_eq instead of is_neutral.
// tree_eq triages both args; for hyp argument, walker rejects.

let BadFam2 = {n} -> select (Eq Nat 0 1) Nat (tree_eq n 0)
test (Pi Nat BadFam2) ({n} -> 0) = FF

// ================================================================
// Attack 5 — reflective is_fork family [REJECTED by walker]
// ================================================================
// is_fork uses triage on its arg; for hyp the walker rejects.

let BadFam3 = {n} -> select Nat (Eq Nat 0 1) (is_fork n)
test (Pi Nat BadFam3) ({n} -> 0) = FF

// ================================================================
// Guard-layer baseline (session 2, still holds)
// ================================================================
// These verify that the guard layer doesn't open a *new* attack
// surface. Should remain unchanged across session 3.

let junk_pred = {_} -> TT
let junk_guarded = guard junk_pred

test hasguard junk_guarded = TT
test (Type) junk_guarded = FF
test is_pi junk_guarded = FF
test is_universe junk_guarded = FF
test is_eq junk_guarded = FF

let fake_handler = {_meta, _x} -> TT
let fake_guarded = guard (wait fake_handler t)

test hasguard fake_guarded = TT
test (Type) fake_guarded = FF
test is_pi fake_guarded = FF
test is_universe fake_guarded = FF
test is_eq fake_guarded = FF

// Post-migration: Nat is now predicate-frame based; its unguarded
// form is `wait kernel_ref.predicate_frame nat_pf_meta`. Sig check:
// unguarded Nat has the predicate_frame signature.
test tree_eq (pair_fst (unguard_or_self Nat)) kernel_predicate_frame_sig = TT
test tree_eq (unguard_or_self t) t = TT

test (guard ({_} -> TT)) 5 = TT
test (guard ({_} -> FF)) 5 = FF
