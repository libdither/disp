// The guard layer end to end (COMPILATION.typ § Declarations as requests).
// Pins: plain declarations are untouched (fast path); `guard <policy> NAME : T := v`
// installs ownership and binds in one declaration; rebinding an owned name is an
// ordinary-looking declaration whose payload carries credentials; guard_eq derives
// the contract from the annotation; interface entries take a first implementation
// license-free; idempotent rebinds pass without consultation. Rejections (freeze,
// lying proofs, plain rebinds of owned names) are LOAD failures, pinned host-side
// in test/guards.test.ts.
open use "../kernel/prelude.disp"
open use "../std/list.disp"
open use "../std/oeq.disp"

// the license kit (the map-id license, as in oeq.test)
let mp := {f, xs} -> list_rec ({_} -> NatList) nil ({h, tl, ih} -> cons (f h) ih) xs
let idA := {xs} -> xs
let idB := {xs} -> mp ({x} -> x) xs
let map_id_law := {a} -> list_rec
  ({xs_} -> Eq NatList xs_ (mp ({x} -> x) xs_))
  refl
  ({h, tl, ih} -> eq_cong NatList NatList ({t_} -> cons h t_) tl (mp ({x} -> x) tl) ih)
  a
let FnT := Arrow NatList NatList

// ── the constructors and the default guard are ordinary, typed kernel values ──
test typecheck GuardAction (Bind zero) = Ok TT
test typecheck GuardAction (Install zero) = Ok TT
test typecheck GuardAction (Both zero zero) = Ok TT
test typecheck Request (base zero) = Ok TT
test default_guard t (base zero) = Ok (Bind zero)                    // plain bind
test default_guard t (guard freeze (base zero)) = Ok (Both zero freeze)  // bind + install
test default_guard t (guard freeze (sig Nat)) = Ok (Install freeze)  // install only
test default_guard t (sig Nat) = Err                                 // nothing to do

// ── an owned name: install + bind in one declaration, rebind with credentials ──
guard (license_guard (oeq FnT)) ident : Arrow NatList NatList := ({xs} -> xs)
test tree_eq ident idA = TT
ident : Arrow NatList NatList := { new := ({xs} -> mp ({x} -> x) xs); proof := map_id_law }
test tree_eq ident idB = TT                       // the name now binds the licensed replacement
test ident (cons 2 nil) = cons 2 nil              // and still behaves

// ── idempotent rebind: tree-identical, no consultation, no credentials needed ──
ident : Arrow NatList NatList := ({xs} -> mp ({x} -> x) xs)
test tree_eq ident idB = TT

// ── guard_eq: the ownership contract derived from the declared type ──
guard_eq ident2 : Arrow NatList NatList := ({xs} -> xs)
ident2 : Arrow NatList NatList := { new := ({xs} -> mp ({x} -> x) xs); proof := map_id_law }
test tree_eq ident2 idB = TT

// ── interface entry: contract first, first implementation license-free ──
guard (license_guard (oeq FnT)) iface : Arrow NatList NatList
iface : Arrow NatList NatList := ({xs} -> xs)
test tree_eq iface idA = TT

// ── freeze: install alongside a value; the name still reads normally ──
guard freeze VERSION : Nat := 3
test VERSION = 3

// ── `let` as a head: binds locally, marks the write private (the export-absence
// half is pinned host-side in test/guards.test.ts) ──
let pvt : Nat := 3
test pvt = 3
// the decorators are typed kernel values (annotations auto-verified at load; re-pinned)
test typecheck Request (guard freeze (base zero)) = Ok TT
test typecheck Request (let (base zero)) = Ok TT
test typecheck Request (sig Nat) = Ok TT
test typecheck Request (given (sig Nat)) = Ok TT

// ── `given` marks a module dependency (MODULES.md): param rides the request ──
test (given (base zero)).param = TT
test (base zero).param = FF
test (let (base zero)).param = FF

// ── the equation item and its marker (SYNTAX.typ § Tests): `test` is the prelude
// IDENTITY, an ordinary value — `test e` ≡ `e` — so the marker is style, not syntax.
test tree_eq (test pvt) pvt = TT      // marker in expression position: identity
pair_fst (pair pvt zero) = 3          // a markerless equation is the same item
