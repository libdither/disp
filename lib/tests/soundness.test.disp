// Walker / kernel soundness — the parametricity guarantees of TYPE_THEORY §4–§7,
// plus characterization tests that PIN the flagged soundness deferral (GAP 2,
// route-to-registered §5.4) so it stays visible. GAP 1 (raw bind_hyp body) is now
// CLOSED — the body runs under the walker — and its tests assert the sound behavior.

open use "../prelude.disp"
open use "../kernel/prelude.disp"

let hN = make_hyp Nat 0

// ================================================================
// PRESENT protections (permanent — these must always hold)
// ================================================================

// Stem-forge rejection (§4.2): user code cannot construct a neutral-rooted fork.
// `forge` tries to build fork(hyp_sig, x) = a fake hypothesis; the walker's
// stem rule rejects it, so dispatching the application fails.
let forge = {x} -> t hyp_sig x
test param_apply forge zero = Err
test param_apply forge (succ zero) = Err

// Triage-on-neutral rejection (§4.2/§4.3): reflecting on a hypothesis's shape
// under the walker fails. is_fork/is_leaf/is_stem all triage on their argument.
test param_apply ({x} -> is_fork x) hN = Err
test param_apply ({x} -> is_leaf x) hN = Err
test param_apply ({x} -> is_stem x) hN = Err

// bind_hyp escape check (§7.2/§8.1): a result that exposes the hypothesis via a
// non-neutral path is rejected; a result independent of it passes. bind_hyp is the
// bare op-tag, routed into the walker from this raw context via `param_apply`.
test param_apply (bind_hyp Nat) ({x} -> Ok zero) = Ok zero
test param_apply (bind_hyp Nat) ({x} -> Ok x) = Err
test param_apply (bind_hyp Nat) ({x} -> Ok (pair x zero)) = Err

// ================================================================
// GAP 1 CLOSED — bind_hyp runs the body UNDER the walker (TYPE_THEORY §7.2)
// ================================================================
// bind_hyp is merged into the walker (`w_bind_hyp`): the body runs via the
// walker's own `self`, so reflection on the hypothesis INSIDE the body is now
// caught exactly as at the top level (the param_apply tests above). A body that
// triages on the hypothesis is rejected with `Err` — no structural verdict leaks.
// (These RHSs were the pinned leaky `Ok TT`/`Ok FF` before the fix landed.)
test param_apply (bind_hyp Nat) ({x} -> Ok (is_fork x)) = Err // triage on hyp -> rejected
test param_apply (bind_hyp Nat) ({x} -> Ok (is_leaf x)) = Err // triage on hyp -> rejected
test param_apply (bind_hyp Nat) ({x} -> Ok (is_stem x)) = Err // triage on hyp -> rejected

// ================================================================
// DEFERRED GAP 2 — param_apply routes to the embedded handler (TYPE_THEORY §5.4)
// ================================================================
// The dispatcher's routed arm runs `f x` (the wait-form's embedded handler),
// not `h (wait_meta f) x` for the registered `h`. This is defense-in-depth that
// is currently MOOT: a forged kernel-op would need a wait-form presenting a
// kernel sig with a *different* embedded handler, but `checker_sig` derives the
// signature FROM the handler tree, so a wait-form's sig and handler are coupled;
// the only other way to present `hyp_sig` — a hand-built fork(hyp_sig, …) — is
// blocked by the stem-forge rejection tested above. So the operative guard is
// forge rejection; route-to-registered hardening is tracked but has no
// constructible in-language counterexample today. The genuine routing IS
// exercised end-to-end — a Nat-neutral eliminated by a case frame runs the
// registered hyp_reduce and extends the spine:
// the respond gates the cases against the motive (§B), so they must be coherent:
// with motive Bool, zero : Bool and succ returns its ih : Bool (cases keyed by variant tag).
let stuck = param_apply hN { motive := ({_} -> Bool); cases := { zero := TT; succ := ({pred, ih} -> ih) } }
test is_neutral stuck = TT // bare stuck neutral (Option A §7.5)
test neutral_type stuck = Bool

// ================================================================
// RAW application: a type whose RECOGNIZER mints a hypothesis fails fast
// ================================================================
// Pi and Intersection check their user type-function against a fresh hypothesis, so
// their recognizer embeds a bind_hyp whose marker fails closed outside the walker. A
// raw juxtaposition `T v` (bypassing param_apply) therefore returns Err instead of a
// silent, unsound verdict — the only sound check is `param_apply` / `typecheck` /
// `verify`.
test (Pi Nat ({_} -> Nat)) ({n} -> n)         = Err     // raw -> fail fast (recognizer mints a hyp)
test (Intersection Nat ({_} -> Nat)) zero     = Err     // raw -> fail fast (recognizer mints a hyp)
test param_apply (Pi Nat ({_} -> Nat)) ({n} -> n) = Ok TT   // the sound path still works
// A type whose recognizer does NOT mint a hyp applies raw to a CONCRETE value safely
// — no parametricity surface. Sigma's recognizer (the telescope fold) checks a
// concrete record (its family is only abstracted in its respond), so raw Sigma
// yields a verdict, NOT fail-fast; recognizers rely on this raw composition internally.
test (Sigma Nat ({_} -> Bool)) { fst := zero; snd := TT } = Ok TT   // raw Sigma: a verdict, not fail-fast
test Nat (succ zero)       = Ok TT
test (Eq Nat zero zero) refl = Ok TT

// ================================================================
// THE SUBSTRATE FLOOR (K0) — the trusted base, declared and pinned
// ================================================================
// "Full verified" != "zero trust" (ACTIVE_PLAN.md §1). The floor is every primitive that
// RAW-INSPECTS a tree's payload: it cannot self-verify, because verifying `f : Tree -> X`
// mints a Tree-hyp and `f` triages it — which the walker rejects by the SAME parametricity
// that makes the kernel sound. So the floor is irreducible TCB; the goal is to MINIMIZE and
// PIN it, not remove it. The walker sanctions exactly FOUR readers as carve-outs — they read
// a neutral WITHOUT triaging its payload — and rejects all other payload-reading. This block
// pins that boundary: the carve-outs verify, the floor does not.

// (a) the 4 SANCTIONED READERS are usable on a hypothesis (engine.disp param_walker carve-outs):
test param_apply (Pi Nat ({_} -> Tree)) ({x} -> pair_fst x)     = Ok TT  // root signature
test param_apply (Pi Nat ({_} -> Tree)) ({x} -> neutral_type x) = Ok TT  // stored type
test param_apply (Pi Nat ({_} -> Bool)) ({x} -> tree_eq x x)    = Ok TT  // conversion (O(1) hash-cons)
test param_apply (Pi Nat ({_} -> Nat))  ({x} -> x)              = Ok TT  // identity

// (b) the FLOOR readers are REJECTED on a hypothesis — they triage its payload, so they
// CANNOT be verified. This rejection IS the proof they are trusted-by-construction (TCB):
test param_apply (Pi Nat ({_} -> Tree)) ({x} -> pair_snd x)  = Err  // raw 2nd projection
test param_apply (Pi Nat ({_} -> Bool)) ({x} -> is_fork x)   = Err  // shape triage
test param_apply (Pi Nat ({_} -> Bool)) ({x} -> is_leaf x)   = Err  // shape triage
test param_apply (Pi Nat ({_} -> Tree)) ({x} -> type_meta x) = Err  // metadata read (pair_snd . pair_snd)
test param_apply (Pi Nat ({_} -> Bool)) ({x} -> is_closed x) = Err  // support/closedness scan
// equivalently, a floor primitive cannot be verified as its own `Tree -> X` type:
test param_apply (Pi Tree ({_} -> Bool)) is_fork  = Err
test param_apply (Pi Tree ({_} -> Tree)) pair_snd = Err
// (checker_sig is trusted too, but reads the sig THROUGH the pair_fst carve-out after a wrap,
//  so it is not a direct-triage floor reader — it is not walker-rejected.)

// ── H-rule NOMINALITY on neutrals (characterization, 2026-07-01): a REFINEMENT cannot
// classify EXISTING neutrals. make_recognizer's H-rule short-circuits EVERY neutral
// candidate to "is your stored type THIS type?" — so a hyp minted at Tree is Ok FF against
// `Refinement Tree is_neutral`, even though the refinement predicate holds for it. Types
// are NOMINAL on neutrals; a structural `Neutral A` classifier would need a recognizer
// that bypasses the H-rule shim, which reopens the level-confusion question (the hyp's OWN
// neutrality vs the values it stands for). Pinned so any change here is a conscious one.
let NeutralT = Refinement Tree is_neutral
test tree_eq (param_apply NeutralT (make_hyp Tree 0)) (Ok TT) = FF // a real neutral: NOT a member (H-rule nominality)
test param_apply NeutralT zero = Ok FF                             // a concrete non-neutral: predicate rejects, as expected

// ================================================================
// ABOVE THE FLOOR (K1) — everything else is meant to verify
// ================================================================
// The claim "everything above the floor verifies" is made checkable by the per-fragment
// self-check `verify {cut,engine,types}_mod = Ok TT` in use_raw.test.disp (the kernel
// typechecking its own annotated exports, under the walker) plus the annotations in the
// kernel sources — every engine/cut export is either ANNOTATED (machine-verified: is_neutral,
// neutral_type, bind_hyp, make_recognizer/make_rec_recognizer, apply_policed, the sigs,
// verify : Module -> CheckerResult, InvalidType, the parametric responds, checker_sig,
// make_meta) or marked SEALED(<why>) at the definition (see engine.disp's header). Representative
// above-floor checks (formers, structural types, a recursor's own type) verify here too:
test param_apply Type Nat = Ok TT                              // Nat : Type (a former verifies)
test typecheck NeutralMeta (type_meta (make_hyp Nat 0)) = Ok TT // structural type inhabited
test param_apply (Pi Nat ({_} -> Nat)) ({y} -> nat_rec ({_} -> Nat) zero ({p, ih} -> succ ih) y) = Ok TT // recursor's own use verifies
// NOTE (K1, updated 2026-07-01): list_rec is now elim-ROUTED (neutral targets run List's gate,
// no more raw make_hyp bypass) and ANNOTATED at the implicit-∀ dependent recursor type
// (Intersection Type ({A} -> …)); list_length carries Intersection Type ({A} -> Arrow (List A)
// Nat). The remaining raw-triage list functions (map/append/fold/…) are unannotated
// substrate-idiom versions — same mechanical rewrite when their annotations are wanted.
