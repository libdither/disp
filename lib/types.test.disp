open use "prelude.disp"
open use "kernel.disp"
open use "types.disp"

// ================================================================
// Nat / Bool predicates (raw apply!)
// ================================================================

// zero : Nat
test Nat 0 = TT

// one : Nat
test Nat 1 = TT

// two : Nat
test Nat 2 = TT

// false : Nat
test Nat FF = FF

// true : Bool
test Bool TT = TT

// false : Bool
test Bool FF = TT

// one : Bool
test Bool 1 = FF

// five : Nat
test Nat 5 = TT

// ================================================================
// VStuckElim (wait-based neutral with ELIM_TAG)
// ================================================================

// stuckElim : Neutral
test is_neutral (StuckElim Nat (Hyp Bool t)) = TT

// neutral_type stuckElim = Nat
test neutral_type (StuckElim Nat (Hyp Bool t)) = Nat

// stuckElim metadata is tagged as an eliminator
test pair_fst (pair_snd (type_meta (StuckElim Nat (Hyp Bool t)))) = ELIM_TAG

// ================================================================
// Typed eliminators
// ================================================================

// bool_rec Nat one zero true = one
test bool_rec ({_} -> Nat) one zero TT = one

// bool_rec Nat one zero false = zero
test bool_rec ({_} -> Nat) one zero FF = zero

// b : Bool |- bool_rec Nat one zero b is neutral
test is_neutral (bool_rec ({_} -> Nat) one zero (Hyp Bool t)) = TT

// nat_rec Bool true step zero = true
test nat_rec ({_} -> Bool) TT ({n, prev} -> prev) zero = TT

// nat_rec Bool true step two = true
test nat_rec ({_} -> Bool) TT ({n, prev} -> prev) two = TT

// n : Nat |- nat_rec Bool true step n is neutral
test is_neutral (nat_rec ({_} -> Bool) TT ({n, prev} -> prev) (Hyp Nat t)) = TT

// nat_rec Nat one const zero = one
test nat_rec ({_} -> Nat) 1 ({n, p} -> p) 0 = 1

// nat_rec Nat zero succ two = two
test nat_rec ({_} -> Nat) zero ({n, p} -> succ p) two = two

// ================================================================
// Eq type
// ================================================================

// refl : Eq Nat zero zero
test (Eq Nat zero zero) refl = TT

// refl : Eq Nat one one
test (Eq Nat one one) refl = TT

// refl : Eq Nat zero one
test (Eq Nat zero one) refl = FF

// FF is not a proof of Eq Nat zero zero
test (Eq Nat zero zero) FF = FF

// eq_J Nat zero motive five zero refl = five
test eq_J Nat zero ({y, p} -> Nat) five zero refl = five

// eq_sym refl : Eq Nat zero zero
test (Eq Nat zero zero) (eq_sym Nat zero zero refl) = TT

// eq_cong succ refl : Eq Nat one one
test (Eq Nat one one) (eq_cong Nat Nat succ zero zero refl) = TT

// eq_subst Nat Nat zero zero refl five = five
test eq_subst Nat Nat zero zero refl five = five

// ================================================================
// Arithmetic: add
// ================================================================

// add zero zero = zero
test add zero zero = zero

// add zero three = three
test add zero three = three

// add two three = five
test add two three = five

// add three two = five
test add three two = five

// refl : Eq Nat (add zero zero) zero
test (Eq Nat (add zero zero) zero) refl = TT

// refl : Eq Nat (add one zero) one
test (Eq Nat (add one zero) one) refl = TT

// refl : Eq Nat (add two zero) two
test (Eq Nat (add two zero) two) refl = TT

// refl : Eq Nat (add three zero) three
test (Eq Nat (add three zero) three) refl = TT

// refl : Eq Nat (add two three) (add three two)
test (Eq Nat (add two three) (add three two)) refl = TT

// refl : Eq Nat (add one four) (add four one)
test (Eq Nat (add one four) (add four one)) refl = TT

// ================================================================
// Arrow type checking (raw apply!)
// ================================================================

// id_fn : Nat -> Nat
test NatToNat id_fn = TT

// constZero : Nat -> Nat
test NatToNat ({_} -> zero) = TT

// constFalse : Nat -> Nat
test NatToNat ({_} -> FF) = FF

// ================================================================
// ton_check
// ================================================================

// n : Nat |- typeOf n = Nat
test ton_check ({x} -> x) (Hyp Nat t) = Nat

// n : Nat |- n : Nat
test ton_check (conv Nat) (Hyp Nat t) = TT

// n : Nat |- n : Bool
test ton_check (conv Bool) (Hyp Nat t) = FF

// f : Nat -> Nat, n : Nat |- typeOf (f n) = Nat
test ton_check ({x} -> x) ((Hyp NatToNat t) (Hyp Nat (t t))) = Nat

// f : Nat -> Nat, n : Nat |- f n : Nat
test ton_check (conv Nat) ((Hyp NatToNat t) (Hyp Nat (t t))) = TT

// h : nonPi, x : nonPi |- typeOf (h x) = FF
test ton_check ({x} -> x) ((Hyp (Hyp t t) (t t)) (Hyp (Hyp t t) (t t))) = FF

// t is not neutral
test ton_check ({x} -> x) t = FF

// ================================================================
// H-rule via raw apply (neutrals checked by type)
// ================================================================

// n : Nat |- n : Nat
test Nat (Hyp Nat t) = TT

// b : Bool |- b : Nat
test Nat (Hyp Bool t) = FF

// f : Nat -> Nat, n : Nat |- f n : Nat
test Nat ((Hyp NatToNat t) (Hyp Nat (t t))) = TT

// ================================================================
// Pi metadata reflection
// ================================================================

// is_pi (Nat -> Nat)
test is_pi (Pi Nat ({_} -> Nat) t) = TT

// is_pi Nat
test is_pi Nat = FF

// is_pi t
test is_pi t = FF

// pi_dom (Nat -> Nat) = Nat
test pi_dom (Pi Nat ({_} -> Nat) t) = Nat

// Pi construction
// is_pi (Nat -> Nat)
test is_pi (Arrow Nat Nat t) = TT

// pi_dom (Nat -> Nat) = Nat
test pi_dom (Arrow Nat Nat t) = Nat

// ================================================================
// Nat le/lt
// ================================================================

// zero <= zero
test nat_le 0 0 = TT

// zero <= three
test nat_le 0 3 = TT

// one <= zero
test nat_le 1 0 = FF

// two <= three
test nat_le 2 3 = TT

// two <= one
test nat_le 2 1 = FF

// zero < one
test nat_lt 0 1 = TT

// zero < zero
test nat_lt 0 0 = FF

// one < two
test nat_lt 1 2 = TT

// ================================================================
// Type n
// ================================================================

// Nat : Type0
test Type0 Nat = TT

// Bool : Type0
test Type0 Bool = TT

// Nat is the registered Nat type
test is_nat_type Nat = TT

// Bool is the registered Bool type
test is_bool_type Bool = TT

// Bool is not the registered Nat type
test is_nat_type Bool = FF

// Nat is not the registered Bool type
test is_bool_type Nat = FF

// t : Type0
test Type0 t = FF

// FF : Type0
test Type0 FF = FF

// fakeNat : malformed Nat-shaped type
let fakeNat = wait ({_meta, _x} -> TT) t

// fakeNat is not the registered Nat type
test is_nat_type fakeNat = FF

// fakeNat : Type0
test Type0 fakeNat = FF

// fakeBool : malformed Bool-shaped type
let fakeBool = wait ({_meta, _x} -> TT) (t t)

// fakeBool is not the registered Bool type
test is_bool_type fakeBool = FF

// fakeBool : Type0
test Type0 fakeBool = FF

// Nat -> Nat : Type0
test Type0 (Arrow Nat Nat t) = TT

// Type0 : Type1
test Type1 Type0 = TT

// Type0 : Type0
test Type0 Type0 = FF

// Nat : Type1
test Type1 Nat = TT

// Type0 : Type2
test Type2 Type0 = TT

// (x : Nat) -> Bool : Type0
test Type0 (Pi Nat ({_x} -> Bool) t) = TT

// (x : Nat) -> x : Type0
test Type0 (Pi Nat ({x} -> x) t) = FF

// (x : FF) -> Nat : Type0
test Type0 (Pi FF ({_x} -> Nat) t) = FF

// (A : Type0) -> A -> A : Type1
test Type1 (Pi Type0 ({A} -> Arrow A A (t t)) t) = TT

// (A : Type0) -> A -> A : Type0
test Type0 (Pi Type0 ({A} -> Arrow A A (t t)) t) = FF

// Eq Nat zero zero : Type0
test Type0 (Eq Nat zero zero) = TT

// Eq Nat zero false : Type0
test Type0 (Eq Nat zero FF) = FF

// Eq FF zero zero : Type0
test Type0 (Eq FF zero zero) = FF

// is_eq (Eq Nat zero zero)
test is_eq (Eq Nat zero zero) = TT

// fakeEq : malformed Eq-shaped type
let fakeEq = wait ({_meta, _x} -> TT) (t Nat (t zero zero))

// is_eq fakeEq
test is_eq fakeEq = FF

// fakeEq : Type0
test Type0 fakeEq = FF

// fakeUniverse : malformed Universe-shaped type
let fakeUniverse = wait ({_meta, _x} -> TT) t

// is_universe fakeUniverse
test is_universe fakeUniverse = FF

// fakeUniverse : Type0
test Type0 fakeUniverse = FF

// fakePi : malformed Pi-shaped type
let fakePi = wait ({_meta, _x} -> TT) (t Nat (t t ({_x} -> Bool)))

// is_pi fakePi
test is_pi fakePi = FF

// fakePi : Type0
test Type0 fakePi = FF

// f : fakePi, n : Nat |- f n : Bool
test Bool ((Hyp fakePi t) zero) = FF

// ================================================================
// Structural conv
// ================================================================

// conv t t
test conv_structural t t = TT

// conv t (t t)
test conv_structural t (t t) = FF

// conv Type0 Type0
test conv_structural Type0 Type0 = TT

// conv Type0 Type1
test conv_structural Type0 Type1 = FF

// conv ((x : Nat) -> Nat) ((x : Nat) -> Nat)
test conv_structural (Pi Nat ({_} -> Nat) t) (Pi Nat ({_} -> Nat) t) = TT

// conv ((x : Nat) -> Nat) ((x : Bool) -> Nat)
test conv_structural (Pi Nat ({_} -> Nat) t) (Pi Bool ({_} -> Nat) t) = FF

// conv ((x : Nat) -> Nat) (Nat -> Nat)
test conv_structural
  (Pi Nat ({_x} -> Nat) t)
  (Arrow Nat Nat t) = TT

// conv (Nat -> Bool) (Nat -> Nat)
test conv_structural
  (Arrow Nat Bool t)
  (Arrow Nat Nat t) = FF

// ================================================================
// Integration: full pipeline (raw apply everywhere!)
// ================================================================

// idPoly : (A : Type0) -> A -> A
test (Pi Type0 ({A} -> Arrow A A (t t)) t) ({_A} -> {x} -> x) = TT

// idNatToNat : (Nat -> Nat) -> Nat -> Nat
// (eta: {f}->{x}->f x = {f}->f in untyped bracket abstraction)
test (Arrow NatToNat NatToNat t) ({f} -> f) = TT

// composeNat : (Nat -> Nat) -> (Nat -> Nat) -> Nat -> Nat
// The term applies g to x (producing stuck), then f to stuck (producing deeper stuck).
// Both stuck terms are accumulated neutrals. Pi checker uses ton_check for codomain.
test (Arrow NatToNat (Arrow NatToNat NatToNat (t (t t))) t)
  ({f} -> {g} -> {x} -> f (g x)) = TT

// badComposeNat : (Nat -> Nat) -> (Nat -> Nat) -> Nat -> Nat
test (Arrow NatToNat (Arrow NatToNat NatToNat (t (t t))) t)
  ({f} -> {g} -> {x} -> FF) = FF

// doubleApply : (Nat -> Nat) -> Nat -> Nat
test (Arrow NatToNat NatToNat t)
  ({f} -> {x} -> f (f x)) = TT

// constNat : Nat -> Nat -> Nat
test (Arrow Nat (Arrow Nat Nat (t (t t))) t) ({x} -> {_y} -> x) = TT

// constPoly : (A : Type0) -> (B : Type0) -> A -> B -> A
test (Pi Type0 ({A} ->
    Pi Type0 ({B} ->
      Arrow A (Arrow B A (t (t (t (t t))))) (t (t (t t))))
      (t (t t)))
    t)
  ({_A} -> {_B} -> {x} -> {_y} -> x) = TT

// badConstPoly : (A : Type0) -> (B : Type0) -> A -> B -> A
test (Pi Type0 ({A} ->
    Pi Type0 ({B} ->
      Arrow A (Arrow B A (t (t (t (t t))))) (t (t (t t))))
      (t (t t)))
    t)
  ({_A} -> {_B} -> {_x} -> {y} -> y) = FF

// flip : (A : Type0) -> (B : Type0) -> (C : Type0) -> (A -> B -> C) -> B -> A -> C
test (Pi Type0 ({A} ->
    Pi Type0 ({B} ->
      Pi Type0 ({C} ->
        Arrow
          (Arrow A (Arrow B C (t (t (t (t (t (t t))))))) (t (t (t (t (t t))))))
          (Arrow B (Arrow A C (t (t (t (t (t (t (t t)))))))) (t (t (t (t (t (t t)))))))
          (t (t (t (t (t t))))))
        (t (t (t t))))
      (t (t t)))
    t)
  ({_A} -> {_B} -> {_C} -> {f} -> {b} -> {a} -> (f a) b) = TT

// f : Nat -> Nat, x : Nat |- f x : Nat
test Nat ((Hyp NatToNat (t (t (t t)))) (Hyp Nat (t (t (t (t t)))))) = TT

// f : Nat -> Nat, x : Nat |- f x : Bool
test Bool ((Hyp NatToNat (t (t (t t)))) (Hyp Nat (t (t (t (t t)))))) = FF

// (A : Type0) -> A -> A : Type1
test Type1 (Pi Type0 ({A} -> Arrow A A (t t)) t) = TT

// (A : Type0) -> A -> A : Type0
test Type0 (Pi Type0 ({A} -> Arrow A A (t t)) t) = FF

// boolToNat : Bool -> Nat
test (Arrow Bool Nat t) ({b} ->
  bool_rec ({_} -> Nat) one zero b) = TT

// natToBool : Nat -> Bool
test (Arrow Nat Bool t) ({n} ->
  nat_rec ({_} -> Bool) TT ({n_, prev} -> FF) n) = TT

// badNatToBool : Nat -> Bool
test (Arrow Nat Bool t) ({n} ->
  nat_rec ({_} -> Nat) zero ({n_, prev} -> succ prev) n) = FF

// applyPoly : (A : Type0) -> (B : Type0) -> (A -> B) -> A -> B
// which has type (A->B)->(A->B). Use correct arrow structure.
test (Pi Type0 ({A} ->
    Pi Type0 ({B} ->
      Arrow (Arrow A B (t (t (t (t t))))) (Arrow A B (t (t (t (t t))))) (t (t (t t))))
      (t (t t)))
    t)
  ({_A} -> {_B} -> {f} -> f) = TT

// badSelf : (A : Type0) -> A -> A
test (Pi Type0 ({A} -> Arrow A A (t (t t))) t)
  ({_A} -> {x} -> x x) = FF

// pairNat : Nat -> Nat -> (Nat -> Nat -> Nat) -> Nat
test (Arrow Nat
  (Arrow Nat
    (Arrow (Arrow Nat (Arrow Nat Nat (t (t (t (t (t t)))))) (t (t (t (t t)))))
      Nat
      (t (t (t (t t)))))
    (t (t (t t))))
  t)
  ({a} -> {b} -> {sel} -> (sel a) b) = TT

// h : H |- h : H
test ton_check (fast_eq (Hyp t t)) (Hyp (Hyp t t) (t t)) = TT

// ctxId : (A : Type0) -> (x : A) -> A
test (Pi Type0 ({A} ->
    Pi A ({_x} -> A) (t t))
    t)
  ({_A} -> {x} -> x) = TT

// ctxConst : (A : Type0) -> (B : Type0) -> A -> B -> A
test (Pi Type0 ({A} ->
    Pi Type0 ({B} ->
      Arrow A (Arrow B A (t (t (t t)))) (t (t t)))
      (t t))
    t)
  ({_A} -> {_B} -> {x} -> {_y} -> x) = TT

// badCtxConst : (A : Type0) -> (B : Type0) -> A -> B -> A
test (Pi Type0 ({A} ->
    Pi Type0 ({B} ->
      Arrow A (Arrow B A (t (t (t t)))) (t (t t)))
      (t t))
    t)
  ({_A} -> {_B} -> {_x} -> {y} -> y) = FF

// f : (x : Nat) -> Bool, n : Nat |- f n : Bool
test Bool
  ((Hyp (Pi Nat ({_x} -> Bool) t) t)
    (Hyp Nat (t t))) = TT

// f : (x : Nat) -> Bool, n : Nat |- f n : Nat
test Nat
  ((Hyp (Pi Nat ({_x} -> Bool) t) t)
    (Hyp Nat (t t))) = FF

// f : (A : Type0) -> A -> A, n : Nat |- f Nat n : Nat
test Nat
  (((Hyp
      (Pi Type0 ({A} -> Arrow A A (t t)) t)
      t)
    Nat)
    (Hyp Nat (t t))) = TT
