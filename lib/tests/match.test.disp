// Tests for `if c then a else b` (the boolean conditional → `cond` desugar,
// with closed-branch free-variable capture) and the coproduct `match` keyword
// (the §2.6 cut — string-tag arms, wildcard, multi-binder destructuring).

open use "../kernel/prelude.disp" // coproduct match uses the cut (prod/inj)

// ================================================================
// Basic correctness — closed scrutinees
// ================================================================

test (if TT then 1 else 0) = 1
test (if FF then 1 else 0) = 0

// ================================================================
// Free-var capture: branches reference outer binders
// ================================================================

// Single free var
test ({x} -> if x then 1 else 0) TT = 1
test ({x} -> if x then 1 else 0) FF = 0

// Multiple free vars; both branches use them
test ({x, a, b} -> if x then a else b) TT 5 7 = 5
test ({x, a, b} -> if x then a else b) FF 5 7 = 7

// Asymmetric: only one branch uses the free var
test ({x, a} -> if x then a else 0) TT 9 = 9
test ({x, a} -> if x then a else 0) FF 9 = 0

// ================================================================
// Nested if
// ================================================================

test (if TT then (if FF then 1 else 2) else 3) = 2
test (if FF then 1 else (if TT then 4 else 5)) = 4

// Nested with shared free vars across both levels (multi-line bodies)
test ({x, y} -> if x
  then (if y then 1 else 2)
  else (if y then 3 else 4)) TT FF = 2

test ({x, y} -> if x
  then (if y then 1 else 2)
  else (if y then 3 else 4)) FF TT = 3

// else-if chain (right-associative; the trailing else needs no parens)
let bucket := {n} ->
  if (tree_eq n 0) then 100
  else if (tree_eq n 1) then 200
  else 300
test bucket 0 = 100
test bucket 1 = 200
test bucket 2 = 300

// ================================================================
// Short-circuit: unselected branch never runs
// ================================================================
// `loops y` diverges when applied (infinite recursion via fix).
// If the desugar is correct (select-then-apply with closed branches),
// the else branch's body never fires when x = TT, so the test terminates.
// If it were broken (eager thunks), bracket abstraction over `y` would
// eagerly evaluate `loops y` and the test would hit budget.

let loops := fix ({self, x} -> self x)

test ({x, y} -> if x then y else loops y) TT 5 = 5

// Symmetric case: FF selected, the then-branch has the divergent body
test ({x, y} -> if x then loops y else y) FF 5 = 5

// ================================================================
// `if` composes with other constructs
// ================================================================

// As a block-let member body (line mode: the else body ends at the newline,
// so the block's trailing `r` is left untouched)
test ({x} -> {
  let r := if x then 10 else 20
  r
}) TT = 10

// As the body of a binder
test (({x} -> if x then 1 else 0) TT) = 1

// Scrutinee is an application
let is_zero := {n} -> tree_eq n 0
test (if (is_zero 0) then 1 else 0) = 1
test (if (is_zero 1) then 1 else 0) = 0

// ================================================================
// CPS-style chain (mirrors soundness plan's must_ok_* pattern)
// ================================================================
// A continuation `{r} -> body` whose body has outer free vars is the
// pattern the soundness plan relies on. The continuation must be
// invoked only when the success branch is selected — otherwise the
// "Err short-circuit" property is broken.

let succ_only := {c, k, x} ->
  if c then k x else loops x

// When c=TT, k is invoked with x.
test succ_only TT ({y} -> y) 7 = 7

// When c=FF, the else branch runs `loops x` which diverges. So the test
// budget would blow up if we ever reached the else branch via c=TT.
test succ_only TT ({y} -> succ y) 4 = 5

// ================================================================
// S2 regression: select_lazy + self-recursion compiles via auto-rewrite
// ================================================================
// Before the S2 fix, this pattern (`select_lazy` with a recursive call
// in one of the thunks) blew the compile-time budget because cirToTree
// eagerly reduced the resulting K(body) form. The elaborator now
// rewrites `select_lazy ({_} -> A) ({_} -> B) cond` to
// `if cond then A else B`, side-stepping the eager reduction.

let count_down := fix ({self, n} ->
  select_lazy
    ({_} -> 0)
    ({_} -> succ (self (pair_snd n)))
    (tree_eq n t))

test count_down 0 = 0
test count_down 3 = 3

// Nested select_lazy with self-recursion under both arms.
let count_down2 := fix ({self, n} ->
  select_lazy
    ({_} -> 0)
    ({_} ->
      select_lazy
        ({_} -> 1)
        ({_} -> succ (self (pair_snd n)))
        (tree_eq (pair_snd n) t))
    (tree_eq n t))

test count_down2 0 = 0
test count_down2 1 = 1
test count_down2 3 = 3

// ================================================================
// Coproduct match: string-tag arms, wildcard, multi-binder destructuring
// ================================================================

// Arm constructor names are TAGS BY SPELLING (strings) — no tag in scope needed.
let classify := {c} -> match c { inc n => succ n; id x => x; _ => zero }
test classify (inj "inc" zero) = succ zero
test classify (inj "id" (succ zero)) = succ zero
test classify (inj "other" TT) = zero // wildcard: unmatched tag -> default

// Nullary arm ignores the (unit) payload.
let opt := {c} -> match c { none => zero; some x => x }
test opt (inj "none" t) = zero
test opt (inj "some" (succ zero)) = succ zero

// Multi-binder arm destructures a right-nested-pair payload (Σ-chain layout):
//   pt a b c   ≡   inj "pt" (pair a (pair b c))
let p3 := inj "pt" (pair zero (pair (succ zero) (succ (succ zero))))
test (match p3 { pt x y z => x }) = zero // x = fst
test (match p3 { pt x y z => y }) = succ zero // y = fst snd
test (match p3 { pt x y z => z }) = succ (succ zero) // z = snd snd
test (match p3 { pt x y z => t x (t y z) }) = t zero (t (succ zero) (succ (succ zero)))

// Wildcard with no named arms is a total default.
test (match (inj "anything" TT) { _ => zero }) = zero
