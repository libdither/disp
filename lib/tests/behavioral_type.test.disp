// R6 LANDED (2026-07-01): Type := BehavioralType — GoodRespond IN THE UNIVERSE.
// `T : Type` now certifies BOTH observable faces (recognizer + MetaShape) AND, for gated
// inductives with concrete variants, that the respond BEHAVES: coherent cases -> Extend (motive s)
// (coh dim) and per-case junk -> Extend InvalidType (junk dims, only for responds that CLAIM to
// gate — declared-ungated `inductive_respond` types skip them and stay defended downstream, R0).
// Tractable EVERYWHERE because do_check routes membership through param_apply: under an ambient
// walk the SS7A token gives each nested check a FRESH NATIVE walker, so nesting FLATTENS —
// the former every-backend OOM (r6_merge_proto RESIDUAL: rust-eager 3.4GiB abort) is gone.
open use "../kernel/prelude.disp"
open use "../std/nat.disp"

// ── the old OOM pins: the universe check nested under other walkers ──
test tree_eq (param_apply Type Bool) (Ok true) = true
test tree_eq (param_apply Type Nat)  (Ok true) = true
let OuterCheck := wait (make_recognizer ({m, v} -> param_apply Type v)) (make_meta unit_witness inert_respond)
test tree_eq (param_apply OuterCheck Bool) (Ok true) = true   // was OOM on every backend
test tree_eq (param_apply OuterCheck Nat)  (Ok true) = true   // was OOM (recursive)
let Outer2 := wait (make_recognizer ({m, v} -> param_apply OuterCheck v)) (make_meta unit_witness inert_respond)
test tree_eq (param_apply Outer2 Nat) (Ok true) = true        // two levels — flattening, not one-shot relief

// ── discrimination: the behavioral dimensions actually bite at certification ──
// inert respond (over-restrictive): not a Type
let BadMyNat := Coproduct_respond inert_respond [pair "z" [], pair "s" [Rec]]
test tree_eq (param_apply Type BadMyNat) (Ok false) = true
// Param-marked (List-shaped): good gate accepted, inert rejected — discrimination is genuine for params
let view_l := {v} -> triage (Ok (inj "nil" t)) ({_} -> Err) ({h, tl} -> Ok (inj "cons" (pair h tl))) v
let encode_l := {x} -> if (tree_eq (pair_fst x) "cons") then (t (pair_fst (pair_snd x)) (pair_snd (pair_snd x))) else t
let GoodList := Coproduct_viewed_respond (cons Nat nil) (gated_inductive_respond (coh_check (cons Nat nil))) (pair view_l encode_l) [pair "nil" [], pair "cons" [Param zero, Rec]]
test tree_eq (param_apply Type GoodList) (Ok true) = true
let BadList := Coproduct_viewed_respond (cons Nat nil) inert_respond (pair view_l encode_l) [pair "nil" [], pair "cons" [Param zero, Rec]]
test tree_eq (param_apply Type BadList) (Ok false) = true
// a LYING gate (claims to gate, accepts everything): caught by the junk dims
let LyingNat := Coproduct_respond (gated_inductive_respond ({T, m, c} -> Ok true)) [pair "z" [], pair "s" [Rec]]
test tree_eq (param_apply Type LyingNat) (Ok false) = true
// declared-ungated (respond IS inductive_respond): junk dims skipped — a visible, accepted category
let UngatedNat := Coproduct_respond inductive_respond [pair "z" [], pair "s" [Rec]]
test tree_eq (param_apply Type UngatedNat) (Ok true) = true

// ── the dispatch boundaries ──
// an abstract-variants former instance takes the structural branch (no declaration to derive from)
test tree_eq (param_apply (Pi Tree ({_} -> Type)) Coproduct) (Ok true) = true
// the universes: behavioral self-inhabits; the structural universe is a Type; Type recognizes StrictType
test tree_eq (param_apply Type Type) (Ok true) = true
test tree_eq (param_apply Type StrictType) (Ok true) = true
test tree_eq Type BehavioralType = true   // the flip, pinned
