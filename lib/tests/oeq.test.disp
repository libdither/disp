// Observational equivalence (std/oeq.disp): the setoid-valued fourth face of a type.
// Pins, layer by layer:
//   data      — oeq collapses to Eq, laws compute on refl
//   functions — funext is the DEFINITION (pointwise lift); laws lift pointwise
//   linked pairs — LinkedPi binds two inhabitants + their link; respect witnesses
//                  check abstractly; transport at concretes is the IDENTITY
//   quotients — behavioral_specs overrides the setoid (image_setoid = quotient by
//               observation); respecting eliminators check, non-respecting ones reject
open use "../kernel/prelude.disp"
open use "../std/list.disp"
open use "../std/nat/ops.disp"
open use "../std/oeq.disp"

// ── data layer: oeq = Eq, definitionally, and the laws compute on refl ──
test tree_eq (oeq Nat 3 3) (Eq Nat 3 3) = true
test typecheck (oeq Nat 3 3) refl = Ok true
test typecheck (oeq Nat 3 4) refl = Ok false
test tree_eq (oeq_refl Nat 3) refl = true
test tree_eq (oeq_sym Nat 3 3 refl) refl = true
test tree_eq (oeq_trans Nat 3 3 3 refl refl) refl = true

// ── function layer: two pointwise-equal, tree-distinct programs and their license ──
let FnT := Arrow NatList NatList
let mp := {f, xs} -> list_rec ({_} -> NatList) nil ({h, tl, ih} -> cons (f h) ih) xs
let idA := {xs} -> xs
let idB := {xs} -> mp ({x} -> x) xs
let map_id_law := {a} -> list_rec
  ({xs_} -> Eq NatList xs_ (mp ({x} -> x) xs_))
  refl
  ({h, tl, ih} -> eq_cong NatList NatList ({t_} -> cons h t_) tl (mp ({x} -> x) tl) ih)
  a
// funext as definition: the pointwise induction proof IS an oeq inhabitant
test param_apply (oeq FnT idA idB) map_id_law = Ok true
// the lifted laws check at the function layer
test param_apply (oeq FnT idA idA) (oeq_refl FnT idA) = Ok true
test param_apply (oeq FnT idB idA) (oeq_sym FnT idA idB map_id_law) = Ok true
test param_apply (oeq FnT idA idB) (oeq_trans FnT idA idA idB (oeq_refl FnT idA) map_id_law) = Ok true

// ── linked pairs: a respect witness for an extensional motive, checked abstractly ──
let P_good := {h} -> Eq NatList (h nil) nil
let resp_good := {h0, h1, rho, x} ->
  eq_subst NatList (h0 nil) (h1 nil) ({z} -> Eq NatList z nil) (rho nil) x
test param_apply (LinkedPi FnT ({h0} -> {h1} -> {rho} -> Arrow (P_good h0) (P_good h1))) resp_good = Ok true
// transport at concretes is the identity: the fibers share the inhabitant, and the
// abstract witness computes to the identity on it
test typecheck (P_good idA) refl = Ok true
test typecheck (P_good idB) refl = Ok true
test tree_eq (resp_good idA idB map_id_law refl) refl = true
// the limit (why the ext-gate probe exists): an INTENSIONAL motive's fibers collapse on
// hyps, so its respect obligation is vacuously checkable; the concrete fraud is caught
// by the use-site re-check
let P_bad := {h} -> if (tree_eq h idA) then Unit else False
test param_apply (LinkedPi FnT ({h0} -> {h1} -> {rho} -> Arrow (P_bad h0) (P_bad h1))) ({h0, h1, rho, x} -> x) = Ok true
test tree_eq (P_bad idA) Unit  = true
test tree_eq (P_bad idB) False = true
test typecheck (P_bad idB) unit_val = Ok false

// ── records: componentwise (non-dependent fields), the licensed-module shape ──
let PP := { f : (Arrow NatList NatList), g : (Arrow NatList NatList) }
let rA := { f := idA; g := idA }
let rB := { f := idB; g := idB }
test param_apply (oeq PP rA rB) { f := map_id_law; g := map_id_law } = Ok true
test param_apply (oeq PP rA rA) (oeq_refl PP rA) = Ok true
test param_apply (oeq PP rB rA) (oeq_sym PP rA rB { f := map_id_law; g := map_id_law }) = Ok true
// a DEPENDENT record falls back to the Eq base (stating componentwise relatedness there
// would need transport along the earlier components — the coe rung, deliberately absent)
let DepT := { a : Nat, p : (Eq Nat a 3) }
test tree_eq (oeq DepT { a := 3; p := refl } { a := 3; p := refl }) (Eq DepT { a := 3; p := refl } { a := 3; p := refl }) = true

// ── quotients: Parity = Nat with oeq coarsened by an observation ──
let is_even := {n} -> nat_rec ({_} -> Bool) true ({p, ih} -> not ih) n
let Parity := wait (make_recognizer ({m, v} -> param_apply Nat v))
  { recognizer_params := unit_witness; functor := trivial_functor; respond := inert_respond;
    behavioral_specs := { setoid := image_setoid is_even Bool } }
test typecheck Type Parity = Ok true
test param_apply Parity 6 = Ok true
test typecheck (oeq Parity 2 4) refl = Ok true      // 2 ~ 4 (same parity)
test typecheck (oeq Parity 2 3) refl = Ok false      // 2 !~ 3
test tree_eq (oeq_sym Parity 2 4 refl) refl = true  // laws inherited from Eq via image_setoid
test tree_eq (oeq_trans Parity 2 4 6 refl refl) refl = true
// eliminator respect over the quotient: the defining observation respects it by identity
// (rho's type IS the goal)...
test param_apply (LinkedPi Parity ({q0} -> {q1} -> {rho} -> Eq Bool (is_even q0) (is_even q1))) ({q0, q1, rho} -> rho) = Ok true
// ...and a class-splitting eliminator's claimed witness is rejected (is_zero separates 2 from 4)
test param_apply (LinkedPi Parity ({q0} -> {q1} -> {rho} -> Eq Bool (is_zero q0) (is_zero q1))) ({q0, q1, rho} -> refl) = Ok false
