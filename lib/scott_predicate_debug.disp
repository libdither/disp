open use "prelude.disp"

TTs := {tc, fc} -> tc
FFs := {tc, fc} -> fc

// Direct sanity:
test tree_eq t TTs = FF
test tree_eq t FFs = FF

// And the OR of these:
test or (tree_eq t TTs) (tree_eq t FFs) = FF

// Why did is_scott_bool t return TT?
is_scott_bool := {v} -> or (tree_eq v TTs) (tree_eq v FFs)
test is_scott_bool t = FF
