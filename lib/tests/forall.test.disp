// Forall — intersection-style quantifier. `Forall A P` is inhabited by
// values v such that `(P a) v = TT` for every closed `a : A`. Unlike
// Pi, the body applies `P hyp` to the SAME v (not to v applied to hyp):
// Forall is a predicate over a single carrier, not a function type.
//
// The recognizer mints a hypothesis of A via bind_hyp, applies P to it
// (producing a type), and then checks v against that type. bind_hyp's
// escape check walls off any leak of the hypothesis through non-neutral
// paths in the result.
//
// Per TYPE_THEORY.typ §5.8.

open use "../prelude.disp"
open use "../kernel/prelude.disp"

// ================================================================
// Identity sanity: Forall is a public guarded predicate_frame type.
// ================================================================
test hasguard (Forall Nat ({_} -> Bool)) = TT
test tree_eq (pair_fst (type_meta (Forall Nat ({_} -> Bool)))) kernel_predicate_frame_sig = TT
test is_forall (Forall Nat ({_} -> Bool)) = TT
test is_forall Nat = FF

// ================================================================
// Reflection helpers
// ================================================================
test forall_dom (Forall Nat ({_} -> Bool)) = Nat
test forall_pred_fn (Forall Nat ({_} -> Bool)) 0 = Bool

// ================================================================
// Forall A ({_} -> Bool): every Bool inhabits this.
// ================================================================
// The predicate P doesn't depend on the hypothesis — it returns Bool
// for every a:A. So `(P hyp) v = Bool v`, which is TT iff v is TT/FF.

test Forall Nat ({_} -> Bool) TT = TT
test Forall Nat ({_} -> Bool) FF = TT

// A non-Bool value is rejected — `Bool 5 = FF`.
test Forall Nat ({_} -> Bool) 5 = FF

// Same shape with Bool as the carrier (the carrier is irrelevant when P
// doesn't depend on its argument):
test Forall Bool ({_} -> Bool) TT = TT
test Forall Bool ({_} -> Bool) FF = TT
test Forall Bool ({_} -> Bool) 0 = FF

// ================================================================
// Forall Nat ({_} -> Nat) — Nat-only values pass for every a:Nat.
// ================================================================
test Forall Nat ({_} -> Nat) 0 = TT
test Forall Nat ({_} -> Nat) 3 = TT
test Forall Nat ({_} -> Nat) TT = FF

// ================================================================
// Negative: a value that inhabits P-at-one-A but not for every a.
// ================================================================
// P b = select Nat Bool b. Then `Forall Bool P v` requires v to inhabit
// BOTH Nat (P TT) and Bool (P FF). No closed value satisfies both:
// - 5 is a Nat but not a Bool, so Forall rejects.
// - TT is a Bool but not a Nat, so Forall rejects.

let dep_P = {b} -> select Nat Bool b
test Forall Bool dep_P 5 = FF
test Forall Bool dep_P TT = FF
test Forall Bool dep_P FF = FF

// ================================================================
// Public boundary rejects hypothesis input.
// ================================================================
let forall_hyp = Hyp (Forall Nat ({_} -> Bool)) 0
test Forall Nat ({_} -> Bool) forall_hyp = FF
