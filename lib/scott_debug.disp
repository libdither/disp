open use "prelude.disp"

TTs := {tc, fc} -> tc
FFs := {tc, fc} -> fc

// Sanity: are TTs / FFs distinct trees from t / t t?
test tree_eq TTs t = FF
test tree_eq TTs (t t) = FF
test tree_eq FFs t = FF
test tree_eq FFs (t t) = FF
test tree_eq TTs FFs = FF

// What ARE TTs and FFs?
test TTs = TTs
test FFs = FFs
