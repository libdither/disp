// Tests for the new-kernel core (lib/next/core.disp): the two-Σ-op shape end
// to end — param_apply dispatch, recognition + H-rule, hyp_reduce spine
// extension via respond, typecheck, and the boundary scan.

open use "../prelude.disp"
open use "../kernel/prelude.disp"

// ---- recognition via param_apply (the dispatcher) ----
test param_apply Bool TT = Ok TT
test param_apply Bool FF = Ok TT
test param_apply Bool zero = Ok FF
test param_apply Nat zero = Ok TT
test param_apply Nat (succ (succ zero)) = Ok TT
test param_apply Nat TT = Ok FF

// ---- typecheck (sanitize + recognize); closed queries only ----
test typecheck Bool TT = Ok TT
test typecheck Nat (succ zero) = Ok TT
test typecheck Bool zero = Ok FF

// param_lift rejects a public neutral
test param_lift (mint_hyp Nat 0) = Fail
test is_closed (mint_hyp Nat 0) = FF
test is_closed (succ zero) = TT

// ---- H-rule via param_apply (reached directly, not through typecheck) ----
let hB = mint_hyp Bool 0
let hN = mint_hyp Nat 0
test param_apply Bool hB = Ok TT          // Bool-hyp inhabits Bool (H-rule)
test param_apply Nat hN = Ok TT
test param_apply Bool hN = Ok FF          // Nat-hyp does not inhabit Bool
test param_apply Nat hB = Ok FF

// ---- hyp_reduce spine extension via the (gated) inductive respond ----
// Applying a Nat-neutral to a case-frame (pair motive cases) yields a stuck
// elimination: a fresh neutral stored at `motive self`. hyp_reduce results are
// Ok-wrapped CheckerResults, so `stuck` is Ok(neutral). The respond now gates the
// cases against the motive (§B), so the cases must be COHERENT: with motive Bool,
// base : Bool and step : Π n. Bool -> Bool.
let motive = {n} -> Bool
let cases = pair TT ({pred, ih} -> ih)         // base TT : Bool ; step returns ih : Bool
let stuck = param_apply hN (pair motive cases)
test is_ok stuck = TT
test is_neutral (ok_value stuck) = TT
test neutral_type (ok_value stuck) = Bool      // motive applied to the reconstructed self

// elim drives the same: concrete target runs the dispatcher, neutral routes here
let nat_dispatcher = {motive, cases, target} -> pair_fst cases   // toy: returns base
test elim nat_dispatcher motive cases zero = TT                  // concrete branch -> base (TT)
test is_neutral (elim nat_dispatcher motive cases hN) = TT  // neutral branch

// ---- bind_hyp (Σ-op): mint, run body, escape-check ----
test bind_hyp Nat ({x} -> Ok zero) = Ok zero            // result independent of x
test bind_hyp Nat ({x} -> Ok x) = Fail                  // x at public position -> escape
test bind_hyp Nat ({x} -> Ok (pair x zero)) = Fail      // x inside a user pair -> escape

// ---- checked values + Pi (monomorphic dependent function) ----
// Bodies must be walker-safe (no raw triage on the argument). Identity, const,
// and constructor-building bodies (e.g. `succ y`) qualify — the recogniser is
// H-rule-aware at every level (§A). Genuinely case-analysing bodies still route
// through the eliminator, which gates its cases against the motive (§B).
let id_nat = checked Nat ({n} -> n)
let const_true = checked Nat ({n} -> TT)
test param_apply (Pi Nat ({_} -> Nat)) id_nat = Ok TT       // id : Nat -> Nat
test typecheck (Arrow Nat Nat) id_nat = Ok TT               // same via Arrow + typecheck
test param_apply (Pi Nat ({_} -> Bool)) const_true = Ok TT  // const TT : Nat -> Bool
test param_apply (Pi Nat ({_} -> Nat)) const_true = Ok FF   // body returns Bool, not Nat
test param_apply (Pi Bool ({_} -> Nat)) id_nat = Ok FF      // domain mismatch (stored Nat)

// (§A) constructor-over-the-argument now checks: the recogniser re-applies the
// H-rule on the neutral predecessor in `succ hyp` instead of triaging it.
test param_apply (Pi Nat ({_} -> Nat)) (checked Nat ({y} -> succ y)) = Ok TT

// (§B) the eliminator's cases must inhabit the motive. Enforced in the TYPE's
// respond (keyed off the neutral's stored type), so it is UNBYPASSABLE: the kernel
// recursor, a hand-rolled recursor, and raw neutral application are all gated.
let lying  = {y} -> nat_rec ({_} -> Nat) TT ({p, ih} -> TT) y        // base/step Bool, motive says Nat
let lying2 = {y} -> nat_rec ({_} -> Nat) zero ({p, ih} -> TT) y      // correct base, lying step
let honest = {y} -> nat_rec ({_} -> Nat) zero ({p, ih} -> succ ih) y
test param_apply (Pi Nat ({_} -> Nat)) (checked Nat lying)  = Ok FF  // incoherent cases -> rejected
test param_apply (Pi Nat ({_} -> Nat)) (checked Nat lying2) = Ok FF  // step lie also caught
test param_apply (Pi Nat ({_} -> Nat)) (checked Nat honest) = Ok TT  // coherent -> accepted
test honest (succ (succ zero)) = succ (succ zero)                    // value-transparent on concrete targets

// adversarial: a USER's OWN recursor (own dispatcher, via elim) is gated identically,
// because on a neutral target elim applies the neutral -> the type's respond -> gate.
let my_dispatcher = fix ({self, motive, cases, target} ->
  match (tree_eq target zero) { TT => pair_fst cases; FF => (pair_snd cases) (pair_snd target) (self motive cases (pair_snd target)) })
let my_rec = {motive, base, step, target} -> elim my_dispatcher motive (pair base step) target
test param_apply (Pi Nat ({_} -> Nat)) (checked Nat ({y} -> my_rec ({_} -> Nat) TT ({p, ih} -> TT) y))        = Ok FF
test param_apply (Pi Nat ({_} -> Nat)) (checked Nat ({y} -> my_rec ({_} -> Nat) zero ({p, ih} -> succ ih) y)) = Ok TT
// applying the neutral to a hand-built frame directly is also gated:
test param_apply (Pi Nat ({_} -> Nat)) (checked Nat ({y} -> must_ok_or_self (y (pair ({_} -> Nat) (pair TT ({p, ih} -> TT)))))) = Ok FF
// and you cannot bypass by DESTRUCTURING the neutral -- triage on a hyp is rejected:
test param_apply (Pi Nat ({_} -> Nat)) (checked Nat ({y} -> pair_snd y)) = Fail
// the gate is general: Bool's recursor is gated the same way (no recursive args).
test param_apply (Pi Bool ({_} -> Nat)) (checked Bool ({b} -> bool_rec ({_} -> Nat) TT TT b))            = Ok FF
test param_apply (Pi Bool ({_} -> Nat)) (checked Bool ({b} -> bool_rec ({_} -> Nat) zero (succ zero) b))  = Ok TT

// ---- cut_apply: the contract boundary on direct application ----
// Applying a `checked` value runs cut_apply: the arg is checked against the
// stored domain before the function fires. Domain holds -> Ok (fn arg);
// domain fails -> Fail (the TypeMismatch boundary, §3 verdict-vs-error).
test (checked Nat ({n} -> n)) (succ zero) = Ok (succ zero)  // domain holds
test (checked Nat ({n} -> n)) TT = Fail                     // TT is not a Nat -> contract breakage
// the checked payload is a {dom, fn} record; the domain is read back by name
test checked_dom (checked Nat ({n} -> n)) = Nat

// ---- MetaShape metadata is a §2.6 headered record, read BY NAME (the cut) ----
// make_meta builds a `prod`; the meta_* accessors are the cut against the
// canonical field-name tags, not positional pair projections.
test meta_respond (type_meta Bool) = bool_respond          // Bool now carries the gated respond (§B)
test meta_respond (type_meta Unit) = inductive_respond     // an ungated inductive type
test meta_respond (type_meta False) = inert_respond
test meta_functor (type_meta Nat) = trivial_functor
test meta_respond (type_meta Type) = type_predicate_h_rule
// a hand-built meta round-trips field-by-field
let m = make_meta zero TT FF unit_val
test meta_params m = zero
test meta_functor m = TT
test meta_respond m = FF
test meta_specs m = unit_val
test has_metashape_layout m = TT
test has_metashape_layout (pair zero (pair TT (pair FF unit_val))) = FF  // old positional shape is no longer a meta
// recognizer_params is itself an inline record read by name (Pi's { dom, cod })
test (meta_params (type_meta (Pi Nat ({_} -> Bool)))).dom = Nat
test (meta_params (type_meta (Sigma Nat ({_} -> Bool)))).dom = Nat
// and a kernel meta projects respond directly via .field
test (type_meta Bool).respond = bool_respond
