// PROTOTYPE: are refine/imeet/eqends necessary? NO — they're all instances of ONE general observe-and-
// check op `obs {get, ty}` = "observe (get source prior), check it : ty". Which ALSO subsumes qid/apply/
// pos. Only `mint` (∀-intro, returns SMint not a check) is genuinely a separate primitive. So the
// recognize-face cell vocabulary collapses to TWO primitives: `mint` + `obs`.
open use "../kernel/prelude.disp"
open use "../std/nat/arith.disp"

let SThread := inj1 "SThread"
let SReject := inj0 "SReject"
let SDone   := inj1 "SDone"
let do_check := {mode, getr, ty} -> if mode then (match (getr t) { Ok part => (match (ty part) { Ok b => (if b then (SThread part) else SReject); Err _ => SReject }); Err _ => SReject }) else (SDone (Extend ty))
let Singleton := {x} -> wait (make_recognizer ({m, v} -> Ok (tree_eq v x))) (make_meta unit_witness inert_respond)
let tele_with := {cells, respond} -> wait (make_recognizer ({meta, v} -> tele_walk t true (meta.recognizer_params) v t t)) (make_meta cells respond)

// THE one general op: observe (get source prior), check it : ty.
let obs_op := {meta, mode, source, prior, frame, rs} -> do_check mode ({_} -> Ok (meta.get source prior)) (meta.ty)
let obs_cell := {get, ty} -> wait obs_op { get := get; ty := ty }
let self_optic := {s, p} -> s   // the qid optic: observe v itself

// Re-derive each meet type from `mint` + `obs` ONLY:
//   Refinement A P = [ obs(v, A) ; obs(P v, Singleton true) ]      (refine = obs on P-applied-to-v vs Singleton true)
let Refinement_o  := {A, P} -> tele_with (t (obs_cell self_optic A) ({_} -> t (obs_cell ({s, p} -> P s) (Singleton true)) ({_} -> t))) inert_respond
//   Intersection A P = [ mint A ; obs(v, P h) ]                  (imeet UNNEEDED — bake `P h` in the continuation, like Pi's apply bakes `B h`)
let Intersection_o := {A, P} -> tele_with (t (mint_cell A) ({h} -> t (obs_cell self_optic (P h)) ({_} -> t))) inert_respond
//   Eq A x y = [ obs(v, Singleton refl) ; obs(x, Singleton y) ] (eqends = obs on a stored endpoint vs Singleton of the other)
let Eq_o := {A, x, y} -> tele_with (t (obs_cell self_optic (Singleton refl)) ({_} -> t (obs_cell ({s, p} -> x) (Singleton y)) ({_} -> t)))
  ({params, self, frame} -> match (apply_policed frame.motive y) { Ok ty => Extend ty; Err _ => Extend InvalidType })

let is_zero := {n} -> tree_eq n zero
// EQUIVALENCE to the LANDED kernel versions (which use the dedicated refine/imeet/eqends ops):
test param_apply (Refinement_o Nat is_zero) zero        = param_apply (Refinement Nat is_zero) zero
test param_apply (Refinement_o Nat is_zero) (succ zero) = param_apply (Refinement Nat is_zero) (succ zero)
test param_apply (Intersection_o Nat ({_} -> Nat)) zero = param_apply (Intersection Nat ({_} -> Nat)) zero
test param_apply (Eq_o Nat zero zero) refl              = param_apply (Eq Nat zero zero) refl
test param_apply (Eq_o Nat zero (succ zero)) refl       = param_apply (Eq Nat zero (succ zero)) refl
test param_apply (Eq_o Nat zero zero) (succ zero)       = Ok false       // only refl inhabits
// also confirm qid itself is just obs(self, ty): obs-based vs the kernel qid_cell on a plain membership
test param_apply (tele_with (t (obs_cell self_optic Nat) ({_} -> t)) inert_respond) zero = Ok true
test param_apply (tele_with (t (obs_cell self_optic Nat) ({_} -> t)) inert_respond) false   = Ok false
