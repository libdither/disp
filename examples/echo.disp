// Read one line from stdin, print it back — spelled with the arrow member
// (`x <- e` is monadic bind in a block; the block desugars to eff_bind).
//   echo "hi" | npm run disp -- examples/echo.disp
open use "../lib/kernel/prelude.disp"
open use "../lib/std/effect.disp"
open use "../lib/std/io.disp"

main : Eff io_row Unit := {
  line <- read_line
  print line
}
