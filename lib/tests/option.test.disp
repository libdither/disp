open use "../kernel/prelude.disp"
open use "../std/nat/ops.disp"
open use "../std/option.disp"

// Constructors are distinct
test is_none none = true
test is_some none = false
test is_some (some 7) = true
test is_none (some 7) = false

// Option Nat accepts/rejects
test Option Nat none = Ok true
test Option Nat (some 0) = Ok true
test Option Nat (some false) = Ok false // false = △ △, no Nat shape (true = △ = zero would pass)
// A value with an unknown tag (not some/none) is rejected
test Option Nat (inj "huh" 5) = Ok false

// Option Bool
test Option Bool (some true) = Ok true
test Option Bool (some false) = Ok true
test Option Bool none = Ok true
test Option Bool (some 3) = Ok false

// option_rec dispatches the right branch
test option_rec ({_} -> Nat) 0 ({v} -> succ v) none = 0
test option_rec ({_} -> Nat) 0 ({v} -> succ v) (some 4) = 5

// option_map
test option_map succ none = none
test option_map succ (some 4) = some 5

// option_and_then
let some_pred := {n} ->
  if (is_zero n) then none else (some (pred n))
test option_and_then (some 5) some_pred = some 4
test option_and_then (some 0) some_pred = none
test option_and_then none some_pred = none

// option_unwrap_or / option_or
test option_unwrap_or 99 none = 99
test option_unwrap_or 99 (some 5) = 5
test option_or (some 1) (some 2) = some 1
test option_or none (some 2) = some 2
test option_or none none = none

// Under a Pi binder — the PARAMETRIC eliminator option_rec routes a neutral
// Option through the coproduct respond, so this typed binding VERIFIES.
let first_or_zero : Option Nat -> Nat := {o} -> option_rec ({_} -> Nat) 0 ({v} -> v) o
test param_apply (Arrow (Option Nat) Nat) ({o} -> option_rec ({_} -> Nat) 0 ({v} -> v) o) = Ok true
test first_or_zero (some 8) = 8
test first_or_zero none = 0
