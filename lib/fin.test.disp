open use "prelude.disp"
trust open use "kernel.disp"
open use "list.disp"
open use "fin.disp"

test Fin 3 0 = TT
test Fin 3 2 = TT
test Fin 3 3 = FF

test fin0 4 = 0
test fin_one_of_three = 1
test fin_two_of_three = 2

test VecNat 0 vnil = TT
test VecNat 1 (vsingleton 8) = TT
test VecNat 2 (list_cons 1 (list_cons 2 nil)) = TT
test VecNat 3 (vappend 1 2 (vsingleton 1) (list_cons 2 (list_cons 3 nil))) = TT
