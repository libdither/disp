// PROTOTYPE: POSITIVE_TYPES §8 (doc deleted, git-recoverable) — the coherence gate as a TELESCOPE walk.
// FINDINGS (all asserted true == green):
//  (A) RUNTIME: the gate-as-telescope WORKS, incl. a DEPENDENT motive. The conceptual
//      unification is real — coherence = typecheck `cases` against a derived case-telescope,
//      same `tele_walk`; the IH premise is a Pi cell, minted by the Pi recognizer.
//  (B) SELF-TYPING (the bet): originally FAILED — the wall was `param_apply (Telescope ..)
//      cases` (a concrete recognizer applied to the abstract cases-hyp), because param_apply's
//      body was a raw un-walkable `param_walker` call. RESOLVED 2026-07-01: param_apply routes
//      through the §7A policed token, so the recognition-form gate now ALSO inhabits
//      ProjectingRespondShape (totality — coh_check remains the production gate, whose
//      CORRECTNESS GoodRespond checks; see coh_why_proto for the minimal-trigger pins).
open use "../kernel/prelude.disp"

let case_tele := {mv} ->
  t (proj_cell "base" (mv zero)) ({_} ->
  t (proj_cell "step" (Pi Nat ({n} -> Arrow (mv n) (mv (succ n))))) ({_} -> t))
let coh_tele  := {T, motive, cases} -> param_apply (Telescope (case_tele motive)) cases
let resp_tele := gated_inductive_respond coh_tele

// ════════ (A) RUNTIME CORRECTNESS — the unification, validated ════════
let cmotive := {_} -> Nat                          // constant motive P n = Nat
test coh_tele Nat cmotive { base := zero; step := {n} -> {ih} -> succ ih } = Ok TT  // coherent
test coh_tele Nat cmotive { base := TT;   step := {n} -> {ih} -> succ ih } = Ok FF  // base : not Nat
test coh_tele Nat cmotive { base := zero; step := {n} -> {ih} -> TT }      = Ok FF  // step : not Nat
let dmotive := {n} -> Eq Nat n n                   // DEPENDENT motive P n = (n = n)
test coh_tele Nat dmotive { base := refl; step := {n} -> {ih} -> refl } = Ok TT     // dependent, coherent
test coh_tele Nat dmotive { base := TT;   step := {n} -> {ih} -> refl } = Ok FF     // base : not a proof

// ════════ (B) THE BET — now fully closed: seal (R1) + walkable param_apply (2026-07-01) ════════
// hand-rolled coh_nat, with its internal bind_hyp SEALED (R1, apply_policed, runtime-identical),
// inhabits ProjectingRespondShape (totality):
test param_apply ProjectingRespondShape ((type_meta Nat).respond (type_meta Nat).recognizer_params) = Ok TT
// and the telescope/RECOGNITION-form gated respond now does TOO — the old wall was param_apply's
// un-walkable body, removed by the token routing. (Still TOTALITY, not correctness.)
test param_apply ProjectingRespondShape (resp_tele unit_witness) = Ok TT

// ════════ (WHY — historical) the wall was "concrete recognizer applied to the cases-hyp" ════════
// Bool's REAL respond always self-typed (it applies the NEUTRAL motive-predicate to
// cases-fields — spine extension, walker-clean — never a concrete recognizer):
test param_apply ProjectingRespondShape ((type_meta Bool).respond (type_meta Bool).recognizer_params) = Ok TT
// the EMPTY-telescope gate (⊤, no cells, no IH) was the minimal trigger of the old failure —
// `param_apply (Telescope t) c` itself — and now self-types with the rest:
let empty_gate := {T, m, c} -> param_apply (Telescope t) c
test param_apply ProjectingRespondShape ((gated_inductive_respond empty_gate) unit_witness) = Ok TT
