/// cells.disp
/// 

// telescopes. One observation = one cell; a telescope is a chain of cells; one
// walker (tele_walk) runs the chain for both faces: recognition (mode true, does this value
// satisfy every cell?) and respond (mode false, route this elimination frame through the
// cells). Pi, Sigma, Record, and the meet types are telescopes differing only in which
// cells they chain, so a new type former is a new cell op, not a walker edit.
// Pins: telescope.test, tree_order.test. Design rationale: NEGATIVE_TYPES.md.
//
// How it fits together. A telescope is `t cell (λx. rest)`: the tail binds the value the
// cell observed, so later cells see earlier fields. A cell is itself a wait-form
// `wait op meta`, both inspectable (its signature says which observation, its meta holds
// the data) and runnable. An op answers a Step, plain data: SMint ty (bind a fresh hyp),
// SThread x (record x and continue), SReject, SDone action (finish). tele_walk interprets
// the Step; the recursion and the bind_hyp call live in tele_walk, not in the ops, because
// a continuation passed through a function to bind_hyp miscompiles under nested binders
// (see CLAUDE.md, compiler workarounds). So an op is the per-cell algebra, tele_walk is
// the harness, and new observations plug in as new ops with no walker edit.
// Hermetic (MODULES.md): prelude + raw earlier siblings for values; givens for the
// annotation-forward type names. `given Pi : Tree` is a SELF-forward: annotations
// above Pi's own definition compile arrows through the in-scope Pi, so the barrel
// fills it from the raw pass of this very file.
open use raw "../prelude.disp" {}
open use raw "cut.disp" {}
open use raw "engine.disp" {}

open given { Type : Type, Tree : Type, Pi : Tree, Action : Type, Step : Type }

// (Step constructors + do_check are exported: they are the vocabulary a userland cell op
// speaks. The ops themselves stay unannotated: they branch on `mode`, which sticks on a
// minted Bool-hyp, the one generic point the Pi check cannot cross.)
SMint   : Type -> Step := inj1 "SMint"
SThread : Tree -> Step := inj1 "SThread"
SReject : Step := inj0 "SReject"
SDone   : Action -> Step := inj1 "SDone"

// The cell ops. Every op has the same shape: {meta, mode, source, prior, frame, rs} -> Step.
//   mode    true = recognize a candidate, false = answer an elimination frame
//   source  the candidate value (recognize) or the stuck neutral (respond)
//   prior   the value observed by the previous cell in the chain
//   frame   the elimination frame (respond face only)
//   rs      the recursion environment: the type itself (rec) or a context fn (rec_at)
//
//   op      observes                 accepts when          on a frame
//   mint    nothing (binds a hyp)    always                instantiate binder, extend at codomain
//   apply   source prior             : ty                  extend at ty
//   proj    field `name` of source   : ty                  route the frame by field name
//   derive  field `name` of source   equals recipe         Reduce recipe
//   pos     acc source (a raw slot)  : ty                  extend at ty
//   qid     source itself            : ty                  extend at ty
//   refine  source itself            pred source = true      reject (inert)
//   imeet   source itself            : pred prior          extend at pred prior
//   eqends  nothing                  stored lhs = rhs      reject (inert)
//   rec     acc source               : F rs                (dead: sums respond via their respond)
//   gen     acc source               is_gen                extend at rs (codata: never descend)
//   rec_at  acc source               : rs idx              (dead, as rec)
//
// Most ops delegate to do_check, whose `getr` is a thunk so the respond face never runs
// the observation on a neutral. The membership check routes through param_apply rather
// than raw `ty part`: under an ambient walk the §7A token gives the sub-check a fresh
// native walker instead of distributing ty's recognizer through the outer walk, which
// flattens nested checks to top-level cost. Verdicts are unchanged (walker rejections
// map to SReject anyway).
do_check := {mode, getr, ty} ->
  if mode
    then (match (getr t) { Ok part => (match (param_apply ty part) { Ok b => (if b then (SThread part) else SReject); Err _ => SReject }); Err _ => SReject })
    else (SDone (Extend ty))
let mint_op := {meta, mode, source, prior, frame, rs} -> SMint (meta.ty) // ∀-intro: `tele_walk` mints (CHECK) / lands the codomain (STUCK)
let apply_op := {meta, mode, source, prior, frame, rs} -> do_check mode ({_} -> Ok (source prior)) (meta.ty) // Pi codomain: observe `source prior`
let proj_op := {meta, mode, source, prior, frame, rs} -> // a record field: honest lookup (key optic); STUCK frame-routes (§7B)
  if mode
    then (do_check true ({_} -> lookup_field source (meta.name)) (meta.ty))
    else (if (tree_eq (pair_fst frame) (meta.name)) then (SDone (Extend (meta.ty))) else (SThread (source (acc (meta.name))))) // §7B: thread field-value via the SANCTIONED elimination source.name
let derive_op := {meta, mode, source, prior, frame, rs} -> // a δ field: present AND pinned to recipe (Pin role)
  if mode
    then (match (lookup_field source (meta.name)) { Err _ => SReject; Ok x => (if (tree_eq x (meta.recipe)) then (SThread (meta.recipe)) else SReject) })
    else (if (tree_eq (pair_fst frame) (meta.name)) then (SDone (Reduce (meta.recipe))) else (SThread (meta.recipe)))

// Cell constructors — the Pi/Sigma/Record wrappers AND the elaborator (recType desugar)
// emit these. is_derive/is_mint_cell inspect a cell by op-signature (a cell's kind is its
// op's checker_sig, the same trick as is_neutral).
mint_cell : Tree -> Tree := {ty} -> wait mint_op { ty := ty }
apply_cell : Tree -> Tree := {ty} -> wait apply_op { ty := ty }
proj_cell : Tree -> Tree -> Tree := {name, ty} -> wait proj_op { name := name; ty := ty }
derive_cell : Tree -> Tree -> Tree := {name, recipe} -> wait derive_op { name := name; recipe := recipe }
is_derive := {cell} -> tree_eq (pair_fst cell) (checker_sig derive_op)
is_mint_cell := {cell} -> tree_eq (pair_fst cell) (checker_sig mint_op)

// pos_cell (POSITIVE_TYPES §5a): a POSITIONAL cell — observe a component of a RAW `inj` payload (not a
// named record) via a stored accessor, then check it : ty. Lets `tele_walk` walk a constructor's arg tuple (pluggable).
let pos_op := {meta, mode, source, prior, frame, rs} -> do_check mode ({_} -> Ok (meta.acc source)) (meta.ty) // positional slot
pos_cell : Tree -> Tree -> Tree := {acc, ty} -> wait pos_op { acc := acc; ty := ty }

// The meet ops, used by the conjunction types. Intersection/Refinement/Eq recognize via a
// 2-cell telescope and keep a type-specific respond (hybrids, like StrictType). qid
// observes v itself and checks it against a type (Refinement's `v : A`, StrictType's
// recognizer face). refine checks a Bool predicate on v. imeet checks v against
// `pred prior`, the predicate applied to the freshly minted hyp threaded as prior
// (Intersection). eqends stores (type, lhs, rhs) so `Eq A x y`'s tree is
// identity-faithful, and accepts when the endpoints convert. (qid_meta, which needs
// MetaShape, lives in universe.disp.)
let qid_op := {meta, mode, source, prior, frame, rs} -> do_check mode ({_} -> Ok source) (meta.ty)
qid_cell := {ty} -> wait qid_op { ty := ty }
let refine_op := {meta, mode, source, prior, frame, rs} -> if mode then (if (meta.pred source) then (SThread source) else SReject) else (SDone (Extend InvalidType))
refine_cell : Tree -> Tree := {P} -> wait refine_op { pred := P }
let imeet_op := {meta, mode, source, prior, frame, rs} -> do_check mode ({_} -> Ok source) (meta.pred prior)
imeet_cell : Tree -> Tree := {P} -> wait imeet_op { pred := P }
let eqends_op := {meta, mode, source, prior, frame, rs} -> if mode then (if (tree_eq (meta.lhs) (meta.rhs)) then (SThread source) else SReject) else (SDone (Extend InvalidType))
eqends_cell : Tree -> Tree -> Tree -> Tree := {A, x, y} -> wait eqends_op { type := A; lhs := x; rhs := y }
// Singleton x: the 1-point type (recognizer = tree_eq v x). The CONV x = MEM (Singleton x) collapse —
// used by Eq (`v : Singleton refl`) and the GoodRespond probe (`result : Singleton outcome`).
Singleton := {x} -> wait (make_recognizer ({m, v} -> Ok (tree_eq v x))) (make_meta unit_witness inert_respond)

// ── Recursion + corecursion as cells. `rec`/`rec_at` recurse via the threaded `rs` (the
// inductive case); `gen` only guards on `is_gen` (the coinductive case: codata is
// infinite, so recognize the finite generator and never descend). A recursive former ties
// its own knot (rs = self); mutual recursion threads a context fn instead. The
// respond-face branches of these ops are dead for sums/codata (they respond via their
// responds) and exist only for totality. `is_gen` reads only the sanctioned pair_fst root
// sig, like is_neutral, so it answers false on a hyp and is walker-safe.
gen_tag := "gen"
is_gen := {v} -> tree_eq (pair_fst v) gen_tag
// rec_op is parameterized by a FUNCTOR `F`: a recursive position checks `acc source : (F self)`. Direct
// recursion is `F = Id`, NESTED is `F = List` etc. ONE op covers both — `rec` is just `rec_under Id`.
let rec_op := {meta, mode, source, prior, frame, rs} -> do_check mode ({_} -> Ok (meta.acc source)) (meta.F rs)        // μ: acc source : F self
let gen_op := {meta, mode, source, prior, frame, rs} ->        // ν: GUARD `is_gen (acc source)`, no descent (Guard role)
  if mode then (if (is_gen (meta.acc source)) then (SThread (meta.acc source)) else SReject) else (SDone (Extend rs))
let rec_at_op := {meta, mode, source, prior, frame, rs} -> do_check mode ({_} -> Ok (meta.acc source)) (rs (meta.idx)) // mutual: acc source : ctx idx
rec_cell : Tree -> Tree -> Tree := {F, acc} -> wait rec_op { F := F; acc := acc }
gen_cell : Tree -> Tree := {acc} -> wait gen_op { acc := acc }
rec_at_cell : Tree -> Tree -> Tree := {idx, acc} -> wait rec_at_op { idx := idx; acc := acc }
// is_rec_cell: marks the functor's RECURSIVE positions (by op-signature, like is_derive) — the data a
// generic fold/map reads to know where to recurse.
is_rec_cell := {cell} -> tree_eq (pair_fst cell) (checker_sig rec_op)

// RecUnder F / Rec / RecAt i: arg-list markers lifted by `pos_tele` to recursive cells. `RecUnder F` ->
// recurse under F (`acc source : F self`); `Rec` = `RecUnder Id` (direct); `RecAt i` -> rec_at_cell (mutual).
// So `[A, Rec]` reads `head:A ; tail:self`, `[Sym, RecUnder List]` reads `tag:Sym ; kids:List self`.
Id := {x} -> x                                  // the identity functor: Id self = self
RecUnder := {F} -> inj "@RecUnder" F
Rec := RecUnder Id
RecAt := {i} -> inj "@RecAt" i
// Param i (CELL_OPTICS): a constructor-arg marker for TYPE PARAMETER #i (what fmap/nmap address).
// Resolved at BUILD time by `pos_tele_p` (→ `pos_cell` checking `params i`), so recognition is unchanged;
// `walk_map` reads the marker to know which slots to map. `List A = Coproduct_p [A] [nil:[]; cons:[Param 0, Rec]]`.
Param := {i} -> inj "@Param" i
is_recunder_marker := {ty} -> and (is_fork ty) (tree_eq (pair_fst ty) "@RecUnder")
is_recat_marker := {ty} -> and (is_fork ty) (tree_eq (pair_fst ty) "@RecAt")
is_param_marker := {ty} -> and (is_fork ty) (tree_eq (pair_fst ty) "@Param")

// const_tail / is_const_tail: the NON-DEPENDENT spine tail. A telescope node is `t cell tail`; an
// INDEPENDENT cell's tail ignores the prior value — the `K rest` shape `t t rest` (what a closed
// `{_} -> rest` compiles to). `is_const_tail` is the §4/§10 dependency-split proxy the canonical sort keys on.
const_tail := {rest} -> t t rest
is_const_tail := {tail} -> and (is_fork tail) (is_leaf (pair_fst tail))

// tele_walk: the spine walker. Apply the head cell's op, interpret the Step, recurse down
// the chain. `rs` is the recursion environment threaded to every op (the recursive type
// itself for rec, a context fn for rec_at; formers that don't recurse pass a dummy `t`).
// On SMint the recognize face binds a fresh hyp for the tail, while the respond face
// routes the tail at the frame's argument and lands the codomain. On SThread the
// recognize face recurses with the observed value, while the respond face instantiates
// the tail under param_walker. SReject means not a member; SDone emits the Action as-is.
tele_walk := fix ({self, rs, mode, tele, source, frame, prior} ->
  if (is_fork tele) then {
    let cell := pair_fst tele
    match (cell mode source prior frame rs) {
      SMint ty => (if mode
                    then (bind_hyp ty ({h} -> self rs true ((pair_snd tele) h) source frame h))
                    else (match (apply_policed (pair_snd tele) frame) { Ok rest => self rs false rest source frame frame; Err _ => Extend InvalidType }))
      SThread x => (if mode
                    then (self rs true ((pair_snd tele) x) source frame x)
                    else (match (apply_policed (pair_snd tele) x) { Ok rest => self rs false rest source frame frame; Err _ => Extend InvalidType }))
      SReject _ => Ok false
      SDone a => a
    }
  } else (if mode then (Ok true) else (Extend InvalidType)))

// tele_with cells respond: the wait-form shape every telescope shares, a telescope
// recognizer (`tele_walk true` over the cells) plus the given respond. Telescope below is
// the negative instance (`tele_walk false` respond); hybrids keep the recognizer but swap in
// a type-specific respond (Eq's J, StrictType's H-rule).
tele_with := {cells, respond} -> wait (make_recognizer ({meta, v} -> tele_walk t true (meta.recognizer_params) v t t)) (make_meta cells respond)

// Telescope: the negative n-ary former, the dependent product over a chain of cells.
// Guard-free: a telescope is the meet of its cells' obligations, so the empty telescope
// is the empty meet, the all-trees predicate (⊤ = Tree). Pi/Sigma are thin instances
// below; Record lifts its flat field list lazily.
Telescope : Tree -> Type := {tele} -> tele_with tele ({params, self, frame} -> tele_walk t false params self frame t)

// Pi A B = the 2-cell telescope [ mint x:A ; apply out:(B x) ] — a thin Telescope instance,
// self-referential (annotation mentions Pi via `->`). mint = ∀-intro (binds arg); apply observes the codomain.
Pi : {A : Type} -> (A -> Type) -> Type := {A, B} -> Telescope (
  t (mint_cell A) ({h} ->
  t (apply_cell (B h)) ({_} -> t)))

Arrow : Type -> Type -> Type := {A, B} -> Pi A ({_} -> B)

// Sigma A B: the dependent pair as a 2-entry telescope { fst : A, snd : B fst }. Values are §2.6 records;
// a Sigma-hyp projects via `acc "fst"`/`acc "snd"` through the telescope respond (`tele_walk false`, dependency preserved).
Sigma : {A : Type} -> (A -> Type) -> Type := {A, B} -> Telescope (
  t (proj_cell "fst" A) ({a} ->
  t (proj_cell "snd" (B a)) ({_} -> t)))

// fields_to_tele_go: lift a flat field list to a const-tail proj-cell telescope (shares Telescope's folds).
// `Param i` fields resolve to `proj_cell name (params i)`. Lifted LAZILY inside the recognizer (not at
// formation) so `Record : Tree -> Type` self-verifies (its param is a neutral there; an eager triage would
// trip the walker). Guard-free like Telescope: a non-record is rejected by `tele_walk`'s lookup_field; `Record []` = ⊤.
let fields_to_tele_go := fix ({self, params, fields} ->
  if (is_fork fields) then {
    let arm := pair_fst fields
    let ty := if (is_param_marker (pair_snd arm)) then (list_nth params (pair_snd (pair_snd arm))) else (pair_snd arm)
    t (proj_cell (pair_fst arm) ty) (const_tail (self params (pair_snd fields)))
  } else t)
Record_p := {params, fields} -> wait (make_recognizer
  {meta, v} -> tele_walk t true (fields_to_tele_go params meta.recognizer_params) v t t
) (make_meta fields ({flds, self, frame} -> tele_walk t false (fields_to_tele_go params flds) self frame t))
Record : Tree -> Type := {fields} -> Record_p t fields
