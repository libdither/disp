// Unit — singleton type tests. Recognizer accepts only `unit_witness`.

open use "../prelude.disp"
open use "../kernel/prelude.disp"

// ================================================================
// Identity sanity: Unit is a public guarded predicate_frame type.
// ================================================================
test hasguard Unit = TT
test tree_eq (pair_fst (type_meta Unit)) kernel_predicate_frame_sig = TT

// ================================================================
// Positive: unit_witness inhabits Unit.
// ================================================================
test Unit unit_witness = TT
test is_unit_witness unit_witness = TT

// ================================================================
// Negative: nothing else inhabits Unit.
// ================================================================
test Unit t = FF                    // bare leaf isn't unit
test Unit TT = FF                   // Scott TT (fork-shaped)
test Unit FF = FF
test Unit (t t (t t t)) = FF  // larger structure
test Unit (t (t t t) t) = FF        // different fork

// is_unit_witness on non-witnesses
test is_unit_witness t = FF
test is_unit_witness (t t (t t t)) = FF
test is_unit_witness TT = FF
