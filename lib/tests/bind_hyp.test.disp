open use "../prelude.disp"
open use "../kernel.disp"

// ================================================================
// Bind-hyp + escape check (migration step 3)
// ================================================================
// bind_hyp := wait kernel_ref.bind_hyp init_meta
// 2-ary: bind_hyp domain body. Mints a fresh hypothesis with stored
// type = domain, applies body to it through ks.checked_apply, runs the
// escape check on the result.

// Body that ignores the hypothesis: result is the closed body value.
test bind_hyp Nat ({h} -> TT) = TT
test bind_hyp Bool ({h} -> FF) = FF
test bind_hyp Nat ({h} -> 5) = 5

// Body that returns the hypothesis directly: escape detected, Fail.
test tree_eq (bind_hyp Nat ({h} -> h)) Fail = TT
test tree_eq (bind_hyp Bool ({h} -> h)) Fail = TT

// Body that returns a fork containing the hypothesis: escape detected.
test tree_eq (bind_hyp Nat ({h} -> t h t)) Fail = TT
test tree_eq (bind_hyp Nat ({h} -> t t h)) Fail = TT

// Body that returns a stem containing the hypothesis: escape detected.
test tree_eq (bind_hyp Nat ({h} -> t h)) Fail = TT

// Identity sanity: bind_hyp has the bind_hyp signature.
test tree_eq (pair_fst bind_hyp) kernel_bind_hyp_sig = TT

// ================================================================
// Predicate-frame Nat
// ================================================================

// Closed Nats accepted.
test Nat_pf 0 = TT
test Nat_pf 1 = TT
test Nat_pf 3 = TT

// Non-Nat closed values rejected. (`t t (t t)` = fork(t, stem(t)) is
// "succ of a non-nat" — fails the recursive recognizer.)
test Nat_pf TT = FF
test Nat_pf (t t (t t)) = FF

// Public boundary rejects hypothesis input.
let nat_pf_hyp = Hyp Nat_pf 0
test Nat_pf nat_pf_hyp = FF

// H-rule reachable via inner core.
let nat_pf_core = type_meta Nat_pf
test nat_pf_core nat_pf_hyp = TT
test nat_pf_core 5 = TT
test nat_pf_core TT = FF

// Identity sanity.
test hasguard Nat_pf = TT
test tree_eq (pair_fst (type_meta Nat_pf)) kernel_predicate_frame_sig = TT
