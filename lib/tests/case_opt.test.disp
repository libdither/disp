// case_opt — the licensed fast face of case_value (std/case.opt.disp).
// The rebind's license (case.disp's CaseRelation) is checked at case.opt's LOAD
// and covers BOTH faces: the explicit pointwise Nat relation (neutral path) and
// the per-constructor LicSum spine equalities with abstract arms + payloads
// (concrete path). This file pins the rest: agreement with the raw cut
// (match) on a FRESH sum, certificates through the verbatim neutral
// delegation, non-cut-class fall-through, junk-tag inertness — and the
// negative control that the relation itself rejects a misdispatcher.
open use "../kernel/prelude.disp"
open use "../std/case.disp"
open use "../std/case.opt.disp"

// an inj-tagged sum: cut-class (identity iso) — the fast tag-cut path fires
ShapeD : Type := Coproduct [pair "DLeaf" [], pair "DStem" [Tree], pair "DFork" [Tree, Tree]]
let cases3 := { DLeaf := 1; DStem := {c} -> 2; DFork := {l, r} -> 3 }
let k_fast := {s} -> case_value ShapeD ({_} -> Nat) cases3 s
let k_cut  := {s} -> match s { DLeaf => 1; DStem c => 2; DFork l r => 3 }

// concrete dispatch, all arities:
test k_fast (inj0 "DLeaf") = 1
test k_fast (inj1 "DStem" (t t)) = 2
test k_fast (inj2 "DFork" t (t t)) = 3

// the license evidence for the CUT relationship, per constructor with ABSTRACT
// payloads (annotated exports auto-verify at load — every concrete member is in
// constructor form, so by canonicity this family covers the whole cut class):
lic_leaf : Eq Nat (k_cut (inj0 "DLeaf")) (k_fast (inj0 "DLeaf")) := refl
lic_stem : {c : Tree} -> Eq Nat (k_cut (inj1 "DStem" c)) (k_fast (inj1 "DStem" c)) := {c} -> refl
lic_fork : {l : Tree} -> {r : Tree} -> Eq Nat (k_cut (inj2 "DFork" l r)) (k_fast (inj2 "DFork" l r)) := {l, r} -> refl

// the neutral face delegates verbatim: certificates complete under the rebind
test param_apply (Pi ShapeD ({_} -> Nat)) k_fast = Ok true
// ...and stay honest:
test param_apply (Pi ShapeD ({_} -> Nat)) ({s} -> case_value ShapeD ({_} -> Nat) { DLeaf := 1; DStem := {c} -> false; DFork := {l, r} -> 3 } s) = Ok false
// while the raw cut still fails closed on a hyp — the boundary the license
// does NOT cover, and the reason match cannot BE case_value (no motive in the term):
test param_apply (Pi ShapeD ({_} -> Nat)) k_cut = Err

// non-cut-class (shape-encoded Nat, iso != iso_id): falls through to the spec
// on both faces — same trees as the spec face, fast path never fires:
test case_value Nat ({_} -> Nat) { zero := 0; succ := {k} -> k } 7 = 6
test param_apply (Pi Nat ({_} -> Nat)) ({n} -> case_value Nat ({_} -> Nat) { zero := 0; succ := {k} -> k } n) = Ok true

// a junk tag on the cut-class path is INERT (spine_go is argspec-guided: an
// unknown tag projects a non-fork spec and answers the unapplied junk, no
// divergence) — it does not accidentally hit a real arm:
test tree_eq (k_fast (inj0 "Bogus")) 1 = false

// the license has TEETH on the concrete face (negative control): a candidate
// that misdispatches every target to the L0 arm fails CaseRelation — its
// at_cut1 obligation would need refl to relate the L0 arm to (L1-arm c):
let misdispatch := {T, motive, cases, target} -> case_value T motive cases (inj0 "L0")
let all_refl := { at_nat := {P} -> {z} -> {s} -> {n} -> refl; at_cut0 := {z} -> {o} -> {w} -> refl; at_cut1 := {z} -> {o} -> {w} -> {c} -> refl; at_cut2 := {z} -> {o} -> {w} -> {l} -> {r} -> refl }
test tree_eq (param_apply (CaseRelation.rel case_value misdispatch) all_refl) (Ok true) = false
// ...and the honest rebind inhabits it (the load-time check, replayed in-suite):
test param_apply (CaseRelation.rel case_value case_value) all_refl = Ok true
