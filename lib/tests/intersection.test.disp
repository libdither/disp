// Intersection — intersection-style quantifier. `Intersection A P` is
// inhabited by values v such that `(P a) v = TT` for every closed
// `a : A`. Unlike Pi, the body applies `P hyp` to the SAME v (not to
// v applied to hyp): Intersection is a predicate over a single
// carrier, not a function type. (NOT the FOL ∀ of standard DTT —
// that role is played by Pi here.)
//
// The recognizer mints a hypothesis of A via bind_hyp, applies P to it
// (producing a type), and then checks v against that type. bind_hyp's
// escape check walls off any leak of the hypothesis through non-neutral
// paths in the result.
//
// Per TYPE_THEORY.typ §5.8.

open use "../prelude.disp"
open use "../kernel/prelude.disp"

// ================================================================
// Identity sanity: Intersection is a public guarded predicate_frame type.
// ================================================================
test hasguard (Intersection Nat ({_} -> Bool)) = TT
test tree_eq (pair_fst (type_meta (Intersection Nat ({_} -> Bool)))) kernel_predicate_frame_sig = TT
test is_intersection (Intersection Nat ({_} -> Bool)) = TT
test is_intersection Nat = FF

// ================================================================
// Reflection helpers
// ================================================================
test intersection_dom (Intersection Nat ({_} -> Bool)) = Nat
test intersection_pred_fn (Intersection Nat ({_} -> Bool)) 0 = Bool

// ================================================================
// Intersection A ({_} -> Bool): every Bool inhabits this.
// ================================================================
// The predicate P doesn't depend on the hypothesis — it returns Bool
// for every a:A. So `(P hyp) v = Bool v`, which is TT iff v is TT/FF.

test Intersection Nat ({_} -> Bool) TT = TT
test Intersection Nat ({_} -> Bool) FF = TT

// A non-Bool value is rejected — `Bool 5 = FF`.
test Intersection Nat ({_} -> Bool) 5 = FF

// Same shape with Bool as the carrier (the carrier is irrelevant when P
// doesn't depend on its argument):
test Intersection Bool ({_} -> Bool) TT = TT
test Intersection Bool ({_} -> Bool) FF = TT
test Intersection Bool ({_} -> Bool) 0 = FF

// ================================================================
// Intersection Nat ({_} -> Nat) — Nat-only values pass for every a:Nat.
// ================================================================
test Intersection Nat ({_} -> Nat) 0 = TT
test Intersection Nat ({_} -> Nat) 3 = TT
test Intersection Nat ({_} -> Nat) TT = FF

// ================================================================
// Negative: a value that inhabits P-at-one-A but not for every a.
// ================================================================
// P b = select Nat Bool b. Then `Intersection Bool P v` requires v to
// inhabit BOTH Nat (P TT) and Bool (P FF). No closed value satisfies
// both:
// - 5 is a Nat but not a Bool, so Intersection rejects.
// - TT is a Bool but not a Nat, so Intersection rejects.

let dep_P = {b} -> select Nat Bool b
test Intersection Bool dep_P 5 = FF
test Intersection Bool dep_P TT = FF
test Intersection Bool dep_P FF = FF

// ================================================================
// Public boundary rejects hypothesis input.
// ================================================================
let intersection_hyp = Hyp (Intersection Nat ({_} -> Bool)) 0
test Intersection Nat ({_} -> Bool) intersection_hyp = FF
