// In-language bracket abstraction vs the HOST elaborator, bit for bit.
// Each test's LHS runs lib/elab/bracket.disp on an encoded Cir term; the RHS
// is the host compiling the SAME term from surface syntax. tree_eq (the test
// harness) is the equivalence check — every line is a host/spec bit-identity.

open use "../prelude.disp"
open use "../kernel/prelude.disp"
open use "../elab/bracket.disp"

// identity / projections
test bracket_compile (cir_lam "x" (cir_var "x")) = ({x} -> x)
test bracket_compile (cir_lam "x" (cir_lam "y" (cir_var "x"))) = ({x, y} -> x)
test bracket_compile (cir_lam "x" (cir_lam "y" (cir_var "y"))) = ({x, y} -> y)

// self-application (S I I) and argument duplication
test bracket_compile (cir_lam "x" (cir_app (cir_var "x") (cir_var "x"))) = ({x} -> x x)
test bracket_compile (cir_lam "f" (cir_lam "x" (cir_app (cir_app (cir_var "f") (cir_var "x")) (cir_var "x")))) = ({f, x} -> f x x)

// flip and composition (the S-rule with real binder shuffling)
test bracket_compile (cir_lam "x" (cir_lam "y" (cir_app (cir_var "y") (cir_var "x")))) = ({x, y} -> y x)
test bracket_compile (cir_lam "f" (cir_lam "g" (cir_lam "x" (cir_app (cir_var "f") (cir_app (cir_var "g") (cir_var "x")))))) = ({f, g, x} -> f (g x))

// the optimizations, each on its own:
test bracket_compile (cir_lam "x" (cir_app (cir_lit succ) (cir_var "x"))) = ({x} -> succ x) // η: → succ itself
test bracket_compile (cir_lam "x" (cir_lit zero)) = ({x} -> zero) // K-rule
test bracket_compile (cir_lam "x" (cir_app (cir_lit succ) (cir_lit zero))) = ({x} -> succ zero) // K-composition
test bracket_compile (cir_lam "x" (cir_lam "y" (cir_app (cir_var "x") (cir_var "y")))) = ({x, y} -> x y) // η under a binder

// shadowing
test bracket_compile (cir_lam "x" (cir_lam "x" (cir_var "x"))) = ({x} -> {x} -> x)

// leaf literals and applied redexes (cir_to_tree's general-application arm
// is the substrate itself, so a closed redex reduces like the host's applyTree)
let K_comb = t t
test bracket_compile (cir_lit t) = t
test bracket_compile (cir_app (cir_lam "x" (cir_var "x")) (cir_lit zero)) = (({x} -> x) zero)
test bracket_compile (cir_app (cir_lam "x" (cir_app (cir_var "x") (cir_var "x"))) (cir_lit K_comb)) = (({x} -> x x) (t t))

// a bigger composite: the B' combinator shape {a, b, c, d} -> a (b c d)
test bracket_compile (cir_lam "a" (cir_lam "b" (cir_lam "c" (cir_lam "d"
  (cir_app (cir_var "a") (cir_app (cir_app (cir_var "b") (cir_var "c")) (cir_var "d"))))))) = ({a, b, c, d} -> a (b c d))
