// Type universe, predicate-side H-rule, polymorphic Pi, inductive recursors,
// and the first-order library types — all on the new two-Σ-op core.

open use "../prelude.disp"
open use "../kernel/prelude.disp"

// ---- Type universe: which things are types ----
test typecheck Type Bool = Ok TT
test typecheck Type Nat = Ok TT
test typecheck Type Type = Ok TT                 // Type : Type
test typecheck Type (Pi Nat ({_} -> Bool)) = Ok TT
test typecheck Type Unit = Ok TT
test typecheck Type (Eq Nat zero zero) = Ok TT
test typecheck Type zero = Ok FF                 // not a type
test typecheck Type TT = Ok FF

// ---- predicate-side H-rule (a Type-hyp used as a predicate) ----
let A_hyp = mint_hyp Type 0
let B_hyp = mint_hyp Type 1
let x_of_A = mint_hyp A_hyp t
test param_apply A_hyp x_of_A = Ok TT            // x:A_hyp inhabits the predicate A_hyp
test param_apply B_hyp x_of_A = Ok FF            // distinct Type-hyp
test param_apply A_hyp zero = Ok FF              // closed value: not a neutral

// ---- polymorphic Pi: the polymorphic identity inhabits Pi Type (A -> A -> A) ----
let polyid = checked Type ({A} -> checked A ({x} -> x))
test param_apply (Pi Type ({A} -> Pi A ({_} -> A))) polyid = Ok TT
// a non-identity polymorphic body does NOT inhabit it (can't produce an A from nothing):
let polywrong = checked Type ({A} -> checked A ({x} -> zero))
test param_apply (Pi Type ({A} -> Pi A ({_} -> A))) polywrong = Ok FF

// ---- inductive recursors via elim ----
let double = nat_rec ({_} -> Nat) zero ({n, rec} -> succ (succ rec))
test double zero = zero
test double (succ zero) = succ (succ zero)
test double (succ (succ zero)) = succ (succ (succ (succ zero)))

let neg = bool_rec ({_} -> Bool) FF TT          // not: TT->FF, FF->TT
test neg TT = FF
test neg FF = TT

// recursor on a neutral target -> stuck elimination stored at motive(self)
let hN = mint_hyp Nat 0
test is_neutral (nat_rec ({_} -> Bool) TT ({n, rec} -> FF) hN) = TT

// ---- first-order types ----
test typecheck Unit unit_val = Ok TT
test typecheck Unit zero = Ok FF
test param_apply False zero = Ok FF              // False is empty
test typecheck String unit_val = Ok TT          // String is permissive
test typecheck (Eq Nat zero zero) refl = Ok TT
test param_apply (Eq Nat zero (succ zero)) refl = Ok FF
test typecheck (Sigma Nat ({_} -> Bool)) (pair zero TT) = Ok TT
test param_apply (Sigma Nat ({_} -> Bool)) (pair zero zero) = Ok FF
test typecheck (Refinement Nat ({n} -> tree_eq n zero)) zero = Ok TT
test param_apply (Refinement Nat ({n} -> tree_eq n zero)) (succ zero) = Ok FF
test typecheck Ord zero_ord = Ok TT
test typecheck Ord (omega_plus zero_ord zero_ord) = Ok TT
test param_apply Ord TT = Ok FF

// ---- Coproduct / Record / the cut (§2.6), using [..] array-literal sugar ----
let tag_a = t t
let tag_b = t (t t)

// array literal desugars to the cons-chain (cons = `t a b`, nil = leaf)
test [zero, succ zero] = cons zero (cons (succ zero) nil)
test [] = nil

// Coproduct [(a, Nat), (b, Bool)]
let MySum = Coproduct [pair tag_a Nat, pair tag_b Bool]
test param_apply MySum (inj tag_a zero) = Ok TT
test param_apply MySum (inj tag_b TT) = Ok TT
test param_apply MySum (inj tag_a TT) = Ok FF            // a expects Nat, got Bool
test param_apply MySum (inj (t t t) zero) = Ok FF        // unknown tag

// n-ary `match` desugars to the cut: dispatch on the tag, feed the payload to
// the matching handler (constructor patterns resolve to the tag values).
let handle = {c} -> match c { tag_a n => succ n; tag_b x => x }
test handle (inj tag_a zero) = succ zero                 // a-handler runs on zero
test handle (inj tag_b TT) = TT                          // b-handler runs on TT
// the underlying library cut (what `match` expands to):
test match_co [tag_a, tag_b] [{n} -> succ n, {x} -> x] (inj tag_a zero) = succ zero

// Record [(a, Nat), (b, Bool)] and projection via the cut
let MyRec = Record [pair tag_a Nat, pair tag_b Bool]
let r = record_val [tag_a, tag_b] [list_const zero, list_const TT]
test typecheck MyRec r = Ok TT
test param_apply MyRec (record_val [tag_a, tag_b] [list_const TT, list_const TT]) = Ok FF
test field r tag_a = zero                                // r.a
test field r tag_b = TT                                  // r.b

// ---- neutral projection through respond (§12.1) ----
// A Sigma-hyp applied to a projection selector yields a stuck component.
let hAB = mint_hyp (Sigma Nat ({_} -> Bool)) 0
test neutral_type (ok_value (param_apply hAB walker_pair_fst)) = Nat     // fst : A = Nat
test neutral_type (ok_value (param_apply hAB walker_pair_snd)) = Bool    // snd : B fst = Bool
// dependency is preserved: snd of (n : Nat, _ : Eq Nat n n) lands at Eq Nat fst fst
let hDep = mint_hyp (Sigma Nat ({n} -> Eq Nat n n)) 0
let fstp = ok_value (param_apply hDep walker_pair_fst)
test neutral_type (ok_value (param_apply hDep walker_pair_snd)) = Eq Nat fstp fstp

// A Record-hyp projects each field at its declared type, read by name.
let hR = mint_hyp MyRec 0
test neutral_type (ok_value (param_apply hR (acc tag_a))) = Nat          // r.a : Nat
test neutral_type (ok_value (param_apply hR (acc tag_b))) = Bool         // r.b : Bool
