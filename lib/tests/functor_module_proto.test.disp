// Functor modules are telescopes — the design probe (ZERO kernel changes).
//
// A module with dependencies is a Pi into a Record; both are telescope
// instances already, so the functor type needs no new former — the surface
// arrow-into-record-type spelling compiles to it directly. Pinned here:
//   1. RECOGNITION: `param_apply` accepts a `{deps} -> { exports }` lambda at
//      the functor type, checking the exports ABSTRACTLY (each dep is a minted
//      hyp; membership lands by the H-rule). The module checks ONCE, before
//      any linking; well-typed fills then need no recheck (the Pi story).
//   2. REJECTION: wrong export type, missing export, non-parametric body.
//   3. The FLAT spelling: requires ARE mint cells, and the composition with
//      the exports happens through a delegating apply cell ([mint ; apply
//      out:ExportsT] accepts the functor — it is Pi-into-Record by hand).
//      A mint→proj chain WITHOUT the delegation is pinned as Ok FF: `source`
//      is stable per walk by design, so instantiate-then-project across cells
//      would need one new source-rebinding op. Nothing needs it today.
//   4. INSTANTIATION is plain application, and an instantiated export is
//      tree-identical to the directly-written definition (hash-cons sharing
//      and the module caches survive linking).
//   5. The ctx-record call `f { dep := … }` is the existing named-argument
//      surface; nothing new to build.
//   6. ELIMINATION: a hyp OF functor type applies and projects abstractly
//      (code can consume a module it doesn't have yet).
// Design thread: COMPILATION.typ § Declarations as requests (module values
// containing computed requests); the module-dependency discussion 2026-07-06.

open use "../prelude.disp"
open use "../kernel/prelude.disp"
open use "../std/nat/arith.disp"   // add

// ── the functor type, in plain surface syntax ──
BinOp : Type := Nat -> Nat -> Nat
ExportsT : Type := { double : Nat -> Nat, quad : Nat -> Nat }
SimpleModT : Type := BinOp -> ExportsT

// ── 1. a functor value checks abstractly: `add` is a minted hyp during the
// walk; `add x x` reduces to a neutral of type Nat, so the H-rule lands it ──
simple_mod : SimpleModT := {add} -> {
  double := {x} -> add x x
  quad := {x} -> add (add x x) (add x x)
}
test param_apply SimpleModT simple_mod = Ok TT

// ── 2. rejection ──
let bad_arity := {add} -> { double := {x} -> add x; quad := {x} -> x }   // add x : Nat -> Nat, not Nat
test param_apply SimpleModT bad_arity = Ok FF
let bad_missing := {add} -> { double := {x} -> add x x }                 // no quad
test param_apply SimpleModT bad_missing = Ok FF

// type-parameterized: the export types USE the minted dep
IdModT : Type := {A : Type} -> { id : A -> A, konst : A -> A -> A }
id_mod : IdModT := {A} -> { id := {x} -> x; konst := {x} -> {_} -> x }
test param_apply IdModT id_mod = Ok TT
let bad_leaf := {A} -> { id := {_} -> t; konst := {x} -> {_} -> x }      // t is not abstractly A
test param_apply IdModT bad_leaf = Ok FF

// ── 3. the FLAT spelling: requires ARE literal mint cells — but composition
// happens through the apply cell's TYPE, not by threading. A hand-built
// [mint dep ; apply out:ExportsT] telescope accepts the functor: the apply
// cell delegates a fresh sub-walk on the instantiated record, which is
// exactly what the Pi-into-Record surface compiles to. ──
FlatPiT := Telescope (
  t (mint_cell BinOp) ({h} ->
  t (apply_cell ExportsT) ({_} -> t)))
test param_apply FlatPiT simple_mod = Ok TT
test param_apply FlatPiT bad_arity = Ok FF

// The mint→proj spelling WITHOUT the delegating apply cell does NOT compose,
// pinned deliberately: `tele_walk` threads a cell's observation to the NEXT
// cell (prior), but `source` is stable per walk BY DESIGN (positional
// accessors are root-relative), so the proj cells still see the un-applied
// lambda and reject. Making this spelling work would take one new
// source-rebinding cell op; the nested spelling above needs nothing.
FlatMintProjT := Telescope (
  t (mint_cell BinOp) ({add} ->
  t (apply_cell Tree) ({_inst} ->
  t (proj_cell "double" (Arrow Nat Nat)) ({_} ->
  t (proj_cell "quad" (Arrow Nat Nat)) ({_} -> t)))))
test param_apply FlatMintProjT simple_mod = Ok FF

// ── 4. instantiation = application; exports reconverge to direct trees ──
inst := simple_mod add
test inst.double 3 = 6
test inst.quad 2 = 8
let direct_double := {x} -> add x x
test tree_eq inst.double direct_double = TT

// ── 5. the ctx-record call is the existing named-argument surface ──
test tree_eq (simple_mod { add := add }).double direct_double = TT

// ── 6. elimination: consume a module you don't have yet. A hyp OF functor
// type applies (extends at ExportsT) and projects (extends at the field
// type). Membership of a NEUTRAL goes through param_apply — `typecheck`
// lifts via param_lift, which gates on closedness, and a neutral is open
// (the same rule as Spine payloads). ──
let hM := make_hyp SimpleModT 40
let habs := (hM add).double        // neutral : Nat -> Nat
test param_apply (Arrow Nat Nat) habs = Ok TT
test param_apply Nat (habs 3) = Ok TT

// The surface type and the hand-built two-cell telescope are behaviorally one
// former (both accept simple_mod above) but NOT tree-identical: Pi's own body
// keeps `apply_cell (B h)` open under the mint binder, while the hand-built
// spelling pre-reduces the closed cell. Conversion is tree_eq by design, so a
// future module-typ builder must construct through Pi/the surface route (not
// hand-assembled cells) to share hash-cons identity with written annotations.
test tree_eq FlatPiT SimpleModT = FF
