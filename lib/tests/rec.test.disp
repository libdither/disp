open use "../prelude.disp"

// ================================================================
// rec combinator + let annotation tests
// ================================================================

// --- Basic 2-field rec ---
let comp_a = {ks, x} -> x
let comp_b = {ks, x} -> x x

let k2 : {a, b} = rec {a := comp_a; b := comp_b}

// Projection access
test k2.a t = t
test k2.a (t t) = t t
test k2.b t = t t

// --- Cross-component calls via annotated ks ---
let comp_id = {ks : {id, double}, x} -> x
let comp_dbl = {ks : {id, double}, x} -> ks.id (ks.id x)

let k2b : {id, double} = rec {id := comp_id; double := comp_dbl}
test k2b.id t = t
test k2b.double t = t

// --- recq lazy self-proxy ---
let qcomp_id = {ks, raw, query, x} -> x
let qcomp_dbl = {ks : {id, double}, raw, query, x} -> ks.id (ks.id x)

let k2q : {id, double} = recq {id := qcomp_id; double := qcomp_dbl}
test k2q.id t = t
test k2q.double t = t

// --- 5-field rec with cross-references ---
let f1 = {ks : {a,b,c,d,e}, x} -> x
let f2 = {ks : {a,b,c,d,e}, x} -> ks.a x
let f3 = {ks : {a,b,c,d,e}, x} -> t (ks.a x)
let f4 = {ks : {a,b,c,d,e}, x} -> ks.c x
let f5 = {ks : {a,b,c,d,e}} -> t

let k5 : {a, b, c, d, e} = rec {
  a := f1;
  b := f2;
  c := f3;
  d := f4;
  e := f5
}

test k5.a t = t
test k5.b t = t
test k5.c t = t t
test k5.d t = t t
test k5.e = t

// --- 10-field rec (kernel scale) ---
let g1 = {ks : {a,b,c,d,e,f,g,h,i,j}, x} -> x
let g2 = {ks : {a,b,c,d,e,f,g,h,i,j}, x} -> ks.a x
let g3 = {ks : {a,b,c,d,e,f,g,h,i,j}} -> t
let g4 = {ks : {a,b,c,d,e,f,g,h,i,j}} -> t
let g5 = {ks : {a,b,c,d,e,f,g,h,i,j}} -> t
let g6 = {ks : {a,b,c,d,e,f,g,h,i,j}} -> t
let g7 = {ks : {a,b,c,d,e,f,g,h,i,j}} -> t
let g8 = {ks : {a,b,c,d,e,f,g,h,i,j}} -> t
let g9 = {ks : {a,b,c,d,e,f,g,h,i,j}} -> t
let g10 = {ks : {a,b,c,d,e,f,g,h,i,j}} -> t

let k10 : {a,b,c,d,e,f,g,h,i,j} = rec {
  a := g1;
  b := g2;
  c := g3;
  d := g4;
  e := g5;
  f := g6;
  g := g7;
  h := g8;
  i := g9;
  j := g10
}

test k10.a t = t
test k10.b t = t
test k10.c = t

// --- Annotation on non-rec expressions also works ---
let plain : {x, y} = {x := t; y := t t}
test plain.x = t
test plain.y = t t
