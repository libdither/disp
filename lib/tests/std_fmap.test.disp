// fmap real & general in the stdlib (CELL_OPTICS): Option/Result/Either are now `Coproduct_p` with
// `Param` markers, so the kernel's GENERIC `fmap`/`bimap` work on them — no per-type map code. This
// test pins that, and that the generic subsumes the hand-written `option_map`/`result_map`.

open use "../kernel/prelude.disp"
open use "../std/nat/arith.disp"
open use "../std/nat/ops.disp"
open use "../std/option.disp"
open use "../std/result.disp"
open use "../std/either.disp"
open use "../std/list.disp"

// ── recognition still holds after the Coproduct_p migration ──
test typecheck (Option Nat) (some 5)   = Ok true
test typecheck (Option Nat) none       = Ok true
test typecheck (Option Nat) (some false) = Ok false       // payload not a Nat
test typecheck (Result Nat Bool) (ok true)  = Ok true    // ok holds A=Bool
test typecheck (Result Nat Bool) (err 3)  = Ok true    // err holds E=Nat
test typecheck (Either Nat Bool) (left 3) = Ok true
test typecheck (Either Nat Bool) (right true) = Ok true

// ── Option is a FUNCTOR: fmap maps `some`, leaves `none` ──
test fmap (Option Nat) succ (some 5) = some 6
test fmap (Option Nat) succ none     = none
// the generic fmap subsumes the hand-written option_map
test fmap (Option Nat) succ (some 5) = option_map succ (some 5)

// ── Either is a BIFUNCTOR: bimap maps left with f, right with g ──
test bimap (Either Nat Nat) succ double (left 5)  = left 6
test bimap (Either Nat Nat) succ double (right 5) = right 10

// ── Result is a BIFUNCTOR over [E, A]: bimap g f maps err (E) with g, ok (A) with f ──
test bimap (Result Nat Nat) succ double (ok 5)  = ok 10      // ok = Param 1 (A) -> double
test bimap (Result Nat Nat) succ double (err 5) = err 6      // err = Param 0 (E) -> succ
// result_map (maps only ok) = bimap with Id on err
test bimap (Result Nat Nat) ({x} -> x) double (ok 5)  = result_map double (ok 5)
test bimap (Result Nat Nat) ({x} -> x) double (err 5) = result_map double (err 5)

// ── fmap preserves recognition ──
test typecheck (Option Nat) (fmap (Option Nat) succ (some 5)) = Ok true
test typecheck (Either Nat Bool) (bimap (Either Nat Bool) succ ({b} -> b) (left 5)) = Ok true

// ── the SHAPE-ENCODED win: generic fmap/fold_value now work on List (via the iso in `functor`),
// not just inj-tagged types. (Nat/Ord are shape-encoded too; they carry no Param, so fmap = id.) ──
test fmap (List Nat) succ nil                              = nil
test fmap (List Nat) succ (cons 1 (cons 2 (cons 3 nil)))  = cons 2 (cons 3 (cons 4 nil))   // maps each element through the iso
test fmap (List Nat) succ (cons 1 (cons 2 nil))           = list_map succ (cons 1 (cons 2 nil)) // generic == bespoke list_map
test typecheck (List Nat) (fmap (List Nat) succ (cons 1 nil)) = Ok true
// fold_value auto-reads the type's view from `functor` -> works on shape-encoded List with NO explicit view
test fold_value (List Nat) { nil := zero; cons := add } (cons 1 (cons 2 (cons 3 nil))) = 6  // sum
test fold_value (List Nat) { nil := zero; cons := ({_h} -> {acc} -> succ acc) } (cons 7 (cons 8 nil)) = 2 // length
