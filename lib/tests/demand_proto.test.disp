// demand_proto — pins for std/demand.disp (the DEMAND face of telescopes:
// DAG-subset extraction answered as "what you must satisfy first, then what
// you get"; design notes in the module header) plus the two promotions:
//
//   (2) per-export given demand on a REAL module's functor face (the
//       slice-3 partial-fills question, answered in-language): the fixture
//       demand_mod.disp has givens A, B; its export just_a demands only
//       position 0, both demands both — and the per-export Pi is a real,
//       membership-checked type SMALLER than the module's full functor typ.
//
//   (3) demand composed with synthesis: enumerate the demanded context =
//       generate inhabitants of DEPENDENT records by propose-and-check
//       (the synthesis handler's mint clause fused: enumerate, filter by
//       membership, thread survivors multishot through the tails). The
//       solver pin: a dependent constraint prunes the search to the unique
//       answer. The proof-candidate table's else arm is principled here:
//       proofs erase to one value in this system, so refl is THE candidate.
// Baseline (rust-eager-native, 2026-07-08): ~22s wall, 26 pins.
open use "../kernel/prelude.disp"
open use "../std/nat/arith.disp"
open use "../std/list.disp"
open use "../std/demand.disp"

// ── the record face: d depends on a and c, skipping b ──
let R4 := { a : Nat, b : Bool, c : Nat, d : Eq Nat (add a c) (add a c) }
test field_deps R4 "d" = cons "a" (cons "c" nil)
test field_deps R4 "b" = nil
test field_deps R4 "c" = nil
test field_pi R4 "b" = Bool
test field_pi R4 "a" = Nat
test param_apply (field_pi R4 "d") ({x} -> {y} -> refl) = Ok true
test param_apply (field_pi R4 "d") ({x} -> {y} -> 5) = Ok false
test param_apply (Eq Nat (add 1 2) (add 1 2)) refl = Ok true

// ── sub_record and the lens ──
let vR4 := { a := 1; b := true; c := 2; d := refl }
test param_apply R4 vR4 = Ok true
let subT := sub_record R4 (cons "d" nil)
test param_apply subT (project_sub vR4 (closure_of R4 (cons "d" nil))) = Ok true
test param_apply subT vR4 = Ok true
test param_apply subT { a := 1; c := 2; d := refl } = Ok true
test param_apply subT { a := 1; c := 2; d := 5 } = Ok false
test param_apply subT { a := 1; d := refl } = Ok false

// ── fields_of: the flat table as a record (independent prefixes) ──
let FT := { u : Nat, v : Bool }
test (fields_of FT).u = Nat
test (fields_of FT).v = Bool

// ── (2) per-export demand on the REAL functor face ──
let fx := use "demand_mod.disp"
test mod_export_deps (fx.typ) "just_a" = cons 0 nil
test mod_export_deps (fx.typ) "both" = cons 0 (cons 1 nil)
test param_apply (mod_export_pi (fx.typ) "just_a") ({D} -> {x} -> x) = Ok true
test param_apply (mod_export_pi (fx.typ) "just_a") ({D} -> {x} -> 5) = Ok false
// mod_extract: PARTIAL USE in-language — fill only what the export demands
// (position 0 for just_a; B is junk-padded, certified unused by the deps):
let pj := mod_extract fx "just_a" (cons Nat nil)
test pj 5 = 5
test param_apply (Arrow Nat Nat) pj = Ok true
// THE AGREEMENT PIN: the partial extraction is TREE-IDENTICAL to the same
// export of a FULL instantiation (the readback rebuilds an export from
// exactly the givens it mentions — junk never reaches it):
let inst := use "demand_mod.disp" { A := Nat, B := Bool }
test tree_eq pj (inst.record.just_a) = true
// an export demanding both givens extracts with both fills:
test (mod_extract fx "both" (cons Nat (cons Bool nil))) 3 true = true

// ── (3) demand times synthesis: propose-and-check over dependent records ──
let enum_of := {ty} -> (if (tree_eq ty Bool) then (cons true (cons false nil)) else (if (tree_eq ty Nat) then (cons 0 (cons 1 (cons 2 nil))) else (cons refl nil)))
let member := {ty, c} -> tree_eq (param_apply ty c) (Ok true)
let filter_mem := {ty, l} -> (fix ({self, l2} -> if (is_fork l2) then (if (member ty (pair_fst l2)) then (cons (pair_fst l2) (self (pair_snd l2))) else (self (pair_snd l2))) else nil)) l
// (concat_map comes from std/list.disp)
let synth_go := fix ({self, cells, names, vals} ->
  if (is_fork cells) then {
    let m := type_meta (pair_fst cells)
    concat_map ({c} -> self ((pair_snd cells) c) (cons (m.name) names) (cons (list_const c) vals)) (filter_mem (m.ty) (enum_of (m.ty)))
  } else (cons (make_record (list_rev names nil) (list_rev vals nil)) nil))
let synth_record := {T} -> synth_go ((type_meta T).recognizer_params) nil nil
// (list_length comes from std/list.disp)
// an independent record enumerates the full product:
test list_length (synth_record { x : Bool, y : Bool }) = 4
// THE SOLVER PIN: the dependent constraint prunes the search to the answer —
// synthesis solved x = 1 by proposing and checking through the telescope:
let SolveT := { x : Nat, y : Eq Nat x 1 }
test list_length (synth_record SolveT) = 1
// the synthesized record IS the literal, tree-identically (make_record with
// plain wrapped values is exactly what a record literal compiles to):
test tree_eq (synth_record SolveT) (cons { x := 1; y := refl } nil) = true
let solved := pair_fst (synth_record SolveT)
test solved.x = 1
test tree_eq (solved.y) refl = true
test param_apply SolveT solved = Ok true
