// PROTOTYPE (R6, 2026-06-29): MERGE GoodRespond's obligations into StrictType's OWN telescope as a
// DEPENDENT TAIL, walking against source=v (the candidate type), deriving R = resp_of v inside the probe.
// NO standalone `GoodRespond T`, NO sub-`param_apply`, NO nested walker. The variable-length GoodRespond
// chain is spliced into StrictType's continuation, which receives `v` (both qid cells thread `source`).
//
// RESULT: the merge DISSOLVES the top-level nested-walker abort. The CRUX `param_apply MergedST Nat`
// (recursive) = Ok TT here, where the NESTED design (a respond_good cell calling param_apply
// (GoodRespond source) ...) gives Err. Faithful (not folded — the BadMyNat discrimination test proves
// the walk runs). This is the basic `T : Type` self-check, recursive INCLUDED.
//
// RESIDUAL — RESOLVED 2026-07-01 (see behavioral_type.test.disp): do_check now routes membership
// through param_apply, whose SS7A token flattens each nesting level to a fresh native walk, so the
// blowup below is GONE and this merge IS the landed universe (Type := BehavioralType, universe.disp).
// Historical record of the diagnosis:
// (was) when MergedST is itself nested ONE level under ANOTHER walker
// (`param_apply (recognizer-running-param_apply-MergedST-v) v`, the module-auto-verify scenario), it
// fails for BOTH Bool and Nat — and the cause is a genuine MEMORY/WORK BLOWUP, NOT a backend bug
// (confirmed 2026-06-29 by instrumenting rust-eager: the "unreachable" is an OUT-OF-MEMORY abort at
// mem=3400MiB — wasm grow fails → handle_alloc_error → raw `unreachable`, bypassing the panic hook).
// All THREE backends exhaust memory the same way: rust-eager OOM (3.4GiB), eager-TS OOM (8GiB heap),
// naive "Invalid array length" (~4-billion-node blowup). So nesting the heavy GoodRespond check
// re-policed by an enclosing walker is intractable on every reducer (the outer walker re-materializes
// the whole deep computation without sharing). The top-level check (above) is cheap (~1.4M steps) and
// cross-validated real (tree_eq vs match-destructure vs payload-emit all agree Ok TT). Open — needs a
// cheaper check or a definition-time-only (top-level) self-check, NOT a backend fix.
open use "../kernel/prelude.disp"
open use "../std/nat/arith.disp"

let SThread := inj1 "SThread"
let SReject := inj0 "SReject"
let SDone   := inj1 "SDone"
let do_check := {mode, getr, ty} -> if mode then (match (getr t) { Ok part => (match (ty part) { Ok b => (if b then (SThread part) else SReject); Err _ => SReject }); Err _ => SReject }) else (SDone (Extend ty))
let resp_of := {T} -> (type_meta T).respond (type_meta T).recognizer_params
let is_gated := {v} -> is_fork ((type_meta v).functor)   // inductives store a real iso; negatives store trivial_functor = t
let probe_op := {meta, mode, source, prior, frame, rs} -> do_check mode ({_} -> Ok (meta.apply source prior)) (Singleton (meta.outcome))
let probe_cell := {ap, out} -> wait probe_op { apply := ap; outcome := out }

// MERGED StrictType: [ qid recognizer ; qid_meta MetaShape ; IF gated: (mint M ; mint s ; mint cases ; probe coh) ].
// ONE telescope, ONE `at` walk. (coh-only here — the over-permissive `junk` dim would append more cells.)
let MergedST := tele_with (
  t (qid_cell (Arrow Tree CheckerResult)) ({_} ->
  t (qid_meta_cell MetaShape) ({v} ->
    if (is_gated v)
      then (
        t (mint_cell (Arrow v Type)) ({M} ->
        t (mint_cell v) ({s} ->
        t (mint_cell (derive_case_telescope v M)) ({cases} ->
        t (probe_cell ({src, _} -> (resp_of src) s { motive := M; cases := cases }) (Extend (M s))) ({_} -> t)))))
      else t)))
  type_predicate_h_rule

// is_gated dispatch
test is_gated Nat  = TT
test is_gated Bool = TT
test is_gated MergedST = FF      // a negative former — not gated (else-branch)

// THE CRUX: top-level self-check, faithful (the BadMyNat test below proves the walk actually runs).
test tree_eq (param_apply MergedST Bool) (Ok TT) = TT     // non-recursive
test tree_eq (param_apply MergedST Nat)  (Ok TT) = TT     // RECURSIVE — the nested design's wall, dissolved
// discrimination (coh dim): an over-restrictive (inert) respond is caught -> Ok FF (so it's not folded-constant)
let BadMyNat := Coproduct_respond inert_respond [pair "z" [], pair "s" [Rec]]
test tree_eq (param_apply MergedST BadMyNat) (Ok FF) = TT
// non-gated former passes the else-branch: self-types
test tree_eq (param_apply MergedST MergedST) (Ok TT) = TT
