// Q1 micro-experiment — WARM-UP. Can a real rewrite be LICENSED past `tree_eq` by a genuine,
// machine-checked witness? (OPTIMIZER.typ §6; FOUNDATIONS.md Q1.)
//
// The substrate's native equality is `tree_eq` — the FLOOR. By Wand-collapse it licenses NOTHING:
// every non-trivial rewrite is between two *distinct* trees, so it needs a COARSER, PROVED equality.
// This file establishes that proof for one law and shows it is the real thing, not a vacuous pass.
//
// Target: `add n zero ~ n` (right-identity of addition).
//  - `add` (std/nat.disp) recurses on its FIRST arg (`add zero m = m`), so `add n zero` is STUCK
//    on a neutral `n` — the law is genuinely INDUCTIVE, not a mere reduction.
//  - It is COST-REDUCING: the rhs `n` skips the entire addition, so `add e zero ⤳ e` is exactly the
//    kind of rewrite the optimizer wants (it deletes work).
//  - The witness goes through `nat_rec`, which is GATE-CHECKED (kernel.test: lying recursors are
//    rejected) — so "it type-checks" means "the induction is correct", NOT vacuous totality.

open use "../kernel/prelude.disp"
open use "../std/nat.disp"

// The law as a dependent type (a ∀ over Nat); its INHABITANT is the licensing witness.
let the_law := Pi Nat ({n} -> Eq Nat (add n zero) n)

// ── (a) PAST tree_eq: `refl` alone does NOT inhabit the law. ──
// For a neutral n, `add n zero` (a stuck nat_rec elimination) is not tree_eq to `n` (the bare hyp),
// so refl's endpoint-conversion check fails. If they WERE tree_eq, there'd be nothing to optimize.
test param_apply the_law ({n} -> refl) = Ok false

// ── (b) The GENUINE inductive witness — induction on n via the gate-checked `nat_rec`. ──
//   base  n=zero       : add zero zero ⤳ zero                      → refl : Eq Nat zero zero
//   step  n=succ pred  : add (succ pred) zero ⤳ succ (add pred zero);  ih : Eq Nat (add pred zero) pred
//                        → eq_cong succ ih : Eq Nat (succ (add pred zero)) (succ pred)
let add_n_zero := {n} -> nat_rec ({n_} -> Eq Nat (add n_ zero) n_) refl ({pred, ih} -> eq_cong Nat Nat ({k} -> succ k) (add pred zero) pred ih) n
test param_apply the_law add_n_zero = Ok true

// ── (c) NON-VACUITY: a LYING witness is REJECTED — the checker really verifies the step. ──
// This step ignores `ih` and offers `refl`, which would need `add (succ pred) zero` ≡ `succ pred`
// (false for neutral pred). The gate catches it. This is what separates a proof from `make_hyp` junk.
let bad_witness := {n} -> nat_rec ({n_} -> Eq Nat (add n_ zero) n_) refl ({pred, ih} -> refl) n
test param_apply the_law bad_witness = Ok false

// ── (d) The rewrite is BEHAVIOR-PRESERVING on concrete inputs (the differential check, in miniature). ──
test add (succ (succ (succ zero))) zero = succ (succ (succ zero))
test tree_eq (add (succ (succ zero)) zero) (succ (succ zero)) = true

// ── (e) The witness is a first-class Eq proof — composes with the Eq combinators, SYMBOLICALLY. ──
// eq_sym carries it to the flipped law `n ~ add n zero`, type-checking under a binder (no reduction).
let flipped := {n} -> eq_sym Nat (add n zero) n (add_n_zero n)
test param_apply (Pi Nat ({n} -> Eq Nat n (add n zero))) flipped = Ok true
