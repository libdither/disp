// `<...>` coproduct (sum) literal surface sugar — the DUAL of recType → Telescope.
//   < Tag1 : T1, Tag2 : T2, Tag3 >  ⟶  Coproduct [pair "Tag1" [T1], pair "Tag2" [T2], pair "Tag3" []]
// `Tag : T` is a single-arg variant `pair "Tag" [T]` (T in TYPE position, like a
// recType field type); bare `Tag` is nullary `pair "Tag" []`; empty `<>` is the
// empty sum `Coproduct []` (⊥). ORACLE: each `<…>` must be tree_eq IDENTICAL to the
// hand-written `Coproduct […]`.
open use "../kernel/prelude.disp"

// ── oracle: the desugared tree IS the hand-written former (tree_eq) ──
// nullary + recursive single-arg variant (the design doc's Peano shape; `Rec` is a kernel value)
test tree_eq (< zero, succ : Rec >) (Coproduct [pair "zero" [], pair "succ" [Rec]]) = TT
// record-payload variant ({v:Nat} desugars to a Telescope in both forms)
test tree_eq (< ok : {v : Nat} >) (Coproduct [pair "ok" [{v : Nat}]]) = TT
// empty sum
test tree_eq (<>) (Coproduct []) = TT
// multi-variant, mixed arities
test tree_eq (< a : Nat, b : Bool, c >) (Coproduct [pair "a" [Nat], pair "b" [Bool], pair "c" []]) = TT
// trailing comma is allowed (like record fields)
test tree_eq (< a : Nat, b, >) (Coproduct [pair "a" [Nat], pair "b" []]) = TT

// ── recognition: a `<…>`-typed value type-checks through the kernel ──
// the design doc's example (payloads simplified to non-record types):
let Event := < Error : Nat, Success : Bool, Done >
test param_apply Event (inj "Error" zero)   = Ok TT
test param_apply Event (inj "Success" TT)   = Ok TT
test param_apply Event (inj "Done" t)       = Ok TT   // nullary value: payload is t
test param_apply Event (inj "Error" TT)     = Ok FF   // Error expects Nat, got Bool
test param_apply Event (inj "Nope" t)       = Ok FF   // unknown tag
test typecheck Type Event                   = Ok TT   // Event is a real Type

// ── a recursive sum (Peano) recognizes exactly like the hand form ──
let PN := < zero, succ : Rec >
let pz := inj "zero" t
let ps := {n} -> inj "succ" n
test typecheck PN pz              = Ok TT
test typecheck PN (ps (ps pz))    = Ok TT
test typecheck Type PN            = Ok TT
