// Record operations and projection. Lives in std/ because it imports
// list.disp — types/record.disp can't depend on std/ (cycle through
// kernel/prelude).
//
// What's here:
//   record_names / record_type_at — list-based reflection helpers
//   in_fields / find_index / sigma_walk — projection internals
//   ValidField fields — refinement type for "name is in this field list"
//   proj — tree-native projector, with name validated by ValidField
//
// Per RECORDS_PROPOSAL.md §5.

open use "../prelude.disp"
open use "../kernel/prelude.disp"
open use "list.disp"

// ================================================================
// Reflection on a Record type
// ================================================================

// A Record type's field list lives in its meta's recognizer_params (new core).
record_fields := {T} -> meta_params (type_meta T)

record_names := {T} ->
  list_map ({nt} -> pair_fst nt) (record_fields T)

// Type at name n. Caller must ensure n is in record_fields T (the
// ValidField refinement on `proj`'s third argument enforces this at
// the call site).
record_type_at := {T, n} ->
  pair_snd (list_find ({nt} -> tree_eq (pair_fst nt) n) (record_fields T))

// ================================================================
// Projection
// ================================================================

// in_fields fields n: TT iff n names a field in `fields`. The recursion
// uses `match` (not select_lazy) per CLAUDE.md's self-recursion
// workaround — the match-arm closures wrap recursive calls so the
// closed combinator's compile-time reduction doesn't fire the recursion.
let in_fields_inner = fix ({self, fields, n} ->
  triage
    FF
    ({_} -> FF)
    ({head, tail} ->
      match (tree_eq (pair_fst head) n) {
        TT => TT
        FF => self tail n
      })
    fields)
in_fields := {fields, n} -> in_fields_inner fields n

// find_index fields n: 0-based position of name n in fields. Caller
// guarantees presence (in_fields = TT); on absence the result is the
// list's length, which then walks past unit_witness in sigma_walk.
let find_index_inner = fix ({self, fields, n} ->
  triage
    zero
    ({_} -> zero)
    ({head, tail} ->
      match (tree_eq (pair_fst head) n) {
        TT => zero
        FF => succ (self tail n)
      })
    fields)
find_index := {fields, n} -> find_index_inner fields n

// sigma_walk r i: extract the i-th value from a Sigma-chain record.
// The record's shape is t v0 (t v1 (t v2 ... unit_witness)). At index
// i, return v_i. Uses raw tree equality to test for zero (succ n is
// fork(t, n) so pair_snd extracts the predecessor).
let sigma_walk_inner = fix ({self, i, r} ->
  match (tree_eq i zero) {
    TT => pair_fst r
    FF => self (pair_snd i) (pair_snd r)
  })
sigma_walk := {r, i} -> sigma_walk_inner i r

// ValidField fields: refinement type for "n is a valid field name in
// fields". Inhabited by exactly the canonical String trees that appear
// as field names; the kernel's Refinement recognizer is what rejects
// invalid names at type-check time.
ValidField := {fields} -> Refinement String ({n} -> in_fields fields n)

// proj: the tree-native projector. Three arguments — fields, record,
// name — match the proposed typed signature
//   proj : {fields} -> Record fields -> (n : ValidField fields) -> record_type_at T n
// The parser desugaring (task #7) supplies all three; user-facing
// syntax is just `r.x`.
record_proj := {fields, r, n} -> sigma_walk r (find_index fields n)
