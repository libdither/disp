// checker_sig (kernel/cut.disp): the signature of a wait-form checker is pair_fst of a
// wait-form built from it — the checker inside the partial-application wrapping, NOT the
// raw checker (it is not identity), and constant across the metadata slot. The wrapping
// is why comparison sites go through checker_sig instead of comparing the checker
// directly: they read pair_fst off real wait-form values, and the known checker must be
// wrapped the same way to match. (Answers the 2026-07-06 read-through Q in cut.disp.)
open use "../kernel/prelude.disp"

// not identity: the sig differs from the raw checker
test tree_eq (checker_sig pair_snd) pair_snd = FF
test tree_eq (checker_sig tree_eq) tree_eq = FF

// constant across the metadata slot (the property that makes it a signature)
test tree_eq (pair_fst (wait pair_snd zero)) (pair_fst (wait pair_snd (succ zero))) = TT

// no separate storage: the sig of a live wait-form is a projection of the term itself
test tree_eq (pair_fst (wait pair_snd zero)) (checker_sig pair_snd) = TT

// the kernel instances are cached projections of the same shape
test tree_eq hyp_sig (checker_sig hyp_reduce) = TT
test tree_eq annihilate_sig (checker_sig annihilate) = TT
