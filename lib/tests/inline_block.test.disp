// Q2 regression: tests and opens inside inline { ... } blocks now flow
// through to the driver via the CompileSinks plumbing in compile.ts.
// Before the fix, `test x = y` inside a recValue/block was silently
// skipped; now it's compiled and registered as a real Test decl.

open use "../prelude.disp"
open use "../kernel/prelude.disp" // record values { := } compile to the §2.6 cut (mk_record)

// ================================================================
// Inline tests in a block-with-trailing-expression
// ================================================================
// A block `{ let x = a; test b = c; expr }` parses as a recValue with
// members; the block desugars to the trailing expr at the call site,
// but the inline test still emits a Decl into the driver.

let probe = {
  let one = succ zero
  test one = succ zero
  test succ one = succ (succ zero)
  one
}

// The block returns `one`, which we test conventionally.
test probe = succ zero

// ================================================================
// Inline tests in a recValue (exported fields)
// ================================================================

let r = {
  let n = succ (succ zero)
  test n = succ (succ zero)
  test pair_fst (t n t) = n
  x := n
  y := succ n
}

test r.x = succ (succ zero)
test r.y = succ (succ (succ zero))

// ================================================================
// Inline `open` inside a block: opened names visible to subsequent
// members, including subsequent tests.
// ================================================================

let r2 = {
  open use "../prelude.disp"
  let x = succ zero
  test pair_fst (t x t) = x
  x
}

test r2 = succ zero
