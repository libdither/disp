// tree_eq is now a normal recursive tree program in lib/prelude.disp.
// The host runtime captures its compiled tree id at boot and fast-paths
// two-arg applications to an O(1) hash-cons identity check; this file
// exercises the predicate's behavior on representative inputs.

open use raw "../prelude.disp" {}

// ================================================================
// Leaves, stems, forks
// ================================================================

test tree_eq t t = true
test tree_eq t (t t) = false
test tree_eq (t t) t = false
test tree_eq (t t) (t t) = true
test tree_eq (t t t) (t t t) = true
test tree_eq (t t t) (t t (t t)) = false
test tree_eq (t (t t) t) (t (t t) t) = true
test tree_eq (t (t t) t) (t t (t t)) = false

// ================================================================
// Mixed shapes
// ================================================================

test tree_eq t (t t t) = false
test tree_eq (t t) (t (t t)) = false
test tree_eq (t (t t)) (t (t t)) = true
test tree_eq (t (t t)) (t t t) = false

// ================================================================
// Deeper trees
// ================================================================

test tree_eq (t (t t t) (t t)) (t (t t t) (t t)) = true
test tree_eq (t (t t t) (t t)) (t (t t t) (t (t t))) = false
test tree_eq (t (t t (t t)) (t (t t) t)) (t (t t (t t)) (t (t t) t)) = true

// ================================================================
// Numeric literals (Nat trees: zero=leaf, succ=fork(t, n))
// ================================================================

test tree_eq 0 0 = true
test tree_eq 0 1 = false
test tree_eq 3 3 = true
test tree_eq 3 4 = false
test tree_eq 5 5 = true
