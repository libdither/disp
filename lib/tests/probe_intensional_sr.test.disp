// probe_intensional_sr — ACTIVE_BUGS item 5: intensional neutrality-branching.
//
// is_neutral is an O(1) root-signature read (pair_fst against hyp_sig), and
// pair_fst is a SANCTIONED reader on every value including hyps — so a body
// can OBSERVE which face it is on and diverge. Certification walks the body at
// a minted hyp, i.e. it only ever sees the neutral branch: a Pi certificate is
// a NEUTRAL-FACE statement, not a semantic forall over members. This is the
// price of polarized application (elim/case_value/every .opt fast path
// dispatches on the same bit) — banning it means unsanctioning root-sig reads
// on hyps, which the H-rule and every eliminator need. Not is_neutral-specific:
// any root-signature comparison reconstructs the bit.
//
// Defended (the ledger's defense model): the junk value fails the NEXT
// membership check (use-site re-check), and theorems cannot be faked — the
// neutral branch must REALLY inhabit the dependent codomain at the abstract
// point, where junk cannot help. The positive-side discipline is the license
// pattern: per-constructor concrete obligations (CaseRelation's at_cut family,
// std/case.disp) force the concrete branch into a checked walk — the
// difference between dispatch-to-DELEGATE (benign, refl-provable) and
// dispatch-to-DIVERGE (this probe) is exactly a pointwise relation obligation.
open use "../kernel/prelude.disp"

// honest on the checker's question, junk on real data:
let evil := {n} -> if (is_neutral n) then n else false

test param_apply (Pi Nat ({_} -> Nat)) evil = Ok true   // the certificate (the gap)
test tree_eq (evil 3) false = true                      // the behavior: 3 -> false (a stem, not a Nat)
test param_apply Nat (evil 3) = Ok false                // defense 1: use-site re-check catches the junk

// the type-preserving variant also certifies — a simple-type certificate never
// pinned WHICH function it is (expected; shown as the benign end of the family):
let sneaky := {n} -> if (is_neutral n) then n else (succ n)
test param_apply (Pi Nat ({_} -> Nat)) sneaky = Ok true
test sneaky 3 = 4

// defense 2: theorems at the abstract point cannot be faked this way — the
// neutral branch must produce a real inhabitant of the dependent codomain:
test tree_eq (param_apply (Pi Nat ({n} -> Eq Nat n (succ n))) ({n} -> if (is_neutral n) then refl else refl)) (Ok true) = false
