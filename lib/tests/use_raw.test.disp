// Smoke test: raw import of the kernel fragments, then a normal re-import in that
// context. Proves `use raw` loads values without annotation processing, and the checked
// re-import produces value-identical trees (the second `open` is a no-op iff every name
// matches the raw one — the open conflict check enforces it).
open use raw "../prelude.disp" {}
open use raw "../kernel/cut.disp" {}
open use raw "../kernel/engine.disp" {}
open use raw "../kernel/cells.disp" {}
open use raw "../kernel/base.disp" {}
open use raw "../kernel/positive.disp" {}
open use raw "../kernel/generic.disp" {}
open use raw "../kernel/universe.disp" {}
open use "../kernel/cut.disp" { Type := Type, Tree, Pi, Action, MetaShape, GuardAction, Request }
open use "../kernel/engine.disp" { Type := Type, Tree, Pi, Bool, CheckerResult, Intersection, MetaShape, Module, RespondShape, InductiveRespondShape }
open use "../kernel/cells.disp" { Type := Type, Tree, Pi, Action, Step }
open use "../kernel/base.disp" { Type := Type, Tree, Unit, Bool, Eq }
open use "../kernel/positive.disp" { Type := Type, Tree, Ord }
open use "../kernel/generic.disp" { Type := Type }
open use "../kernel/universe.disp" { Type := Type, RespondShape }

// kernel names are in scope and usable
test param_apply Type Nat = Ok true
test typecheck Type (Pi Nat ({_} -> Bool)) = Ok true

// Deferred self-check: with the raw layer in scope, a fragment's CHECKED module tuple
// { record, typ } carries its annotated exports, resolved against the raw snapshot.
// `verify` routes through `param_apply` (the checker entry) — NOT raw `typ record`
// juxtaposition, which would bypass the walker's parametricity guards. This is the kernel
// typechecking the kernel, under the walker (verify itself is one of the annotated exports).
// TWO witnesses pin the mechanism — the first fragment (cut) and the metacircular one
// (universe). The other five fragments' checks are not repeated here: the driver's
// load-time auto-verification runs the SAME `param_apply typ record` for every fragment
// at every kernel load (each in-language repeat cost ~2-3s of suite time for no new
// discrimination — the 2026-07-08 audit trimmed them).
let cut_mod := use "../kernel/cut.disp" { Type := Type, Tree, Pi, Action, MetaShape, GuardAction, Request }
let universe_mod := use "../kernel/universe.disp" { Type := Type, RespondShape }
test verify cut_mod = Ok true
test verify universe_mod = Ok true
