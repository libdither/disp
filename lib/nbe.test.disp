open use "prelude.disp"
open use "nbe.disp"

// ================================================================
// Tag infrastructure
// ================================================================

test is_tagged (mkVHyp t t) = TT
test is_tagged t = FF
test is_tagged (t t) = FF
test is_tagged (t t t) = FF

test tag_kind (mkVHyp t t) = KV_HYP
test tag_payload (mkVHyp (t t) t) = t (t t) t

// Val recognizers
test is_vhyp (mkVHyp t t) = TT
test is_vhyp t = FF
test is_vstuck (mkVStuck t t) = TT
test is_vstuck t = FF
test is_neutral (mkVHyp t t) = TT
test is_neutral (mkVStuck t t) = TT
test is_neutral t = FF

// Payload accessors
test vhyp_type (mkVHyp (t t) t) = t t
test mkVHyp_prog t t = mkVHyp t t

// ================================================================
// val_apply
// ================================================================

test val_apply ({x} -> x) t = t
test val_apply ({x} -> x) (t t) = t t
test val_apply ({x} -> x) (mkVHyp (t t) t) = mkVHyp (t t) t
test val_apply (mkVHyp t t) (t t) = mkVStuck (mkVHyp t t) (t t)
test val_apply (mkVStuck (mkVHyp t t) t) (t t) = mkVStuck (mkVStuck (mkVHyp t t) t) (t t)
test val_apply t t = t t
test val_apply (t t) (t t) = t t (t t)

// ================================================================
// VStuckElim
// ================================================================

test is_velim (mkVStuckElim t (mkVHyp t t)) = TT
test is_neutral (mkVStuckElim t (mkVHyp t t)) = TT
test velim_motive (mkVStuckElim t (mkVHyp t t)) = t
test velim_target (mkVStuckElim t (mkVHyp t t)) = mkVHyp t t
