// The kernel's own structural types (§11.2 / §12.6), made first-class: Tree, Frame,
// NeutralMeta, Action, RespondShape, MetaShape. Pins (a) that they are types and
// real kernel values inhabit them, (b) the kernel self-typing its metadata via
// auto-verify (make_meta : Tree -> Tree -> MetaShape ; inert_respond : RespondShape),
// and (c) the Rung-3 wall: an INSPECTING respond does not inhabit RespondShape.
open use "../kernel/prelude.disp"

// ---- the structural types are types ----
test typecheck Type Tree        = Ok true
test typecheck Type Frame       = Ok true
test typecheck Type NeutralMeta = Ok true
test typecheck Type Action      = Ok true
test typecheck Type RespondShape = Ok true
test typecheck Type MetaShape   = Ok true

// ---- InvalidType is a REAL empty type now (§12.6 / STRICTTYPE.md step 1) ----
// Promoted from the old `false` sentinel to a make_recognizer wait-form with a MetaShape
// meta, so `type_meta InvalidType` is a real record (no more `.respond` off `false`).
test typecheck Type InvalidType    = Ok true  // it is a Type
test tree_eq InvalidType False     = false      // kept DISTINCT from the empty proposition
test param_apply InvalidType zero  = Ok false   // nothing inhabits it (recognizer is Ok false)

// ---- real kernel values inhabit them ----
test param_apply Tree zero                                       = Ok true // Tree is permissive (any tree)
test param_apply NeutralMeta { stored_type := Nat; payload := (inj "Mint" zero) } = Ok true
test param_apply NeutralMeta { stored_type := Nat; payload := zero } = Ok false // payload must be a Spine now
// Neutral: the type of stuck values (no H-rule nominality — ANY neutral inhabits)
test typecheck Type Neutral = Ok true
test param_apply Neutral (make_hyp Nat 0) = Ok true
test param_apply Neutral zero = Ok false
// Spine: the payload's honest type — a mint (freshness id) or an extension (the PARENT
// NEUTRAL + the frame; storing the parent neutral is how occurs sees through spines)
test typecheck Type Spine = Ok true
test typecheck Spine ((type_meta (make_hyp Nat 0)).payload) = Ok true   // a minted payload is closed
let stuckB := (make_hyp Nat 1) { motive := ({_} -> Bool); cases := { zero := true; succ := ({p, ih} -> ih) } }
// an extended payload CONTAINS the parent neutral, so it is not closed (typecheck Errs at
// the boundary by design); param_apply checks membership directly
test param_apply Spine ((type_meta stuckB).payload) = Ok true
test param_apply NeutralMeta (type_meta stuckB) = Ok true
test param_apply Action (Extend Nat)                             = Ok true
test param_apply Action (Reduce zero)                            = Ok true
test param_apply Action (Reduce (Ok zero))                       = Ok true // the verdict case is an ordinary Reduce
// CheckerResult: BOTH constructors inhabit it. (Err's variant is bare/nullary — Err carries
// payload `t`; the old `Err : Unit` variant demanded `unit_val` and Err did NOT inhabit.)
test param_apply CheckerResult (Ok true)                           = Ok true
test param_apply CheckerResult Err                               = Ok true
test param_apply CheckerResult zero                              = Ok false
// Step: the cell-op answer vocabulary (constructors annotated in cells.disp).
test param_apply Step (SMint Nat)                                = Ok true
test param_apply Step (SThread zero)                             = Ok true
test param_apply Step SReject                                    = Ok true
test param_apply Step (SDone (Extend Nat))                       = Ok true
test param_apply Step zero                                       = Ok false
// a real neutral's meta is a NeutralMeta
test typecheck NeutralMeta (type_meta (make_hyp Nat 0))          = Ok true

// ---- the kernel's metadata records inhabit MetaShape ----
test typecheck MetaShape (make_meta unit_witness inert_respond)  = Ok true
test typecheck MetaShape (type_meta Bool)                        = Ok true // a live type's actual metadata
test typecheck MetaShape (type_meta (Pi Nat ({_} -> Bool)))      = Ok true
test param_apply MetaShape zero                                  = Ok false // a non-record is not a MetaShape

// RespondShape is defined `Tree -> Tree -> Frame -> Action` (the `->` sugar), in a
// raw-loaded kernel fragment. This pins that a `: Type := <arrow>` alias compiles to
// the SAME Pi tree as the function-application `Arrow` form (the raw-load type-mode
// fix) — i.e. `->` is mode-independent for type aliases.
test tree_eq RespondShape (Arrow Tree (Arrow Tree (Arrow Frame Action))) = true

// ---- RespondShape (post §12.6 Part-A re-contract): respond = {params, self, frame} -> Action ----
// hyp_reduce now extracts the metadata once and passes params + reconstructed self, so
// responds no longer raw-read `type_meta` of an abstract stored type. But that alone
// does NOT make the inspecting responds typeable:
// - inert_respond ignores all three args -> parametric -> inhabits RespondShape.
test param_apply RespondShape inert_respond = Ok true
// - inductive/eq/telescope PROJECT off `frame` (`frame.motive`, `pair_fst frame`). Under
//   RespondShape, `frame : Tree` is abstract, so `frame.motive` routes to Tree's inert
//   respond -> InvalidType, and applying that to the self-neutral trips the walker -> Err.
//   Fixing this needs a per-former STRUCTURED Frame type (Part C), so `frame.motive` is a
//   real motive. (When that lands, these flip to Ok true.) The single-use responds are
//   inlined into their formers now, so read them off the live metas.
// (these do NOT inhabit RespondShape — checked robustly as ≠ Ok true, since the
// single-walk `at` makes the rejection a stuck non-verdict rather than a clean Err).
test tree_eq (param_apply RespondShape inductive_respond) (Ok true) = false
test tree_eq (param_apply RespondShape ((type_meta (Eq Nat zero zero)).respond)) (Ok true) = false
test tree_eq (param_apply RespondShape ((type_meta (Telescope t)).respond)) (Ok true) = false
// ...but with the frame STRUCTURED (InductiveFrame), the projecting inductive respond DOES
// inhabit its per-former shape — the §7 wall, validated in-tree (the merged apply_policed
// carve-out makes `frame.motive self` type-check). This is the StrictType-wiring milestone.
test param_apply InductiveRespondShape inductive_respond = Ok true
// And the StrictType-realistic check: pin params to each type's OWN recognizer_params, then
// the PLAIN projecting family inhabits the one ProjectingRespondShape — plain inductive
// (Unit/Ord, params ignored) and Eq's J-rule (reads `params.rhs`, fine once pinned).
test param_apply ProjectingRespondShape ((type_meta Unit).respond (type_meta Unit).recognizer_params) = Ok true
test param_apply ProjectingRespondShape ((type_meta Ord).respond (type_meta Ord).recognizer_params)   = Ok true
test param_apply ProjectingRespondShape ((type_meta (Eq Nat zero zero)).respond (type_meta (Eq Nat zero zero)).recognizer_params) = Ok true
// RESOLVED (R1 seal, ACTIVE_PLAN.md §2): the old "recursive gated Nat doesn't self-type" residual is
// gone. Sealing coh_nat's internal bind_hyp (apply_policed, runtime-identical) makes the gate TOTAL, so
// Nat's respond now inhabits ProjectingRespondShape — like every other respond. CAVEAT: inhabiting
// RespondShape is TOTALITY, not coherence-CORRECTNESS — a do-nothing or reject-everything gate inhabits
// it too. Behavioral correctness (accepts coherent / rejects unknown) is GoodRespond's job (Track 1 L2).
test param_apply ProjectingRespondShape ((type_meta Nat).respond (type_meta Nat).recognizer_params) = Ok true

// NEGATIVE former (Pi): its `at false` respond, params PINNED to the spine `[mint A ; apply (B h)]`,
// inhabits `Self -> A -> Action` — the elimination frame IS the argument (: the domain A), and the
// walk lands `Extend (B arg)`. So for `Pi Nat ({_} -> Bool)` the per-former shape is
// `Tree -> Nat -> Action`. This is §7B self-typing the spine, validated in-tree for the Pi face.
test param_apply (Arrow Tree (Arrow Nat Action)) ((type_meta (Pi Nat ({_} -> Bool))).respond (type_meta (Pi Nat ({_} -> Bool))).recognizer_params) = Ok true
// NEGATIVE formers Sigma/Record (PROJECTION-lead): params PINNED, frame : Frame (Tree). Unlike Pi
// (which APPLIES its codomain to the frame, so frame : A), a projection respond only READS
// `pair_fst frame` and threads `source (acc name)` — no application — so the frame stays abstract
// Tree and the field-name branch doesn't block. Shape `Self -> Frame -> Action`.
test param_apply (Arrow Tree (Arrow Frame Action)) ((type_meta (Sigma Nat ({_} -> Bool))).respond (type_meta (Sigma Nat ({_} -> Bool))).recognizer_params) = Ok true
test param_apply (Arrow Tree (Arrow Frame Action)) ((type_meta (Record (cons (pair "a" Nat) t))).respond (type_meta (Record (cons (pair "a" Nat) t))).recognizer_params) = Ok true
// - Pi's / Nat's responds now TERMINATE (STRICTTYPE.md step 1): with InvalidType a
//   real empty type, eliminating an InvalidType-neutral runs a well-defined inert
//   respond instead of projecting `.respond` out of `false` and looping. They still do
//   NOT inhabit RespondShape (the Part-C reason: `params`/`frame` are unstructured
//   Tree, so projecting off them under abstract inputs is ill-formed) — a stuck
//   non-verdict (≠ Ok true) under the single-walk `at`.
test tree_eq (param_apply RespondShape ((type_meta Nat).respond)) (Ok true) = false
test tree_eq (param_apply RespondShape ((type_meta (Pi Nat ({_} -> Bool))).respond)) (Ok true) = false

// ---- meta_of: typed meta access (the @meta arm of the universe respond) ----
// meta_of : Type -> MetaShape is annotated in universe.disp (auto-verified); re-pinned here:
test param_apply (Arrow Type MetaShape) meta_of = Ok true
test tree_eq (meta_of Nat) (type_meta Nat) = true               // concrete face = type_meta
// on an abstract type the meta is a well-typed STUCK record; projections land field types
let TA := make_hyp Type 0
let mTA := meta_of TA
test is_neutral mTA = true
test neutral_type mTA = MetaShape
test neutral_type (mTA.recognizer_params) = Tree
test neutral_type (mTA.respond) = Tree
// projecting through meta_of TYPES: a field projection of the stuck meta lands the
// field's declared type, so the projecting lambda inhabits Type -> Tree. (This is the
// property the former meta_params/meta_respond accessor exports pinned; deleted
// 2026-07-07 — spell the projection at the use site.)
test param_apply (Arrow Type Tree) ({T} -> (meta_of T).recognizer_params) = Ok true
test param_apply (Arrow Type Tree) ({T} -> (meta_of T).respond)           = Ok true
// collision pin: the one candidate literally shaped like the meta frame goes STUCK under
// an abstract predicate (incompleteness for that tree, not unsoundness; a walked
// membership check maps the non-verdict to rejection)...
test is_neutral (param_apply TA meta_frame) = true
// ...while ordinary candidates still get verdicts (the predicate face is intact)
test param_apply TA zero = Ok false
// and a VALUE-hyp answers no meta: the gate mis-fires on the junk frame and the
// application computes to junk, like any malformed raw frame today (no MetaShape and
// no meta content leaks off a value-hyp)
test is_neutral ((make_hyp Nat 0) meta_frame) = false
test tree_eq (neutral_type ((make_hyp Nat 0) meta_frame)) MetaShape = false
