// Tests for the kernel core (lib/kernel/core.disp): the two-Σ-op shape end
// to end — param_apply dispatch, recognition + H-rule, hyp_reduce spine
// extension via respond, typecheck, and the boundary scan.

open use "../prelude.disp"
open use "../kernel/prelude.disp"

// ---- recognition via param_apply (the dispatcher) ----
test param_apply Bool TT = Ok TT
test param_apply Bool FF = Ok TT
test param_apply Bool zero = Ok FF
test param_apply Nat zero = Ok TT
test param_apply Nat (succ (succ zero)) = Ok TT
test param_apply Nat TT = Ok FF

// ---- typecheck (sanitize + recognize); closed queries only ----
test typecheck Bool TT = Ok TT
test typecheck Nat (succ zero) = Ok TT
test typecheck Bool zero = Ok FF

// param_lift rejects a public neutral
test param_lift (make_hyp Nat 0) = Err
test is_closed (make_hyp Nat 0) = FF
test is_closed (succ zero) = TT

// ---- H-rule via param_apply (reached directly, not through typecheck) ----
let hB = make_hyp Bool 0
let hN = make_hyp Nat 0
test param_apply Bool hB = Ok TT // Bool-hyp inhabits Bool (H-rule)
test param_apply Nat hN = Ok TT
test param_apply Bool hN = Ok FF // Nat-hyp does not inhabit Bool
test param_apply Nat hB = Ok FF

// ---- hyp_reduce spine extension via the (gated) inductive respond ----
// Applying a Nat-neutral to a case-frame { motive; cases } yields a stuck
// elimination: a fresh neutral stored at `motive self`. Under Option A (§7.5)
// hyp_reduce's Extend is BARE, so `stuck` is the neutral itself, not Ok(neutral).
// The respond now gates the cases against the motive (§B), so the cases must be
// COHERENT: with motive Bool, base : Bool and step : Π n. Bool -> Bool.
let motive = {n} -> Bool
let cases = { base := TT; step := ({pred, ih} -> ih) } // base TT : Bool ; step returns ih : Bool
let stuck = param_apply hN { motive := motive; cases := cases }
test is_neutral stuck = TT // bare stuck neutral (Option A)
test is_ok stuck = FF // ...NOT Ok-wrapped
test neutral_type stuck = Bool // motive applied to the reconstructed self

// elim drives the same: concrete target runs the dispatcher, neutral routes here
let nat_dispatcher = {motive, cases, target} -> cases.base // toy: returns base
test elim nat_dispatcher motive cases zero = TT // concrete branch -> base (TT)
test is_neutral (elim nat_dispatcher motive cases hN) = TT // neutral branch

// ---- bind_hyp (Σ-op): mint, run body, escape-check ----
test bind_hyp Nat ({x} -> Ok zero) = Ok zero // result independent of x
test bind_hyp Nat ({x} -> Ok x) = Err // x at public position -> escape
test bind_hyp Nat ({x} -> Ok (pair x zero)) = Err // x inside a user pair -> escape

// ---- raw functions + Pi (monomorphic dependent function) ----
// Functions are raw bracket-abstracted lambdas — no `checked` wrapper. Pi binds
// a fresh A-hyp, applies the candidate, and checks the reduced spine against the
// codomain. Bodies must be walker-safe (no raw triage on the argument). Identity,
// const, and constructor-building bodies (e.g. `succ y`) qualify — the recogniser
// is H-rule-aware at every level (§A). Genuinely case-analysing bodies still route
// through the eliminator, which gates its cases against the motive (§B).
let id_nat = {n} -> n
let const_true = {n} -> TT
test param_apply (Pi Nat ({_} -> Nat)) id_nat = Ok TT // id : Nat -> Nat
test typecheck (Arrow Nat Nat) id_nat = Ok TT // same via Arrow + typecheck
test param_apply (Pi Nat ({_} -> Bool)) const_true = Ok TT // const TT : Nat -> Bool
test param_apply (Pi Nat ({_} -> Nat)) const_true = Ok FF // body returns Bool, not Nat
test param_apply (Pi Bool ({_} -> Nat)) id_nat = Ok FF // domain mismatch -> clean verdict

// (§A) constructor-over-the-argument now checks: the recogniser re-applies the
// H-rule on the neutral predecessor in `succ hyp` instead of triaging it.
test param_apply (Pi Nat ({_} -> Nat)) ({y} -> succ y) = Ok TT

// (§B) the eliminator's cases must inhabit the motive. Enforced in the TYPE's
// respond (keyed off the neutral's stored type), so it is UNBYPASSABLE: the kernel
// recursor, a hand-rolled recursor, and raw neutral application are all gated.
let lying  = {y} -> nat_rec ({_} -> Nat) TT ({p, ih} -> TT) y // base/step Bool, motive says Nat
let lying2 = {y} -> nat_rec ({_} -> Nat) zero ({p, ih} -> TT) y // correct base, lying step
let honest = {y} -> nat_rec ({_} -> Nat) zero ({p, ih} -> succ ih) y
test param_apply (Pi Nat ({_} -> Nat)) lying  = Ok FF // incoherent cases -> rejected
test param_apply (Pi Nat ({_} -> Nat)) lying2 = Ok FF // step lie also caught
test param_apply (Pi Nat ({_} -> Nat)) honest = Ok TT // coherent -> accepted
test honest (succ (succ zero)) = succ (succ zero) // value-transparent on concrete targets

// adversarial: a USER's OWN recursor (own dispatcher, via elim) is gated identically,
// because on a neutral target elim applies the neutral -> the type's respond -> gate.
let my_dispatcher = fix ({self, motive, cases, target} ->
  match (tree_eq target zero) { TT => cases.base; FF => cases.step (pair_snd target) (self motive cases (pair_snd target)) })
let my_rec = {motive, base, step, target} -> elim my_dispatcher motive { base := base; step := step } target
test param_apply (Pi Nat ({_} -> Nat)) ({y} -> my_rec ({_} -> Nat) TT ({p, ih} -> TT) y)        = Ok FF
test param_apply (Pi Nat ({_} -> Nat)) ({y} -> my_rec ({_} -> Nat) zero ({p, ih} -> succ ih) y) = Ok TT
// applying the neutral to a hand-built frame directly is also gated (Option A:
// `y frame` is already a bare stuck neutral, so no must_ok_or_self to unwrap):
test param_apply (Pi Nat ({_} -> Nat)) ({y} -> y { motive := ({_} -> Nat); cases := { base := TT; step := ({p, ih} -> TT) } }) = Ok FF
// and you cannot bypass by DESTRUCTURING the neutral -- triage on a hyp is rejected:
test param_apply (Pi Nat ({_} -> Nat)) ({y} -> pair_snd y) = Err
// the gate is general: Bool's recursor is gated the same way (no recursive args).
test param_apply (Pi Bool ({_} -> Nat)) ({b} -> bool_rec ({_} -> Nat) TT TT b)            = Ok FF
test param_apply (Pi Bool ({_} -> Nat)) ({b} -> bool_rec ({_} -> Nat) zero (succ zero) b)  = Ok TT

// ---- MetaShape metadata is a §2.6 headered record, read BY NAME (the cut) ----
// make_meta builds a `prod`; fields are read by name with the §2.6 cut (.field),
// not positional pair projections.
test (type_meta Unit).respond = inductive_respond // an ungated inductive type
test (type_meta False).respond = inert_respond
test (type_meta Nat).functor = trivial_functor
test (type_meta Type).respond = type_predicate_h_rule
// a hand-built meta round-trips field-by-field
let m = make_meta zero FF
test m.recognizer_params = zero
test m.respond = FF
test has_metashape_layout m = TT
test has_metashape_layout (pair zero (pair TT (pair FF unit_val))) = FF // old positional shape is no longer a meta
// recognizer_params is itself an inline record read by name (Pi's { dom, cod })
test (type_meta (Pi Nat ({_} -> Bool))).recognizer_params.dom = Nat
test (type_meta (Sigma Nat ({_} -> Bool))).recognizer_params.dom = Nat
