// Pin the EXACT trigger of the self-typing failure with minimal responds.
open use "../prelude.disp"
open use "../kernel/prelude.disp"

// R0: constant gate — never touches `cases`. Expect self-types (Ok TT).
test param_apply ProjectingRespondShape ((gated_inductive_respond ({T, m, c} -> Ok FF)) unit_witness) = Ok TT

// R1: gate applies a CONCRETE recognizer (Nat) to the cases-hyp. Expect NOT Ok TT.
test tree_eq (param_apply ProjectingRespondShape ((gated_inductive_respond ({T, m, c} -> param_apply Nat c)) unit_witness)) (Ok TT) = FF

// R2: the SANCTIONED pattern — inductive_respond applies the NEUTRAL motive to self via
// apply_policed. Expect self-types (Ok TT) — this is Unit's/Ord's respond (metashape.test).
test param_apply ProjectingRespondShape (inductive_respond unit_witness) = Ok TT

// R3: gate applies a concrete recognizer to the MOTIVE-hyp m (not cases). Expect NOT Ok TT
// (isolates "concrete recognizer on a hyp", independent of WHICH hyp).
test tree_eq (param_apply ProjectingRespondShape ((gated_inductive_respond ({T, m, c} -> param_apply Bool m)) unit_witness)) (Ok TT) = FF

// R4 (decisive): apply a concrete recognizer to the cases-hyp but DISCARD the result entirely
// (both arms return Ok FF). If this STILL fails, the wall is the walker REJECTING the redex
// `Nat c` structurally — not the value it produces. Expect NOT Ok TT.
test tree_eq (param_apply ProjectingRespondShape ((gated_inductive_respond ({T, m, c} -> match (param_apply Nat c) { Ok v => Ok FF; Err _ => Ok FF })) unit_witness)) (Ok TT) = FF
