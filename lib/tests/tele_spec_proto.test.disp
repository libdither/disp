// tele_spec_proto — STAGE 1 of EFFECT_BOOTSTRAP_PLAN.md: the kernel signature
// and the floor handler (stage 2, tele_spec, split to tele_spec2_proto).
// First seeded (2026-07-07) with hazard 1a's empirical pins: the stage-1 mint
// clause must hand a continuation to the bind_hyp route, and CLAUDE.md's
// compiler-workarounds section documents that a continuation passed THROUGH a
// function miscompiles under nested binders (the fresh hyp leaks into the
// result and trips the escape check). These pins establish, on the live
// compiler, which shapes are actually safe:
//
//   control     inline lambdas at the route (the tele_walk shape) — safe;
//   mint_via    the continuation as a helper PARAMETER, passed on unapplied —
//               the documented wall's minimal form;
//   mint_naive  the innocent wrapper {h} -> kont h — bracket abstraction's
//               eta rule collapses it back to the bare parameter;
//   go_letbound the continuation as a mid-body `let`, closed over the OUTER
//               hyp — the shape the historical miscompile was observed in;
//   mint_keep   {h} -> kont (keep h), keep a top-level identity — the inner
//               application blocks the eta, and keep arriving as a scope
//               literal (not the CIR `I` sentinel) blocks the S (K p) I
//               collapse (the plan's keep trick);
//   floor_rec   the clause as a RECORD field (the stage-1 handler shape);
//   mint_loop   the continuation references a fix `self` and reaches the
//               route through a helper (the walker's historical context).
//
// Every continuation body below USES the outer hyp (`t a b`), the dataflow
// that historically failed, and returns a hyp-free verdict (no real escape).
//
// FINDING (2026-07-07): the documented miscompile does NOT reproduce in any
// of these forms — all ten pins pass on the live compiler. Either an
// intervening compiler change fixed it (candidates: the 2026-06-12 match
// desugar closing the cut over arm free vars; the 2026-07-05 let rework), or
// the failure needed a context these minimal forms still miss. Consequences:
// the stage-1 mint clause can be written in the natural shape
// `{ty, resume} -> param_apply (bind_hyp ty) resume` (mint_via IS that
// clause, pinned nested + fix-self + record-field); the keep trick works and
// stays available if an unpinned context fails; and this file is the
// regression guard either way. CLAUDE.md's inline-lambda rule stays the law
// for KERNEL code (tele_walk's inline mint is not relaxed by these pins).
// Baseline (rust-eager-native, 2026-07-08): ~20s wall, 28 pins (stage 1 landed).
open use "../kernel/prelude.disp"
open use "../std/effect.disp"

// control: inline continuations, nested binders — the safe shape:
test param_apply (bind_hyp Tree) ({a} -> param_apply (bind_hyp Tree) ({b} -> Ok (is_fork (t a b)))) = Ok true

// the helper parameter pass (unapplied):
let mint_via := {ty, kont} -> param_apply (bind_hyp ty) kont
test mint_via Tree ({a} -> Ok (is_fork (t t a))) = Ok true
test mint_via Tree ({a} -> mint_via Tree ({b} -> Ok (is_fork (t a b)))) = Ok true

// the eta-trap wrapper (collapses to the bare parameter):
let mint_naive := {ty, kont} -> param_apply (bind_hyp ty) ({h} -> kont h)
test mint_naive Tree ({a} -> mint_naive Tree ({b} -> Ok (is_fork (t a b)))) = Ok true

// the mid-body let-bound continuation over the outer hyp:
test param_apply (bind_hyp Tree) ({a} -> {
  let go := {b} -> Ok (is_fork (t a b))
  param_apply (bind_hyp Tree) go
}) = Ok true

// the keep trick (the stage-1 mint clause shape):
let keep := {x} -> x
let mint_keep := {ty, kont} -> param_apply (bind_hyp ty) ({h} -> kont (keep h))
test mint_keep Tree ({a} -> Ok (is_fork (t t a))) = Ok true
test mint_keep Tree ({a} -> mint_keep Tree ({b} -> Ok (is_fork (t a b)))) = Ok true
test param_apply (bind_hyp Tree) ({a} -> {
  let go := {b} -> Ok (is_fork (t a b))
  param_apply (bind_hyp Tree) ({h} -> go (keep h))
}) = Ok true

// the clause as a record field (how the stage-1 floor handler will carry it):
let floor_rec := { on_mint := {ty, kont} -> param_apply (bind_hyp ty) ({h} -> kont (keep h)) }
test (floor_rec.on_mint) Tree ({a} -> (floor_rec.on_mint) Tree ({b} -> Ok (is_fork (t a b)))) = Ok true

// the closest repro of the HISTORICAL context: the continuation references a
// fix `self` (the walker's shape — "a continuation {h} -> self ... h passed
// THROUGH a function") and reaches the route through the helper. This is the
// exact dataflow the stage-1 handler has (handle's fold hands the clause a
// resume that closes over the fold's self):
let mint_loop := fix ({self, n, acc} ->
  if (tree_eq n zero) then (Ok acc)
  else (mint_via Tree ({h} -> self (nat_pred n) (is_fork (t acc h)))))
test mint_loop 2 t = Ok true

// ═══ STAGE 1: the kernel signature and the floor handler ═══
// One op table for exactly the capabilities the walker cannot walk (seal(Σ)),
// one handler interpreting them, clauses wrapping the sealed bodies verbatim.
// Sanctioned-pure operations (tree_eq, the plain pair_fst read) are NOT ops:
// they run natively under the walker already. Self-describing occurrences
// make DEPENDENT result types free: mint's result is its own argument, and
// extend's is the requested new stored type.
//
// THE LEDGER — op | clause wraps | replaces | soundness note:
//   classify v     is_hyp_fork guard + raw triage | the SEALED(reflection)
//                  reads | answers `hyp` for anything wearing the hyp shape,
//                  forged forks included — exactly the answer w_stem needs;
//                  the payload stays unreadable (only neutral_type escapes).
//   mint ty        param_apply (bind_hyp ty) resume | SEALED(forge) make_hyp
//                  + the Σ route | the handled carrier must be CheckerResult:
//                  the escape check BINDS the tail, so the floor inherits
//                  bind_hyp's escape discipline (a leaked `Ok h` answers Err,
//                  pinned). A tail that is NOT a CheckerResult (e.g. the bare
//                  request, whose tail is the hyp itself) makes the escape
//                  bind a mis-tagged cut: the result is INERT JUNK, not Err
//                  and not the hyp (pinned). The carrier discipline is the
//                  program author's obligation.
//   check ty v     param_apply | the policed §7A route (do_check's) | a pure
//                  wrapper; verdicts identical by construction, pinned.
//   extend n ty f  the wait hyp_reduce { stored_type; Ext(n, f) } build |
//                  SEALED(Σ-op) hyp_reduce's Extend branch | does NOT consult
//                  the respond — the requester chooses ty, which is the forge
//                  power; floor-only by design (forge(Σ) as a table row).
//
// the response vocabulary as a real Coproduct (hazard 0a chain, item 1). The
// tags match the reflect prototype's raw inj forms, so these answers are
// tree-identical to that arc's handler answers:
ShapeR : Type := Coproduct [pair "leaf" [], pair "stem" [Tree], pair "fork" [Tree, Tree], pair "hyp" [Type]]

let k_classify := mk_op "Reflect" "classify" Tree ShapeR
let k_mint := {ty} -> io_op { label := pair "Mint" "mint"; param := Type; result := ty } ty ({r} -> io_pure r)
let k_check := {ty, v} -> (mk_op "Check" "check" Tree CheckerResult) (pair ty v)
let k_extend := {n, ty, frame} -> io_op { label := pair "Extend" "extend"; param := Tree; result := ty } (pair n (pair ty frame)) ({r} -> io_pure r)
let kernel_row := mk_row (cons "Reflect" (cons "Mint" (cons "Check" (cons "Extend" nil))))

// the floor handler: THE enumerated place that looks. return is bare (the
// carrier is CheckerResult or a kernel answer, never re-wrapped) so the mint
// clause can feed the handled tail straight into the escape check.
let is_hyp_fork_l := {v} -> and (is_fork v) (tree_eq (pair_fst v) hyp_sig)
let classify_answer := {v} -> if (is_hyp_fork_l v) then (inj1 "hyp" (neutral_type v)) else (triage (inj0 "leaf") ({c} -> inj1 "stem" c) ({l, r} -> inj2 "fork" l r) v)
let extend_build := {n, ty, frame} -> wait hyp_reduce { stored_type := ty; payload := inj "Ext" (pair n frame) }
let floor_on := {op} -> {arg, resume} ->
  if (tree_eq (op_name op) "classify") then (resume (classify_answer arg))
  else (if (tree_eq (op_name op) "mint") then (param_apply (bind_hyp arg) resume)
  else (if (tree_eq (op_name op) "check") then (resume (param_apply (pair_fst arg) (pair_snd arg)))
  else (resume (extend_build (pair_fst arg) (pair_fst (pair_snd arg)) (pair_snd (pair_snd arg))))))
let floor_h := { covers := {op} -> label_in_row (effect_of op) kernel_row; return := {x} -> x; on := floor_on; forward := default_forward }
let run_floor := handle floor_h

// requests are typed VALUES at their rows (asking is typed), including over
// a hypothesis, and mint/extend demonstrate the dependent result:
test param_apply (Eff (row1 "Reflect") ShapeR) (k_classify t) = Ok true
test param_apply (Eff (row1 "Reflect") ShapeR) (k_classify (make_hyp Tree 0)) = Ok true
test param_apply (Eff (row1 "Mint") Nat) (k_mint Nat) = Ok true
test param_apply (Eff (row1 "Check") CheckerResult) (k_check Nat 3) = Ok true
let hf := make_hyp (Arrow Nat Nat) 7
test param_apply (Eff (row1 "Extend") Nat) (k_extend hf Nat 3) = Ok true
test param_apply (Eff (row1 "Reflect") ShapeR) (k_mint Nat) = Ok false     // wrong row rejects

// the handler reproduces the sealed behaviors on concrete data —
// classify, all four shapes:
test run_floor (k_classify t) = inj0 "leaf"
test run_floor (k_classify (t t)) = inj1 "stem" t
test run_floor (k_classify (t t t)) = inj2 "fork" t t
test run_floor (k_classify (make_hyp Nat 0)) = inj1 "hyp" Nat
// check agrees with param_apply by construction:
test run_floor (k_check Nat 3) = param_apply Nat 3
test run_floor (k_check Nat false) = param_apply Nat false
// extend builds the SAME tree the walker's hyp_reduce Extend builds:
test run_floor (k_extend hf Nat 3) = param_apply hf 3
// mint: freshness, use, and the inherited escape discipline:
test run_floor (eff_bind (k_mint Nat) ({h} -> io_pure (Ok (is_neutral h)))) = Ok true
test run_floor (eff_bind (k_mint Nat) ({a} -> eff_bind (k_mint Nat) ({b} -> io_pure (Ok (tree_eq a b))))) = Ok false
test run_floor (eff_bind (k_mint Nat) ({h} -> io_pure (Ok h))) = Err
// a bare mint request violates the carrier contract (its tail is the hyp,
// not a CheckerResult): the escape bind becomes a mis-tagged cut and the
// result is inert junk — not Err, and not the hyp:
test is_neutral (run_floor (k_mint Nat)) = false
test tree_eq (run_floor (k_mint Nat)) Err = false
