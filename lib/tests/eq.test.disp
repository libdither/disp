// Tests for the Eq library type (predicate_frame + eliminator_frame).
//
// Covers:
//   1. Eq predicate recognises refl only when endpoints match.
//   2. refl is well-typed (Eq A x x) for Nat and Bool values.
//   3. eq_J on a basic motive ({a} -> Eq Nat zero a style).
//   4. eq_subst transports a value across an equality.
//   5. eq_sym: symmetry of equality.
//   6. eq_cong: congruence under a function.
//   7. Hypothesis-typed proof targets produce stuck neutrals via eliminator_frame.
//   8. Negative cases: malformed Eq arguments rejected.

open use "../prelude.disp"
open use "../kernel/prelude.disp"
open use "../std/nat/arith.disp"

// ================================================================
// Eq predicate: refl and non-refl witnesses
// ================================================================

// refl = t (LEAF). Eq Nat 0 0 accepts refl.
test (Eq Nat 0 0) refl = TT

// Same for succ values.
test (Eq Nat 1 1) refl = TT
test (Eq Nat 3 3) refl = TT

// Eq Bool TT TT / FF FF.
test (Eq Bool TT TT) refl = TT
test (Eq Bool FF FF) refl = TT

// Endpoints must match: 0 ≠ 1, so refl is rejected.
test (Eq Nat 0 1) refl = FF
test (Eq Nat 1 0) refl = FF
test (Eq Nat 2 3) refl = FF

// Wrong witness shape: FF is not refl.
test (Eq Nat 0 0) FF = FF

// A fork is not refl.
test (Eq Nat 0 0) (t t) = FF

// ================================================================
// eq_J: basic eliminator
// ================================================================

// eq_J A x motive base y proof
// For closed refl (y = x, proof = refl): reduces to base.
test eq_J Nat 0 ({y, p} -> Nat) 5 0 refl = 5

// motive that computes from y.
test eq_J Nat 0 ({y, p} -> y) 0 0 refl = 0

// motive Eq Nat zero a: proves `0 = 0` from `refl`.
// motive = {a, _p} -> Eq Nat 0 a; base = refl; y = 0; proof = refl
let motive_eq_zero = {a, _p} -> Eq Nat 0 a
test (Eq Nat 0 0) (eq_J Nat 0 motive_eq_zero refl 0 refl) = TT

// eq_J with succ endpoints.
test eq_J Nat 1 ({y, p} -> Nat) 42 1 refl = 42

// ================================================================
// eq_subst: transport a value across an equality
// ================================================================

// eq_subst A P x y p px:
//   given p : Eq A x y, px : P x, produce : P y.
// For closed refl: x = y, so P x = P y, result = px.
test eq_subst Nat ({_} -> Nat) 0 0 refl 7 = 7
test eq_subst Nat ({_} -> Bool) 0 0 refl TT = TT

// With a nontrivial predicate P = {n} -> Eq Nat n n.
let P_refl = {n} -> Eq Nat n n
test (Eq Nat 0 0) (eq_subst Nat P_refl 0 0 refl refl) = TT

// ================================================================
// eq_sym: symmetry
// ================================================================

// eq_sym A x y p : Eq A y x.
// For closed refl: returns refl.
let sym_proof = eq_sym Nat 0 0 refl
test (Eq Nat 0 0) sym_proof = TT

// Symmetry with succ.
test (Eq Nat 2 2) (eq_sym Nat 2 2 refl) = TT

// ================================================================
// eq_cong: congruence under a function
// ================================================================

// eq_cong A B f x y p : Eq B (f x) (f y).
// f = succ: Eq Nat (succ 0) (succ 0).
let cong_succ = eq_cong Nat Nat succ 0 0 refl
test (Eq Nat 1 1) cong_succ = TT

// f = {n} -> 0 (constant): Eq Nat 0 0.
let cong_const = eq_cong Nat Nat ({_} -> 0) 3 3 refl
test (Eq Nat 0 0) cong_const = TT

// f = {x} -> add x 1.
let cong_add1 = eq_cong Nat Nat ({x} -> add x 1) 2 2 refl
test (Eq Nat 3 3) cong_add1 = TT

// ================================================================
// Hypothesis proof target: eliminator_frame mints stuck neutral
// ================================================================

let eq_hyp = Hyp (Eq Nat 0 0) 0

// eq_J with a hypothesis proof: produces a neutral (stuck eliminator).
let stuck_j = eq_J Nat 0 ({_y, _p} -> Nat) 5 0 eq_hyp
test is_neutral stuck_j = TT
// Stored type is the motive applied to the target's endpoints.
test neutral_type stuck_j = Nat

// eq_sym on a hypothesis proof produces a neutral.
let stuck_sym = eq_sym Nat 0 0 eq_hyp
test is_neutral stuck_sym = TT
test neutral_type stuck_sym = Eq Nat 0 0

// eq_cong on a hypothesis proof produces a neutral.
let stuck_cong = eq_cong Nat Nat succ 0 0 eq_hyp
test is_neutral stuck_cong = TT
test neutral_type stuck_cong = Eq Nat 1 1

// eq_subst on a hypothesis proof produces a neutral.
let stuck_subst = eq_subst Nat ({_} -> Nat) 0 0 eq_hyp 5
test is_neutral stuck_subst = TT
test neutral_type stuck_subst = Nat

// ================================================================
// Negative cases: malformed Eq calls rejected
// ================================================================

// A non-type as the type parameter: structurally, Eq still builds
// a wait-form, but TT as witness is not refl.
test (Eq Nat 0 0) TT = FF

// Eq checked against a hypothesis: public boundary scans for neutrals
// and rejects any pre-existing neutral input.
let nat_hyp = Hyp Nat 0
test (Eq Nat 0 0) nat_hyp = FF

// ================================================================
// is_eq reflection helper
// ================================================================

test is_eq (Eq Nat 0 0) = TT
test is_eq (Eq Bool TT FF) = TT
test is_eq Nat = FF
test is_eq Bool = FF
test is_eq t = FF

// Adversarial: trivially-accepting checker with Eq-like metadata.
let fakeEq = wait ({_meta, _x} -> TT) (t Nat (t 0 0))
test is_eq fakeEq = FF
