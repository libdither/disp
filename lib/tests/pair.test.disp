open use "../prelude.disp"
open use "../kernel/prelude.disp"
open use "../std/pair.disp"

// Constructors and accessors
test pair_fst (pair 1 2) = 1
test pair_snd (pair 1 2) = 2

// Pair A B is a Sigma type — recognized through the kernel (Ok-wrapped verdict).
test typecheck (Pair Nat Nat) (pair 0 0) = Ok TT
test typecheck (Pair Nat Nat) (pair 3 7) = Ok TT
test typecheck (Pair Nat Bool) (pair 1 TT) = Ok TT
test typecheck (Pair Bool Nat) (pair FF 5) = Ok TT

// Rejects ill-typed contents
test typecheck (Pair Bool Nat) (pair 1 5) = Ok FF

// Helpers
test pair_map_fst succ (pair 1 9) = pair 2 9
test pair_map_snd succ (pair 1 9) = pair 1 10
test pair_swap (pair 1 9) = pair 9 1

// Pair under a Pi binder — exercises is_neutral permissiveness.
let snd_of_nats : Pair Nat Nat -> Nat = {p} -> pair_snd p
test snd_of_nats (pair 4 7) = 7
